{% extends 'admin/base.html.twig' %}

{% block title %}Admin Blog{% endblock %}
{% block admin_page_title %}Blog{% endblock %}
{% block admin_page_intro %}Gestion des articles, recherche et edition.{% endblock %}

{% block admin_toolbar %}
  <form method="get" action="{{ path('admin_blog') }}" class="ds-search-form ds-toolbar-grow">
    <input
      type="text"
      name="q"
      value="{{ q }}"
      placeholder="Rechercher un article"
      class="ds-input"
    >
    <button type="submit" class="ds-btn ds-btn--secondary">Rechercher</button>
  </form>

  <a href="{{ path('admin_article_new') }}" class="ds-btn ds-btn--primary">Nouvel article</a>
{% endblock %}

{% block admin_content %}
  <div class="ds-surface ds-table-wrap">
    <table class="ds-table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Apercu</th>
          <th>Slug FR</th>
          <th>Slug EN</th>
          <th>Publication</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {% for a in articles %}
          <tr>
            <td class="ds-title-strong">#{{ a.id }}</td>
            <td>
              {% if a.coverImage %}
                <img src="{{ asset('uploads/blog/' ~ a.coverImage) }}" alt="Cover" class="ds-media-thumb">
              {% else %}
                <span class="ds-muted">-</span>
              {% endif %}
            </td>
            <td class="ds-text-break">{{ a.slugFr }}</td>
            <td class="ds-text-break">{{ a.slugEn ?: '-' }}</td>
            <td>
              {% include 'components/ui/status_badge.html.twig' with {
                label: a.publishedAt ? a.publishedAt|date('d/m/Y H:i') : '-',
                tone: 'success'
              } only %}
            </td>
            <td>
              <div class="ds-actions-stack">
                <a href="{{ path('admin_article_edit', {id: a.id}) }}" class="ds-btn ds-btn--secondary ds-btn--block">Editer</a>
                <form method="post" action="{{ path('admin_article_delete', {id: a.id}) }}" class="ds-inline-form" onsubmit="return confirm('Supprimer cet article ?');">
                  <input type="hidden" name="_token" value="{{ csrf_token('delete_article_' ~ a.id) }}">
                  <button type="submit" class="ds-btn ds-btn--danger ds-btn--block">Supprimer</button>
                </form>
              </div>
            </td>
          </tr>
        {% else %}
          <tr>
            <td colspan="6" class="ds-empty">Aucun article trouve.</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
{% endblock %}
