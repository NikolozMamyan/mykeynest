{% extends 'admin/base.html.twig' %}

{% block title %}Admin Extensions{% endblock %}
{% block admin_page_class %}ds-page--wide{% endblock %}
{% block admin_page_title %}Extension Installation{% endblock %}
{% block admin_page_intro %}Visibilite sur les clients extension installes et les demandes d installation en attente.{% endblock %}

{% block admin_content %}
  <section class="ds-surface">
    <div class="ds-section-head">
      <div>
        <h2 class="ds-section-title">Clients extension</h2>
        <p class="ds-section-text">Derniers clients vus avec statut de revocation ou blocage.</p>
      </div>
    </div>

    <div class="ds-table-wrap">
      <table class="ds-table">
        <thead>
          <tr>
            <th>Utilisateur</th>
            <th>Client</th>
            <th>Environnement</th>
            <th>Activite</th>
            <th>Statut</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {% for client in clients %}
            <tr>
              <td>
                <div class="ds-cell-stack">
                  <span class="ds-title-strong">{{ client.user.email }}</span>
                  <span class="ds-muted">{{ client.user.company ?: '-' }}</span>
                </div>
              </td>
              <td>
                <div class="ds-cell-stack">
                  <span class="ds-mono">{{ client.clientId }}</span>
                  <span>{{ client.deviceLabel ?: 'Appareil inconnu' }}</span>
                </div>
              </td>
              <td>
                <div class="ds-cell-stack">
                  <span>{{ client.browserName ?: '-' }} {{ client.browserVersion ?: '' }}</span>
                  <span>{{ client.osName ?: '-' }} {{ client.osVersion ?: '' }}</span>
                  <span>Extension {{ client.extensionVersion ?: '-' }} / manifest {{ client.manifestVersion ?: '-' }}</span>
                  <span class="ds-muted">{{ client.originType ?: '-' }}</span>
                </div>
              </td>
              <td>
                <div class="ds-cell-stack">
                  <span>Premier: {{ client.firstSeenAt ? client.firstSeenAt|date('d/m/Y H:i') : '-' }}</span>
                  <span>Dernier: {{ client.lastSeenAt ? client.lastSeenAt|date('d/m/Y H:i') : '-' }}</span>
                  <span class="ds-mono">{{ client.lastIpAddress ?: '-' }}</span>
                </div>
              </td>
              <td>
                {% if client.isBlocked %}
                  {% include 'components/ui/status_badge.html.twig' with { label: 'bloquee', tone: 'danger' } only %}
                {% elseif client.isRevoked %}
                  {% include 'components/ui/status_badge.html.twig' with { label: 'revoquee', tone: 'warning' } only %}
                {% else %}
                  {% include 'components/ui/status_badge.html.twig' with { label: 'active', tone: 'success' } only %}
                {% endif %}

                <div class="ds-cell-stack" style="margin-top:0.5rem;">
                  {% if client.blockedReason %}
                    <span class="ds-muted">Blocage: {{ client.blockedReason }}</span>
                  {% endif %}
                  {% if client.revokedReason %}
                    <span class="ds-muted">Revocation: {{ client.revokedReason }}</span>
                  {% endif %}
                </div>
              </td>
              <td>
                <div class="ds-actions-stack">
                  {% if not client.isRevoked %}
                    <form method="post" action="{{ path('admin_extension_client_revoke', {id: client.id}) }}" class="ds-inline-form" onsubmit="return confirm('Revoquer ce client extension ?');">
                      <input type="hidden" name="_token" value="{{ csrf_token('admin_revoke_extension_' ~ client.id) }}">
                      <button type="submit" class="ds-btn ds-btn--warning ds-btn--block">Revoquer</button>
                    </form>
                  {% endif %}

                  {% if not client.isBlocked %}
                    <form method="post" action="{{ path('admin_extension_client_block', {id: client.id}) }}" class="ds-inline-form" onsubmit="return confirm('Bloquer ce client extension ?');">
                      <input type="hidden" name="_token" value="{{ csrf_token('admin_block_extension_' ~ client.id) }}">
                      <button type="submit" class="ds-btn ds-btn--danger ds-btn--block">Bloquer</button>
                    </form>
                  {% else %}
                    <form method="post" action="{{ path('admin_extension_client_unblock', {id: client.id}) }}" class="ds-inline-form" onsubmit="return confirm('Debloquer ce client extension ?');">
                      <input type="hidden" name="_token" value="{{ csrf_token('admin_unblock_extension_' ~ client.id) }}">
                      <button type="submit" class="ds-btn ds-btn--success ds-btn--block">Debloquer</button>
                    </form>
                  {% endif %}
                </div>
              </td>
            </tr>
          {% else %}
            <tr>
              <td colspan="6" class="ds-empty">Aucun client extension a afficher.</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>

  <section class="ds-surface">
    <div class="ds-section-head">
      <div>
        <h2 class="ds-section-title">Demandes d installation</h2>
        <p class="ds-section-text">Historique des challenges d approbation envoyes par e-mail.</p>
      </div>
    </div>

    <div class="ds-table-wrap">
      <table class="ds-table">
        <thead>
          <tr>
            <th>Utilisateur</th>
            <th>Client demande</th>
            <th>Contexte</th>
            <th>Dates</th>
            <th>Statut</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {% for challenge in challenges %}
            <tr>
              <td>
                <div class="ds-cell-stack">
                  <span class="ds-title-strong">{{ challenge.user.email }}</span>
                  <span class="ds-mono">{{ challenge.publicId }}</span>
                </div>
              </td>
              <td>
                <div class="ds-cell-stack">
                  <span class="ds-mono">{{ challenge.requestedClientId }}</span>
                  <span>{{ challenge.deviceLabel ?: 'Appareil inconnu' }}</span>
                </div>
              </td>
              <td>
                <div class="ds-cell-stack">
                  <span>{{ challenge.browserName ?: '-' }} {{ challenge.browserVersion ?: '' }}</span>
                  <span>{{ challenge.osName ?: '-' }} {{ challenge.osVersion ?: '' }}</span>
                  <span>Extension {{ challenge.extensionVersion ?: '-' }}</span>
                  <span class="ds-mono">{{ challenge.ipAddress ?: '-' }}</span>
                </div>
              </td>
              <td>
                <div class="ds-cell-stack">
                  <span>Cree: {{ challenge.createdAt ? challenge.createdAt|date('d/m/Y H:i') : '-' }}</span>
                  <span>Expire: {{ challenge.expiresAt ? challenge.expiresAt|date('d/m/Y H:i') : '-' }}</span>
                  <span>Approve: {{ challenge.approvedAt ? challenge.approvedAt|date('d/m/Y H:i') : '-' }}</span>
                  <span>Reject: {{ challenge.rejectedAt ? challenge.rejectedAt|date('d/m/Y H:i') : '-' }}</span>
                </div>
              </td>
              <td>
                {% if challenge.status == 'approved' %}
                  {% include 'components/ui/status_badge.html.twig' with { label: 'approved', tone: 'success' } only %}
                {% elseif challenge.status == 'pending' %}
                  {% include 'components/ui/status_badge.html.twig' with { label: 'pending', tone: 'warning' } only %}
                {% elseif challenge.status == 'rejected' %}
                  {% include 'components/ui/status_badge.html.twig' with { label: 'rejected', tone: 'danger' } only %}
                {% elseif challenge.status == 'completed' %}
                  {% include 'components/ui/status_badge.html.twig' with { label: 'completed', tone: 'success' } only %}
                {% else %}
                  {% include 'components/ui/status_badge.html.twig' with { label: challenge.status, tone: 'muted' } only %}
                {% endif %}
              </td>
              <td>
                <div class="ds-actions-stack">
                  {% if challenge.status == 'pending' and challenge.expiresAt and challenge.expiresAt > date() %}
                    <form method="post" action="{{ path('admin_extension_challenge_approve', {id: challenge.id}) }}" class="ds-inline-form" onsubmit="return confirm('Approuver cette installation ?');">
                      <input type="hidden" name="_token" value="{{ csrf_token('admin_approve_extension_challenge_' ~ challenge.id) }}">
                      <button type="submit" class="ds-btn ds-btn--success ds-btn--block">Approuver</button>
                    </form>
                    <form method="post" action="{{ path('admin_extension_challenge_reject', {id: challenge.id}) }}" class="ds-inline-form" onsubmit="return confirm('Rejeter cette installation ?');">
                      <input type="hidden" name="_token" value="{{ csrf_token('admin_reject_extension_challenge_' ~ challenge.id) }}">
                      <button type="submit" class="ds-btn ds-btn--danger ds-btn--block">Rejeter</button>
                    </form>
                  {% else %}
                    <span class="ds-muted">Aucune action</span>
                  {% endif %}
                </div>
              </td>
            </tr>
          {% else %}
            <tr>
              <td colspan="6" class="ds-empty">Aucune demande d installation a afficher.</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
{% endblock %}
