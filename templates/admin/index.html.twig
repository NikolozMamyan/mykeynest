{% extends 'admin/base.html.twig' %}

{% block title %}Dashboard Admin{% endblock %}
{% block admin_page_title %}Dashboard Admin{% endblock %}
{% block admin_page_intro %}Administration structuree par domaine pour eviter le melange entre blog, subscriptions, sessions et extension.{% endblock %}

{% block admin_content %}
  <section class="ds-grid-3">
    {% include 'components/ui/metric_card.html.twig' with { label: 'Articles blog', value: articlesCount } only %}
    {% include 'components/ui/metric_card.html.twig' with { label: 'Utilisateurs', value: usersCount } only %}
    {% include 'components/ui/metric_card.html.twig' with { label: 'Subscriptions actives', value: activeSubscriptionsCount } only %}
  </section>

  <section class="ds-grid-2">
    <div class="ds-surface">
      <div class="ds-section-head">
        <div>
          <h2 class="ds-section-title">Blog</h2>
          <p class="ds-section-text">Derniers articles publies.</p>
        </div>
        <a class="ds-section-link" href="{{ path('admin_blog') }}">Ouvrir</a>
      </div>

      <div class="ds-table-wrap">
        <table class="ds-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Titre</th>
              <th>Publication</th>
            </tr>
          </thead>
          <tbody>
            {% for article in recentArticles %}
              <tr>
                <td>#{{ article.id }}</td>
                <td class="ds-title-strong">{{ article.h1Fr ?: article.slugFr }}</td>
                <td>{{ article.publishedAt ? article.publishedAt|date('d/m/Y H:i') : '-' }}</td>
              </tr>
            {% else %}
              <tr>
                <td colspan="3" class="ds-empty">Aucun article a afficher.</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>

    <div class="ds-surface">
      <div class="ds-section-head">
        <div>
          <h2 class="ds-section-title">Subscriptions</h2>
          <p class="ds-section-text">Derniers comptes et etat d abonnement.</p>
        </div>
        <a class="ds-section-link" href="{{ path('admin_subscriptions') }}">Ouvrir</a>
      </div>

      <div class="ds-table-wrap">
        <table class="ds-table">
          <thead>
            <tr>
              <th>Utilisateur</th>
              <th>Plan</th>
              <th>Statut</th>
            </tr>
          </thead>
          <tbody>
            {% for user in recentUsers %}
              {% set subscription = user.userSubscription %}
              <tr>
                <td class="ds-title-strong">{{ user.email }}</td>
                <td>{{ subscription and subscription.planCode ? subscription.planCode|upper : 'FREE' }}</td>
                <td>
                  {% if subscription and subscription.isActive %}
                    {% include 'components/ui/status_badge.html.twig' with { label: subscription.status ?: 'active', tone: 'success' } only %}
                  {% elseif subscription %}
                    {% include 'components/ui/status_badge.html.twig' with { label: subscription.status ?: 'inactive', tone: 'warning' } only %}
                  {% else %}
                    {% include 'components/ui/status_badge.html.twig' with { label: 'aucun', tone: 'muted' } only %}
                  {% endif %}
                </td>
              </tr>
            {% else %}
              <tr>
                <td colspan="3" class="ds-empty">Aucun utilisateur a afficher.</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </section>
{% endblock %}
