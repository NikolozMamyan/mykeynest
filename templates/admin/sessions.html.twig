{% extends 'admin/base.html.twig' %}

{% block title %}Admin Sessions{% endblock %}
{% block admin_page_class %}ds-page--wide{% endblock %}
{% block admin_page_title %}Sessions{% endblock %}
{% block admin_page_intro %}Surveillance des sessions users avec actions de revocation et blocage appareil.{% endblock %}

{% block admin_content %}
  <div class="ds-surface ds-table-wrap">
    <table class="ds-table">
      <thead>
        <tr>
          <th>Utilisateur</th>
          <th>Appareil</th>
          <th>Reseau</th>
          <th>Activite</th>
          <th>Statut</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {% for session in sessions %}
          <tr>
            <td>
              <div class="ds-cell-stack">
                <span class="ds-title-strong">#{{ session.id }} {{ session.user.email }}</span>
                <span class="ds-muted">{{ session.user.company ?: '-' }}</span>
              </div>
            </td>
            <td>
              <div class="ds-cell-stack">
                <span class="ds-title-strong">{{ session.deviceName ?: 'Appareil inconnu' }}</span>
                <span class="ds-mono">{{ session.deviceId ?: 'device: -' }}</span>
                <span class="ds-muted ds-text-break">{{ session.userAgent ?: '-' }}</span>
              </div>
            </td>
            <td><span class="ds-mono">{{ session.ipAddress ?: '-' }}</span></td>
            <td>
              <div class="ds-cell-stack">
                <span>Creee: {{ session.createdAt ? session.createdAt|date('d/m/Y H:i') : '-' }}</span>
                <span>Derniere activite: {{ session.lastActivityAt ? session.lastActivityAt|date('d/m/Y H:i') : '-' }}</span>
                <span>Expire: {{ session.expiresAt ? session.expiresAt|date('d/m/Y H:i') : '-' }}</span>
              </div>
            </td>
            <td>
              <div class="ds-badges">
                {% if session.isBlocked %}
                  {% include 'components/ui/status_badge.html.twig' with { label: 'bloquee', tone: 'danger' } only %}
                {% endif %}
                {% if session.isRevoked %}
                  {% include 'components/ui/status_badge.html.twig' with { label: 'revoquee', tone: 'warning' } only %}
                {% endif %}
                {% if not session.isBlocked and not session.isRevoked and session.expiresAt and session.expiresAt > date() %}
                  {% include 'components/ui/status_badge.html.twig' with { label: 'active', tone: 'success' } only %}
                {% endif %}
                {% if session.expiresAt and session.expiresAt <= date() %}
                  {% include 'components/ui/status_badge.html.twig' with { label: 'expiree', tone: 'muted' } only %}
                {% endif %}
              </div>
              <div class="ds-cell-stack" style="margin-top:0.5rem;">
                {% if session.blockedReason %}
                  <span class="ds-muted">Blocage: {{ session.blockedReason }}</span>
                {% endif %}
                {% if session.revokedReason %}
                  <span class="ds-muted">Revocation: {{ session.revokedReason }}</span>
                {% endif %}
              </div>
            </td>
            <td>
              <div class="ds-actions-stack">
                {% if not session.isRevoked %}
                  <form method="post" action="{{ path('admin_session_revoke', {id: session.id}) }}" class="ds-inline-form" onsubmit="return confirm('Revoquer cette session ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_revoke_session_' ~ session.id) }}">
                    <button type="submit" class="ds-btn ds-btn--warning ds-btn--block">
                      <i class="fas fa-ban"></i>
                      <span>Revoquer</span>
                    </button>
                  </form>
                {% endif %}

                {% if session.deviceId and not session.isBlocked %}
                  <form method="post" action="{{ path('admin_session_block_device', {id: session.id}) }}" class="ds-inline-form" onsubmit="return confirm('Bloquer cet appareil et ses sessions ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_block_device_' ~ session.id) }}">
                    <button type="submit" class="ds-btn ds-btn--danger ds-btn--block">
                      <i class="fas fa-user-lock"></i>
                      <span>Bloquer appareil</span>
                    </button>
                  </form>
                {% endif %}

                {% if session.deviceId and session.isBlocked %}
                  <form method="post" action="{{ path('admin_session_unblock_device', {id: session.id}) }}" class="ds-inline-form" onsubmit="return confirm('Debloquer cet appareil ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_unblock_device_' ~ session.id) }}">
                    <button type="submit" class="ds-btn ds-btn--success ds-btn--block">
                      <i class="fas fa-unlock"></i>
                      <span>Debloquer appareil</span>
                    </button>
                  </form>
                {% endif %}
              </div>
            </td>
          </tr>
        {% else %}
          <tr>
            <td colspan="6" class="ds-empty">Aucune session a afficher.</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
{% endblock %}
