{% extends 'admin/base.html.twig' %}

{% block title %}Admin Subscriptions{% endblock %}
{% block admin_page_title %}Subscriptions{% endblock %}
{% block admin_page_intro %}Vue rapide des 100 derniers comptes avec leur statut d abonnement.{% endblock %}

{% block admin_toolbar %}
  <form method="get" action="{{ path('admin_subscriptions') }}" class="ds-search-form ds-toolbar-grow">
    <input class="ds-input" type="search" name="q" value="{{ filters.q }}" placeholder="Email, entreprise ou ID">
    <select class="ds-select" name="subscription">
      <option value="all" {{ filters.subscription == 'all' ? 'selected' : '' }}>Tous abonnements</option>
      <option value="active" {{ filters.subscription == 'active' ? 'selected' : '' }}>Actifs</option>
      <option value="inactive" {{ filters.subscription == 'inactive' ? 'selected' : '' }}>Inactifs</option>
      <option value="free" {{ filters.subscription == 'free' ? 'selected' : '' }}>Sans abonnement</option>
    </select>
    <select class="ds-select" name="role">
      <option value="all" {{ filters.role == 'all' ? 'selected' : '' }}>Tous roles</option>
      <option value="admin" {{ filters.role == 'admin' ? 'selected' : '' }}>Admins</option>
      <option value="user" {{ filters.role == 'user' ? 'selected' : '' }}>Users</option>
      <option value="guest" {{ filters.role == 'guest' ? 'selected' : '' }}>Guests</option>
    </select>
    <button type="submit" class="ds-btn ds-btn--primary">Filtrer</button>
  </form>
{% endblock %}

{% block admin_content %}
  <div class="ds-surface ds-table-wrap">
    <table class="ds-table">
      <thead>
        <tr>
          <th>Utilisateur</th>
          <th>Entreprise</th>
          <th>Roles</th>
          <th>Plan</th>
          <th>Statut</th>
          <th>Stripe</th>
          <th>Mise a jour</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {% for user in users %}
          {% set subscription = user.userSubscription %}
          <tr>
            <td>
              <div class="ds-cell-stack">
                <span class="ds-title-strong">#{{ user.id }} {{ user.email }}</span>
                <span class="ds-muted">
                  {{ subscription ? 'Abonnement cree le ' ~ subscription.createdAt|date('d/m/Y H:i') : 'Date utilisateur indisponible' }}
                </span>
              </div>
            </td>
            <td>{{ user.company ?: '-' }}</td>
            <td class="ds-text-break">{{ user.roles ? user.roles|join(', ') : 'ROLE_USER' }}</td>
            <td class="ds-title-strong">{{ subscription and subscription.planCode ? subscription.planCode|upper : 'FREE' }}</td>
            <td>
              {% if subscription and subscription.isActive %}
                {% include 'components/ui/status_badge.html.twig' with { label: subscription.status ?: 'active', tone: 'success' } only %}
              {% elseif subscription %}
                {% include 'components/ui/status_badge.html.twig' with { label: subscription.status ?: 'inactive', tone: 'warning' } only %}
              {% else %}
                {% include 'components/ui/status_badge.html.twig' with { label: 'aucun', tone: 'muted' } only %}
              {% endif %}
            </td>
            <td>
              <div class="ds-cell-stack">
                <span class="ds-mono">{{ subscription and subscription.stripeCustomerId ? subscription.stripeCustomerId : 'customer: -' }}</span>
                <span class="ds-mono">{{ subscription and subscription.stripeSubscriptionId ? subscription.stripeSubscriptionId : 'subscription: -' }}</span>
              </div>
            </td>
            <td>{{ subscription ? subscription.updatedAt|date('d/m/Y H:i') : '-' }}</td>
            <td>
              <div class="ds-actions-stack">
                <a href="{{ path('admin_user_show', {id: user.id}) }}" class="ds-btn ds-btn--secondary ds-btn--block">Fiche user</a>
                {% if not subscription or not subscription.isActive %}
                  <form method="post" action="{{ path('admin_user_subscription_assign_pro', {id: user.id}) }}" class="ds-inline-form">
                    <input type="hidden" name="_token" value="{{ csrf_token('assign_pro_' ~ user.id) }}">
                    <button type="submit" class="ds-btn ds-btn--primary ds-btn--block">Activer Pro</button>
                  </form>
                {% endif %}

                {% if subscription %}
                  <form method="post" action="{{ path('admin_user_subscription_deactivate', {id: user.id}) }}" class="ds-inline-form" onsubmit="return confirm('Desactiver cet abonnement ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('deactivate_subscription_' ~ user.id) }}">
                    <button type="submit" class="ds-btn ds-btn--warning ds-btn--block">Desactiver</button>
                  </form>
                {% endif %}
              </div>
            </td>
          </tr>
        {% else %}
          <tr>
            <td colspan="8" class="ds-empty">Aucun utilisateur recent a afficher.</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
{% endblock %}
