{% extends 'base_auth.html.twig' %}

{% block title %}{{ 'install_app.meta.title'|trans }}{% endblock %}

{% block page_styles %}
<style>
  .install-app-page {
    max-width: 1120px;
    margin: 0 auto;
    padding: 2rem 1rem 3rem;
  }

  .install-shell {
    display: grid;
    gap: 1.25rem;
  }

  .install-hero {
    position: relative;
    overflow: hidden;
    border-radius: 32px;
    padding: 2rem;
    background:
      radial-gradient(circle at top right, rgba(16, 185, 129, 0.18), transparent 34%),
      radial-gradient(circle at bottom left, rgba(14, 165, 233, 0.14), transparent 32%),
      linear-gradient(135deg, #f8fafc, #ecfdf5);
    border: 1px solid rgba(16, 185, 129, 0.22);
    box-shadow: 0 24px 44px rgba(15, 23, 42, 0.08), 0 0 0 1px rgba(255, 255, 255, 0.65) inset;
  }

  .install-hero__eyebrow,
  .install-context {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    width: fit-content;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.85);
    color: #0f172a;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .install-context {
    margin-top: 0.9rem;
    color: #047857;
  }

  .install-hero__title {
    max-width: 760px;
    margin-top: 1rem;
    color: #0f172a;
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1.02;
    letter-spacing: -0.05em;
  }

  .install-hero__text,
  .install-hero__hint,
  .install-card__text,
  .install-step-list li,
  .install-tip-list li {
    color: #475569;
    line-height: 1.65;
  }

  .install-hero__text {
    max-width: 760px;
    margin-top: 0.9rem;
    font-size: 1rem;
  }

  .install-hero__hint {
    margin-top: 0.9rem;
  }

  .install-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.4rem;
  }

  .install-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: 1rem;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    border: 1px solid rgba(5, 150, 105, 0.22);
    background: rgba(255, 255, 255, 0.78);
    color: #047857;
    font-size: 0.84rem;
    font-weight: 700;
    box-shadow: 0 12px 24px rgba(16, 185, 129, 0.08);
  }

  .install-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    min-height: 3rem;
    padding: 0.8rem 1.15rem;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.24);
    text-decoration: none;
    font-weight: 700;
    font: inherit;
    cursor: pointer;
  }

  .install-cta--primary {
    background: linear-gradient(135deg, #059669, #10b981);
    color: #fff;
    border-color: transparent;
    box-shadow: 0 18px 28px rgba(5, 150, 105, 0.18), 0 0 0 4px rgba(16, 185, 129, 0.12);
  }

  .install-cta--secondary {
    background: rgba(255, 255, 255, 0.84);
    color: #0f172a;
  }

  .install-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
    gap: 1.25rem;
  }

  .install-card {
    position: relative;
    border-radius: 26px;
    padding: 1.4rem;
    background: #fff;
    border: 1px solid rgba(148, 163, 184, 0.16);
    box-shadow: 0 16px 30px rgba(15, 23, 42, 0.06);
  }

  .install-card--highlight {
    border-color: rgba(16, 185, 129, 0.24);
    box-shadow: 0 20px 34px rgba(5, 150, 105, 0.08);
  }

  .install-card--highlight::before {
    content: "";
    position: absolute;
    inset: 0;
    padding: 1px;
    border-radius: inherit;
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.45), rgba(14, 165, 233, 0.28));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  .install-card__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-bottom: 0.8rem;
    padding: 0.38rem 0.72rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #ecfdf5, #dbeafe);
    color: #047857;
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .install-card h2 {
    margin-bottom: 0.45rem;
    color: #0f172a;
    font-size: 1.12rem;
  }

  .install-step-group + .install-step-group {
    margin-top: 1.15rem;
    padding-top: 1.15rem;
    border-top: 1px solid rgba(148, 163, 184, 0.18);
  }

  .install-step-group h3 {
    margin-bottom: 0.6rem;
    color: #0f172a;
    font-size: 0.98rem;
  }

  .install-step-list,
  .install-tip-list {
    margin: 0;
    padding-left: 1.2rem;
  }

  .install-step-list li + li,
  .install-tip-list li + li {
    margin-top: 0.6rem;
  }

  .install-benefits {
    display: grid;
    gap: 0.8rem;
    margin-top: 1rem;
  }

  .install-benefit {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    gap: 0.8rem;
    align-items: start;
  }

  .install-benefit__icon {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #ecfdf5, #dbeafe);
    color: #059669;
  }

  .install-benefit strong {
    display: block;
    margin-bottom: 0.2rem;
    color: #0f172a;
  }

  .install-note {
    margin-top: 1rem;
    padding: 0.95rem 1rem;
    border-radius: 18px;
    background: #f8fafc;
    border: 1px dashed rgba(148, 163, 184, 0.3);
    color: #475569;
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .install-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .install-app-page {
      padding: 1rem 0 2rem;
    }

    .install-hero,
    .install-card {
      border-radius: 22px;
      padding: 1.15rem;
    }

    .install-hero__actions {
      flex-direction: column;
    }

    .install-cta {
      width: 100%;
    }
  }
</style>
{% endblock %}

{% block body %}
  {% set nextRoute = app.user ? path('app_credential') : path('show_register') %}
  {% set nextLabel = app.user ? 'install_app.hero.secondary_cta_logged'|trans : 'install_app.hero.secondary_cta_guest'|trans %}

  <section class="install-app-page">
    <div class="install-shell">
      <div class="install-hero">
        <div class="install-hero__eyebrow">
          <i class="fas fa-mobile-screen-button"></i>
          {{ 'install_app.hero.eyebrow'|trans }}
        </div>

        <div class="install-context">
          <i class="fas fa-circle-check"></i>
          {{ ('install_app.context.' ~ install_platform ~ '.label')|trans }}
        </div>

        <h1 class="install-hero__title">{{ 'install_app.hero.title'|trans }}</h1>
        <p class="install-hero__text">{{ 'install_app.hero.text'|trans }}</p>
        <p class="install-hero__hint">
          {{ ('install_app.context.' ~ install_platform ~ '.text')|trans }}
        </p>

        <div class="install-badge">
          <i class="fas fa-sparkles"></i>
          {{ 'install_app.hero.badge'|trans }}
        </div>

        <div class="install-hero__actions">
          {% if install_platform == 'android' %}
            <button
              type="button"
              class="install-cta install-cta--primary"
              data-pwa-install-target="pageInstallButton"
              data-action="click->pwa-install#install"
              hidden
            >
              <i class="fas fa-download"></i>
              {{ 'install_app.hero.primary_cta'|trans }}
            </button>
          {% endif %}

          <a href="{{ nextRoute }}" class="install-cta install-cta--secondary">
            <i class="fas {{ app.user ? 'fa-shield-alt' : 'fa-user-plus' }}"></i>
            {{ nextLabel }}
          </a>
        </div>

        <div class="install-note">
          {{ is_mobile_device ? 'install_app.hero.mobile_note'|trans : 'install_app.hero.desktop_note'|trans }}
        </div>

        {% if install_platform == 'android' %}
          <div
            class="install-note"
            data-pwa-install-target="installHint"
            data-waiting-text="{{ 'install_app.hero.install_waiting'|trans }}"
            data-ready-text="{{ 'install_app.hero.install_ready'|trans }}"
          ></div>
        {% endif %}
      </div>

      <div class="install-grid">
        <article class="install-card install-card--highlight">
          <div class="install-card__badge">
            <i class="fas fa-star"></i>
            {{ 'install_app.flow.badge'|trans }}
          </div>
          <h2>{{ 'install_app.flow.title'|trans }}</h2>
          <p class="install-card__text">{{ ('install_app.flow.' ~ install_platform ~ '.intro')|trans }}</p>

          {% if install_platform == 'android' %}
            <div class="install-step-group">
              <h3>{{ 'install_app.flow.android.title'|trans }}</h3>
              <ol class="install-step-list">
                <li>{{ 'install_app.flow.android.step_1'|trans|raw }}</li>
                <li>{{ 'install_app.flow.android.step_2'|trans|raw }}</li>
                <li>{{ 'install_app.flow.android.step_3'|trans|raw }}</li>
              </ol>
            </div>
          {% elseif install_platform == 'ios' %}
            <div class="install-step-group">
              <h3>{{ 'install_app.flow.ios.title'|trans }}</h3>
              <ol class="install-step-list">
                <li>{{ 'install_app.flow.ios.step_1'|trans|raw }}</li>
                <li>{{ 'install_app.flow.ios.step_2'|trans|raw }}</li>
                <li>{{ 'install_app.flow.ios.step_3'|trans|raw }}</li>
              </ol>
            </div>
          {% else %}
            <div class="install-step-group">
              <h3>{{ 'install_app.flow.desktop.title'|trans }}</h3>
              <ol class="install-step-list">
                <li>{{ 'install_app.flow.desktop.step_1'|trans }}</li>
                <li>{{ 'install_app.flow.desktop.step_2'|trans }}</li>
                <li>{{ 'install_app.flow.desktop.step_3'|trans }}</li>
              </ol>
            </div>

            <div class="install-step-group">
              <h3>{{ 'install_app.flow.android.title'|trans }}</h3>
              <ol class="install-step-list">
                <li>{{ 'install_app.flow.android.step_1'|trans|raw }}</li>
                <li>{{ 'install_app.flow.android.step_2'|trans|raw }}</li>
                <li>{{ 'install_app.flow.android.step_3'|trans|raw }}</li>
              </ol>
            </div>

            <div class="install-step-group">
              <h3>{{ 'install_app.flow.ios.title'|trans }}</h3>
              <ol class="install-step-list">
                <li>{{ 'install_app.flow.ios.step_1'|trans|raw }}</li>
                <li>{{ 'install_app.flow.ios.step_2'|trans|raw }}</li>
                <li>{{ 'install_app.flow.ios.step_3'|trans|raw }}</li>
              </ol>
            </div>
          {% endif %}
        </article>

        <aside class="install-card">
          <h2>{{ 'install_app.benefits.title'|trans }}</h2>

          <div class="install-benefits">
            <div class="install-benefit">
              <div class="install-benefit__icon"><i class="fas fa-bolt"></i></div>
              <div>
                <strong>{{ 'install_app.benefits.items.speed.title'|trans }}</strong>
                <span>{{ 'install_app.benefits.items.speed.text'|trans }}</span>
              </div>
            </div>

            <div class="install-benefit">
              <div class="install-benefit__icon"><i class="fas fa-mobile-screen"></i></div>
              <div>
                <strong>{{ 'install_app.benefits.items.experience.title'|trans }}</strong>
                <span>{{ 'install_app.benefits.items.experience.text'|trans }}</span>
              </div>
            </div>

            <div class="install-benefit">
              <div class="install-benefit__icon"><i class="fas fa-shield-heart"></i></div>
              <div>
                <strong>{{ 'install_app.benefits.items.security.title'|trans }}</strong>
                <span>{{ 'install_app.benefits.items.security.text'|trans }}</span>
              </div>
            </div>
          </div>

          <div class="install-step-group">
            <h3>{{ 'install_app.tips.title'|trans }}</h3>
            <ul class="install-tip-list">
              <li>{{ 'install_app.tips.item_1'|trans }}</li>
              <li>{{ 'install_app.tips.item_2'|trans }}</li>
              <li>{{ 'install_app.tips.item_3'|trans }}</li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>
{% endblock %}
