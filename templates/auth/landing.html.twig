{% extends 'base_auth.html.twig' %}

{% block title %}{{ app.request.locale == 'en' ? 'SMB Cybersecurity Solution & Enterprise Password Manager | MYKEYNEST' : 'Cybersécurité PME & gestionnaire de mots de passe entreprise | MYKEYNEST' }}{% endblock %}
{% block description %}{{ app.request.locale == 'en' ? 'MYKEYNEST helps SMBs secure passwords, reduce phishing risk, protect access, and improve cybersecurity with an enterprise password manager, audit tools, and practical guidance.' : 'MYKEYNEST aide les PME à sécuriser les mots de passe, réduire le risque phishing, protéger les accès et renforcer la cybersécurité avec un gestionnaire de mots de passe entreprise, des outils d audit et un accompagnement concret.' }}{% endblock %}
{% block og_title %}{{ app.request.locale == 'en' ? 'SMB Cybersecurity Solution & Enterprise Password Manager | MYKEYNEST' : 'Cybersécurité PME & gestionnaire de mots de passe entreprise | MYKEYNEST' }}{% endblock %}
{% block og_description %}{{ app.request.locale == 'en' ? 'Secure passwords, protect accounts, and give your SMB a practical cybersecurity baseline with MYKEYNEST.' : 'Sécurisez les mots de passe, protégez les comptes et donnez à votre PME un socle de cybersécurité concret avec MYKEYNEST.' }}{% endblock %}
{% block twitter_title %}{{ app.request.locale == 'en' ? 'SMB Cybersecurity Solution & Enterprise Password Manager | MYKEYNEST' : 'Cybersécurité PME & gestionnaire de mots de passe entreprise | MYKEYNEST' }}{% endblock %}
{% block twitter_description %}{{ app.request.locale == 'en' ? 'Enterprise password manager, phishing awareness, security audit, and access protection for SMBs.' : 'Gestionnaire de mots de passe entreprise, sensibilisation phishing, audit cybersécurité et protection des accès pour PME.' }}{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/pages/landing.css') }}">
{% endblock %}

{% block body %}
{# ======================== HERO ======================== #}
<section class="hero" role="banner" id="main-content">
  <div class="hero-inner">
    <div class="hero-text">
      <div class="hero-eyebrow" aria-hidden="true">
        <i class="fas fa-shield-halved"></i> AES-256 - Zero-Knowledge - RGPD
      </div>
      <h1 class="hero-h1">
        {{ 'landing.hero.title_before'|trans }}
        <span class="hl">{{ 'landing.hero.title_highlight'|trans }}</span>
      </h1>
      <p class="hero-sub">{{ 'landing.hero.subtitle'|trans }}</p>
      <div class="hero-cta">
        <a href="{{ path('show_register') }}" class="btn btn-primary btn-lg btn-w" aria-label="{{ 'landing.hero.cta_start_aria'|trans }}">
          <i class="fas fa-rocket" aria-hidden="true"></i> {{ 'landing.hero.cta_start'|trans }}
        </a>
        <a href="#features" class="btn btn-outline btn-lg btn-w">{{ 'landing.hero.cta_discover'|trans }}</a>
      </div>
      <p class="hero-hint"><i class="fas fa-circle-check"></i> Essai gratuit 14 jours - sans carte bancaire</p>
      <div class="trust" aria-label="{{ 'landing.hero.trust_aria'|trans }}">
        <div class="trust-item"><i class="fas fa-shield-check"></i><span>{{ 'landing.hero.trust.aes'|trans }}</span></div>
        <div class="trust-item"><i class="fas fa-lock"></i><span>{{ 'landing.hero.trust.zeroknowledge'|trans }}</span></div>
        <div class="trust-item"><i class="fas fa-fingerprint"></i><span>{{ 'landing.hero.trust.hashed'|trans }}</span></div>
      </div>
    </div>

    <div class="hero-vis" aria-hidden="true">
      <div class="sec-pill"><i class="fas fa-shield-check"></i> Coffre-fort AES-256</div>
      <div class="vault">
        <div class="vault-bar">
          <div class="vdots"><div class="vdot"></div><div class="vdot"></div><div class="vdot"></div></div>
          <span class="vault-title">MyKeyNest - Vault</span>
        </div>
        <div class="vault-search">
          <i class="fas fa-magnifying-glass"></i>
          <input type="text" placeholder="Rechercher un acces" tabindex="-1" readonly>
        </div>
        <div class="cred-list">
          <div class="cred">
            <div class="cred-logo g"><i class="fab fa-google"></i></div>
            <div class="cred-body"><b>{{ 'landing.hero.mock.gmail'|trans }}</b><span>email@example.com</span></div>
            <div class="sdots"><div class="sd ok"></div><div class="sd ok"></div><div class="sd ok"></div><div class="sd ok"></div></div>
            <i class="fas fa-lock cred-lock"></i>
          </div>
          <div class="cred">
            <div class="cred-logo f"><i class="fab fa-facebook"></i></div>
            <div class="cred-body"><b>{{ 'landing.hero.mock.facebook'|trans }}</b><span>••••••••••••</span></div>
            <div class="sdots"><div class="sd mid"></div><div class="sd mid"></div><div class="sd mid"></div><div class="sd"></div></div>
            <i class="fas fa-lock cred-lock"></i>
          </div>
          <div class="cred">
            <div class="cred-logo gh"><i class="fab fa-github"></i></div>
            <div class="cred-body"><b>{{ 'landing.hero.mock.github'|trans }}</b><span>developer@mail.com</span></div>
            <div class="sdots"><div class="sd ok"></div><div class="sd ok"></div><div class="sd ok"></div><div class="sd ok"></div></div>
            <i class="fas fa-lock cred-lock"></i>
          </div>
          <div class="cred cred-extra">
            <div class="cred-logo s"><i class="fab fa-stripe-s"></i></div>
            <div class="cred-body"><b>Stripe Dashboard</b><span>admin@company.com</span></div>
            <div class="sdots"><div class="sd ok"></div><div class="sd ok"></div><div class="sd ok"></div><div class="sd ok"></div></div>
            <i class="fas fa-lock cred-lock"></i>
          </div>
          <div class="cred cred-extra">
            <div class="cred-logo a"><i class="fab fa-aws"></i></div>
            <div class="cred-body"><b>AWS Console</b><span>ops@company.com</span></div>
            <div class="sdots"><div class="sd ok"></div><div class="sd ok"></div><div class="sd ok"></div><div class="sd ok"></div></div>
            <i class="fas fa-lock cred-lock"></i>
          </div>
        </div>
        <div class="hash-badge">
          <span style="color:#64748b;">HASH</span>
          <span>0x8f2a-c3e1</span>
          <span class="hash-ok"><i class="fas fa-circle-check"></i> OK</span>
        </div>
      </div>
    </div>
  </div>
</section>

{# STRIP #}
<div class="strip" aria-hidden="true">
  <div class="strip-inner">
    <div class="s-item"><i class="fas fa-certificate"></i> AES-256</div>
    <div class="s-div"></div>
    <div class="s-item"><i class="fas fa-fingerprint"></i> Installation Hashee</div>
    <div class="s-div"></div>
    <div class="s-item"><i class="fas fa-euro-sign"></i> Donnees en Europe</div>
    <div class="s-div"></div>
    <div class="s-item"><i class="fas fa-user-secret"></i> Zero-Knowledge</div>
    <div class="s-div"></div>
    <div class="s-item"><i class="fas fa-check-double"></i> RGPD</div>
  </div>
</div>



{# ======================== SECURITY ======================== #}
<section class="sec-section" id="security" aria-labelledby="sec-h2">
  <div class="wrap">
    <div class="sec-inner">
      <div class="sec-text">
        <span class="sh-label"><i class="fas fa-fingerprint"></i> {{ 'landing.security.label'|trans }}</span>
        <h2 class="sec-h2" id="sec-h2">{{ 'landing.security.title'|trans }}</h2>
        <p class="sec-intro">{{ 'landing.security.intro'|trans }}</p>
        <div class="sec-pts">
          <div class="sp">
            <div class="sp-ico"><i class="fas fa-fingerprint"></i></div>
            <div class="sp-body"><b>{{ 'landing.security.points.p1_title'|trans }}</b><p>{{ 'landing.security.points.p1_text'|trans }}</p></div>
          </div>
          <div class="sp">
            <div class="sp-ico"><i class="fas fa-link-slash"></i></div>
            <div class="sp-body"><b>{{ 'landing.security.points.p2_title'|trans }}</b><p>{{ 'landing.security.points.p2_text'|trans }}</p></div>
          </div>
          <div class="sp">
            <div class="sp-ico"><i class="fas fa-database"></i></div>
            <div class="sp-body"><b>{{ 'landing.security.points.p3_title'|trans }}</b><p>{{ 'landing.security.points.p3_text'|trans }}</p></div>
          </div>
          <div class="sp">
            <div class="sp-ico"><i class="fas fa-file-shield"></i></div>
            <div class="sp-body"><b>{{ 'landing.security.points.p4_title'|trans }}</b><p>{{ 'landing.security.points.p4_text'|trans }}</p></div>
          </div>
        </div>
      </div>
      <div class="terminal" aria-hidden="true">
        <div class="t-bar">
          <div class="t-dots"><div class="t-dot"></div><div class="t-dot"></div><div class="t-dot"></div></div>
          <span class="t-title">mykeynest - registre de confiance</span>
        </div>
        <div class="t-body">
          <div class="tl"><span class="tp">$</span><span class="tc">verify_install --id 0x8f2a</span></div>
          <div class="tl"><span class="tp"> </span><span class="tv">ID_INSTALL&nbsp; : 0x8f2a...c3e1</span></div>
          <div class="tl"><span class="tp"> </span><span class="tv">HASH_STATUS : SIGNED & VERIFIED &#10003;</span></div>
          <div class="tl"><span class="tp"> </span><span class="tv">INTEGRITY&nbsp;&nbsp; : PASS</span></div>
          <br>
          <div class="tl"><span class="tp">$</span><span class="tc">simulate_attack --replay-hash</span></div>
          <div class="tl"><span class="tp"> </span><span class="te">ERROR : HASH_MISMATCH - Access denied</span></div>
          <div class="tl"><span class="tp"> </span><span class="tw">ALERT : Unauthorized attempt logged</span></div>
          <div class="tl"><span class="tp"> </span><span class="te">VAULT : LOCKED - Session terminated</span></div>
          <br>
          <div class="tl"><span class="tp">$</span><span class="tc">status</span></div>
          <div class="tl"><span class="tp"> </span><span class="tok">âœ“ Vault secure. Zero data exposed.</span></div>
        </div>
        <div class="t-chain">
          <div class="tnode"><i class="fas fa-puzzle-piece"></i></div>
          <div class="tarrow"></div>
          <div class="tnode"><i class="fas fa-file-signature"></i></div>
          <div class="tarrow"></div>
          <div class="tnode"><i class="fas fa-lock"></i></div>
          <div class="tarrow"></div>
          <div class="tnode"><i class="fas fa-shield-check"></i></div>
        </div>
        <div class="t-scan"></div>
      </div>
    </div>
  </div>
</section>

