<script defer>
if('loading' in HTMLImageElement.prototype===false && 'IntersectionObserver' in window){
  const io=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){const img=e.target;if(img.dataset.src){img.src=img.dataset.src;img.classList.add('loaded');io.unobserve(img);}}}));
  document.querySelectorAll('img[data-src]').forEach(img=>io.observe(img));
}
document.querySelectorAll('.faq-item').forEach(el=>{
  el.addEventListener('toggle',()=>{const t=el.querySelector('.faq-tog');if(t)t.textContent=el.open?'−':'+';});
});
</script>

