{% extends 'base.html.twig' %}

{% block title %}Gestion des sessions{% endblock %}

{% block body %}
<style>
.sessions-container {
    max-width: 900px;
    margin: 2rem auto;
    padding: 0 1.5rem;
}

.sessions-header {
    margin-bottom: 2rem;
}

.sessions-header h1 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-text-dark);
    margin-bottom: 0.5rem;
}

.sessions-subtitle {
    color: var(--color-text-muted);
    font-size: 0.95rem;
}

.sessions-actions {
    margin-bottom: 1.5rem;
    display: flex;
    justify-content: flex-end;
}

.btn-danger-outline {
    padding: 0.625rem 1.25rem;
    border: 2px solid var(--color-danger-start);
    background: transparent;
    color: var(--color-danger-start);
    border-radius: var(--border-radius-sm);
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
}

.btn-danger-outline:hover {
    background: var(--color-danger-start);
    color: white;
}

.sessions-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.loading-state {
    text-align: center;
    padding: 3rem;
    color: var(--color-text-muted);
}

.spinner {
    width: 40px;
    height: 40px;
    border: 3px solid var(--color-border);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin: 0 auto 1rem;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

.session-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    padding: 1.5rem;
    transition: all 0.2s;
    position: relative;
}

.session-card:hover {
    box-shadow: var(--shadow-md);
}

.session-card.current {
    border-color: var(--color-primary);
    background: linear-gradient(135deg, rgba(5, 150, 105, 0.02) 0%, rgba(16, 185, 129, 0.05) 100%);
}

.session-card.blocked {
    border-color: var(--color-danger-start);
    background: linear-gradient(135deg, rgba(239, 68, 68, 0.02) 0%, rgba(220, 38, 38, 0.05) 100%);
    opacity: 0.7;
}

.session-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
}

.session-info {
    flex: 1;
}

.session-device {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
}

.device-icon {
    width: 40px;
    height: 40px;
    background: var(--background-gradient);
    border-radius: var(--border-radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    font-size: 1.25rem;
}

.session-card.current .device-icon {
    box-shadow: var(--shadow-green);
}

.device-details h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-dark);
    margin: 0;
}

.device-details p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0.25rem 0 0;
}

.device-type-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
}

.session-badge {
    padding: 0.375rem 0.75rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.badge-current {
    background: linear-gradient(135deg, var(--color-primary) 0%, #10b981 100%);
    color: white;
}

.badge-blocked {
    background: linear-gradient(135deg, var(--color-danger-start) 0%, var(--color-danger-end) 100%);
    color: white;
}

.badge-device {
    text-transform: none;
    letter-spacing: 0;
}

.badge-device--mobile {
    background: rgba(59, 130, 246, 0.16);
    color: #3b82f6;
}

.badge-device--desktop {
    background: rgba(148, 163, 184, 0.18);
    color: var(--color-text-medium);
}

.device-expiry {
    color: var(--color-text-muted);
    font-size: 0.8125rem;
    font-weight: 600;
}

.session-meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 1rem;
}

.meta-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-medium);
    font-size: 0.875rem;
}

.meta-item i {
    color: var(--color-primary);
    width: 16px;
}

.blocked-info {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid var(--color-danger-start);
    border-radius: var(--border-radius-sm);
    padding: 0.75rem;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.blocked-info i {
    color: var(--color-danger-start);
    font-size: 1.25rem;
}

.blocked-info p {
    margin: 0;
    color: var(--color-text-dark);
    font-size: 0.875rem;
}

.blocked-info strong {
    display: block;
    margin-bottom: 0.25rem;
}

.session-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
}

.btn-session {
    padding: 0.5rem 1rem;
    border-radius: var(--border-radius-sm);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    border: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
}

.btn-revoke {
    background: var(--color-bg-light);
    color: var(--color-text-dark);
    border: 1px solid var(--color-border);
}

.btn-revoke:hover {
    background: var(--color-bg-hover);
}

.btn-block {
    background: linear-gradient(135deg, var(--color-danger-start) 0%, var(--color-danger-end) 100%);
    color: white;
}

.btn-block:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
}

.btn-unblock {
    background: linear-gradient(135deg, var(--color-primary) 0%, #10b981 100%);
    color: white;
}

.btn-unblock:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-green);
}

.btn-session:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.empty-state {
    text-align: center;
    padding: 3rem;
    color: var(--color-text-muted);
}

.empty-state i {
    font-size: 3rem;
    color: var(--color-text-light);
    margin-bottom: 1rem;
}

/* Toast notifications */
.toast {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    padding: 1rem 1.5rem;
    border-radius: var(--border-radius);
    box-shadow: var(--shadow-xl);
    transform: translateX(400px);
    transition: transform 0.3s ease;
    z-index: 1000;
    max-width: 400px;
}

.toast.show {
    transform: translateX(0);
}

.toast-content {
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.toast-icon {
    font-size: 1.25rem;
}

.toast.success {
    border-left: 4px solid var(--color-success);
}

.toast.success .toast-icon::before {
    content: "✓";
    color: var(--color-success);
}

.toast.error {
    border-left: 4px solid var(--color-danger-start);
}

.toast.error .toast-icon::before {
    content: "✕";
    color: var(--color-danger-start);
}

.toast-message {
    color: var(--color-text-dark);
    font-size: 0.9375rem;
}
.toast {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    padding: 1rem 1.5rem;
    border-radius: var(--border-radius);
    box-shadow: var(--shadow-xl);
    transform: translateX(400px);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: transform 0.3s ease, opacity 0.3s ease, visibility 0.3s ease;
    z-index: 9999;
    max-width: 400px;
}

.toast.show {
    transform: translateX(0);
    opacity: 1;
    visibility: visible;
}
/* Responsive */
@media (max-width: 768px) {
    .sessions-container {
        padding: 0 1rem;
    }

    .sessions-header h1 {
        font-size: 1.5rem;
    }

    .session-meta {
        grid-template-columns: 1fr;
    }

    .session-actions {
        flex-direction: column;
    }

    .btn-session {
        width: 100%;
        justify-content: center;
    }

    .toast {
        right: 1rem;
        left: 1rem;
        max-width: none;
    }
}
</style>

<div class="sessions-container" data-controller="session-manager">
    <div class="sessions-header">
        <h1>Mes appareils connectés</h1>
        <p class="sessions-subtitle">Gérez les appareils qui ont accès à votre compte</p>
    </div>

    <div class="sessions-actions">
        <button 
            class="btn-danger-outline"
            data-action="click->session-manager#logoutAll"
            data-session-manager-target="logoutAllBtn"
        >
            <i class="fas fa-sign-out-alt"></i>
            Déconnecter tous les appareils
        </button>
    </div>

    <div class="sessions-list" data-session-manager-target="sessionsList">
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Chargement des sessions...</p>
        </div>
    </div>

    <!-- Toast pour les notifications -->
    <div class="toast" data-session-manager-target="toast">
        <div class="toast-content">
            <i class="toast-icon"></i>
            <span class="toast-message" data-session-manager-target="toastMessage"></span>
        </div>
    </div>
</div>
{% endblock %}
