<!DOCTYPE html>
<html lang="{{ app.request.locale|default('fr') }}">
  <head>
    {% set currentRoute = app.request.attributes.get('_route') %}
    {% set routeParams = app.request.attributes.get('_route_params') ?? {} %}
    {% set queryParams = app.request.query.all %}
    {% set currentLocale = app.request.locale|default('fr') %}
    {% set seoPublicRoutes = [
      'app_landing',
      'app_public_generator',
      'app_help_center',
      'app_help_category',
      'app_help_article',
      'business_solution',
      'business_password_manager',
      'business_comparatif',
      'business_audit',
      'legal_cgu',
      'legal_cgv'
    ] %}
    {% set sensitiveAuthRoutes = ['app_guest_register', 'app_guest_shared_preview'] %}
    {% set isSensitiveAuthRoute = currentRoute in sensitiveAuthRoutes %}
    {% set legacyMetaHead = block('meta_description')|trim %}
    {% set canonicalUrl = block('canonical_url')|trim %}
    {% if canonicalUrl is empty %}
      {% if isSensitiveAuthRoute and currentRoute %}
        {% set canonicalUrl = url(currentRoute, routeParams) %}
      {% elseif currentRoute and currentRoute in seoPublicRoutes %}
        {% set canonicalQueryParams = {} %}
        {% if queryParams.page is defined %}
          {% set canonicalQueryParams = canonicalQueryParams|merge({ page: queryParams.page }) %}
        {% endif %}
        {% if currentLocale == 'en' %}
          {% set canonicalQueryParams = canonicalQueryParams|merge({ lang: 'en' }) %}
        {% endif %}
        {% set canonicalUrl = url(currentRoute, routeParams|merge(canonicalQueryParams)) %}
      {% else %}
        {% set canonicalUrl = app.request.uri %}
      {% endif %}
    {% endif %}

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#f8fafc" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

    <title>{% block title %}MYKEYNEST - Gestionnaire de mots de passe securise{% endblock %}</title>

    <script>
      (() => {
        const savedTheme = window.localStorage.getItem('theme') || 'light';
        const themeColor = savedTheme === 'dark' ? '#0f172a' : '#f8fafc';
        document.documentElement.setAttribute('data-theme', savedTheme);
        document.querySelector('meta[name="theme-color"]')?.setAttribute('content', themeColor);
      })();
    </script>

    {% if not isSensitiveAuthRoute %}
      <script async src="https://www.googletagmanager.com/gtag/js?id=G-RG9YT46TFS"></script>
      <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-RG9YT46TFS');
      </script>
    {% endif %}

    {% if legacyMetaHead is not empty %}
      {{ legacyMetaHead|raw }}
    {% else %}
      <meta name="description" content="{% block description %}Securisez vos mots de passe et vos acces avec MYKEYNEST. Chiffrement AES-256, zero-knowledge, synchronisation multi-appareils et partage securise.{% endblock %}" />
      <meta name="author" content="MYKEYNEST" />
      <meta name="robots" content="{% block robots %}{% if isSensitiveAuthRoute %}noindex,nofollow,noarchive{% else %}index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1{% endif %}{% endblock %}" />
      <meta name="googlebot" content="{% block googlebot %}{% if isSensitiveAuthRoute %}noindex,nofollow,noarchive{% else %}index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1{% endif %}{% endblock %}" />
      <meta name="referrer" content="{% if isSensitiveAuthRoute %}no-referrer{% else %}strict-origin-when-cross-origin{% endif %}" />

      <meta property="og:type" content="{% block og_type %}website{% endblock %}" />
      <meta property="og:site_name" content="MYKEYNEST" />
      <meta property="og:locale" content="{% block og_locale %}{{ app.request.locale == 'en' ? 'en_US' : 'fr_FR' }}{% endblock %}" />
      <meta property="og:url" content="{{ canonicalUrl }}" />
      <meta property="og:title" content="{% block og_title %}MYKEYNEST - Gestionnaire de mots de passe securise{% endblock %}" />
      <meta property="og:description" content="{% block og_description %}Centralisez vos mots de passe, partagez vos acces en securite et documentez vos pratiques de cybersecurite.{% endblock %}" />
      <meta property="og:image" content="{% block og_image %}{{ absolute_url(asset('apple-touch-icon.png')) }}{% endblock %}" />

      <meta name="twitter:card" content="{% block twitter_card %}summary_large_image{% endblock %}" />
      <meta name="twitter:url" content="{{ canonicalUrl }}" />
      <meta name="twitter:title" content="{% block twitter_title %}MYKEYNEST - Gestionnaire de mots de passe securise{% endblock %}" />
      <meta name="twitter:description" content="{% block twitter_description %}Securisez vos mots de passe, vos acces et vos workflows avec MYKEYNEST.{% endblock %}" />
      <meta name="twitter:image" content="{% block twitter_image %}{{ absolute_url(asset('apple-touch-icon.png')) }}{% endblock %}" />
    {% endif %}

    <link rel="canonical" href="{{ canonicalUrl }}" />

    {% if currentRoute %}
      {% set hreflangBaseParams = routeParams %}
      {% if queryParams.page is defined %}
        {% set hreflangBaseParams = hreflangBaseParams|merge({ page: queryParams.page }) %}
      {% endif %}
      {% set frUrl = currentLocale == 'fr'
        ? canonicalUrl
        : url(currentRoute, hreflangBaseParams) %}
      {% set enUrl = currentLocale == 'en'
        ? canonicalUrl
        : url(currentRoute, hreflangBaseParams|merge({ lang: 'en' })) %}
      {% set defaultUrl = url(currentRoute, hreflangBaseParams) %}

      <link rel="alternate" hreflang="fr" href="{{ frUrl }}" />
      <link rel="alternate" hreflang="en" href="{{ enUrl }}" />
      <link rel="alternate" hreflang="x-default" href="{{ defaultUrl }}" />
    {% endif %}

    <link rel="icon" type="image/x-icon" href="{{ asset('favicon.ico') }}" />
    <link rel="apple-touch-icon" href="{{ asset('apple-touch-icon.png') }}" />
    <link rel="manifest" href="{{ asset('manifest.webmanifest') }}" />
    <link rel="alternate" type="text/markdown" title="LLMs" href="{{ absolute_url(asset('llms.txt')) }}" />

    {% if not isSensitiveAuthRoute %}
      <link rel="preconnect" href="https://cdnjs.cloudflare.com" />
      <link rel="dns-prefetch" href="https://cdnjs.cloudflare.com" />

      <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
      />
    {% endif %}

    {% block stylesheets %}{% endblock %}
    {% block page_styles %}{% endblock %}
    {% block javascripts %}
      {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}

    {% block seo_jsonld %}
      <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Organization",
            "name": "MYKEYNEST",
            "url": "{{ absolute_url(path('app_landing')) }}",
            "logo": "{{ absolute_url(asset('apple-touch-icon.png')) }}"
          },
          {
            "@type": "WebSite",
            "name": "MYKEYNEST",
            "url": "{{ absolute_url(path('app_landing')) }}",
            "inLanguage": "{{ app.request.locale|default('fr') }}"
          }
        ]
      }
      </script>
    {% endblock %}
  </head>

  <body class="auth-layout" data-controller="pwa-install">
    {% set route = app.request.attributes.get('_route') %}

    {% if route not in ['show_login', 'show_register'] %}
      {% include 'components/nav.html.twig' %}
    {% endif %}

    {% block body %}{% endblock %}
    {% include './components/parts/_toasts.html.twig' %}
    {% include './components/parts/_pwa_install_banner.html.twig' %}
  </body>
</html>

{% block meta_description %}{% endblock %}
{% block canonical_url %}{% endblock %}
