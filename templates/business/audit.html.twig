{% extends 'base_auth.html.twig' %}

{% block title %}{{ 'business.audit.meta.title'|trans }}{% endblock %}

{% set localeParams = app.request.locale == 'en' ? { lang: 'en' } : {} %}
{% set auditUrl = absolute_url(path('business_audit', localeParams)) %}

{% block description %}{{ 'business.audit.meta.description'|trans }}{% endblock %}
{% block keywords %}{{ 'business.audit.meta.keywords'|trans }}{% endblock %}
{% block og_title %}{{ 'business.audit.meta.title'|trans }}{% endblock %}
{% block og_description %}{{ 'business.audit.meta.description'|trans }}{% endblock %}
{% block twitter_title %}{{ 'business.audit.meta.title'|trans }}{% endblock %}
{% block twitter_description %}{{ 'business.audit.meta.description'|trans }}{% endblock %}
{% block canonical_url %}{{ auditUrl }}{% endblock %}

{% block head_extras %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
{% endblock %}

{% block seo_jsonld %}
{% set faqEntities = [] %}
{% for faq in ['q1', 'q2', 'q3', 'q4'] %}
    {% set faqEntities = faqEntities|merge([{
        '@type': 'Question',
        'name': ('business.audit.faq.' ~ faq ~ '.question')|trans,
        'acceptedAnswer': {
            '@type': 'Answer',
            'text': ('business.audit.faq.' ~ faq ~ '.answer')|trans
        }
    }]) %}
{% endfor %}
{% set seoGraph = {
    '@context': 'https://schema.org',
    '@graph': [
        {
            '@type': 'Organization',
            'name': 'MYKEYNEST',
            'url': absolute_url(path('app_landing', localeParams)),
            'logo': absolute_url(asset('apple-touch-icon.png'))
        },
        {
            '@type': 'WebPage',
            'name': 'business.audit.meta.title'|trans,
            'description': 'business.audit.meta.description'|trans,
            'url': auditUrl,
            'inLanguage': app.request.locale|default('fr')
        },
        {
            '@type': 'BreadcrumbList',
            'itemListElement': [
                {
                    '@type': 'ListItem',
                    'position': 1,
                    'name': 'business.audit.breadcrumb.home'|trans,
                    'item': absolute_url(path('app_landing', localeParams))
                },
                {
                    '@type': 'ListItem',
                    'position': 2,
                    'name': 'business.audit.breadcrumb.solution'|trans,
                    'item': absolute_url(path('business_solution', localeParams))
                },
                {
                    '@type': 'ListItem',
                    'position': 3,
                    'name': 'business.audit.breadcrumb.current'|trans,
                    'item': auditUrl
                }
            ]
        },
        {
            '@type': 'Service',
            'name': 'business.audit.schema.name'|trans,
            'description': 'business.audit.schema.description'|trans,
            'provider': {
                '@type': 'Organization',
                'name': 'MYKEYNEST'
            },
            'url': auditUrl,
            'serviceType': [
                'Audit cybersecurite PME',
                'Formation cybersecurite collaborateurs'
            ]
        },
        {
            '@type': 'FAQPage',
            'mainEntity': faqEntities
        }
    ]
} %}
<script type="application/ld+json">{{ seoGraph|json_encode|raw }}</script>
{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/pages/business-audit.css') }}">
{% endblock %}

{% block body %}
{% set isEn = app.request.locale == 'en' %}
<main>
    {# ?? Breadcrumb ?? #}
    <nav class="aud-breadcrumb" aria-label="{{ 'business.audit.breadcrumb.aria'|trans }}">
        <div class="aud-breadcrumb-inner">
            <a href="{{ path('app_landing') }}">{{ 'business.audit.breadcrumb.home'|trans }}</a>
            <span class="aud-breadcrumb-sep">&rsaquo;</span>
            <a href="{{ path('business_solution') }}">{{ 'business.audit.breadcrumb.solution'|trans }}</a>
            <span class="aud-breadcrumb-sep">&rsaquo;</span>
            <span class="aud-breadcrumb-current">{{ 'business.audit.breadcrumb.current'|trans }}</span>
        </div>
    </nav>

    {# ?? Hero ?? #}
    <section class="aud-hero">
        <div class="aud-hero-inner">
            <div class="aud-eyebrow">
                <i class="fa-solid fa-shield-halved" aria-hidden="true"></i>
                {{ 'business.audit.hero.eyebrow'|trans }}
            </div>
            <h1>
                <span class="aud-grad">{{ 'business.audit.hero.h1_highlight'|trans }}</span>
                {{ 'business.audit.hero.h1_suffix'|trans }}
            </h1>
            <p class="aud-hero-sub">{{ 'business.audit.hero.subtitle'|trans }}</p>
            <div class="aud-hero-pills">
                <span class="aud-pill"><span class="aud-pill-dot"></span>{{ 'business.audit.hero.pill1'|trans }}</span>
                <span class="aud-pill"><span class="aud-pill-dot"></span>{{ 'business.audit.hero.pill2'|trans }}</span>
                <span class="aud-pill"><span class="aud-pill-dot"></span>{{ 'business.audit.hero.pill3'|trans }}</span>
            </div>
        </div>
    </section>

    <section class="aud-layout" aria-labelledby="aud-summary-title" style="padding-top: 2rem;">
        <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:24px;padding:1.5rem 1.75rem;">
            <div class="aud-section-eyebrow">{{ isEn ? 'Quick summary' : 'Resume rapide' }}</div>
            <h2 class="aud-section-title" id="aud-summary-title">{{ isEn ? 'When this page is relevant' : 'Quand cette page est pertinente' }}</h2>
            <p class="aud-section-sub">{{ isEn ? 'This page is for SMBs that need a cybersecurity audit, employee awareness, phishing-risk reduction, or ransomware risk mitigation alongside password hygiene improvements.' : 'Cette page est utile aux PME qui ont besoin d un audit cybersécurité, de sensibilisation collaborateurs, d une reduction du risque phishing ou d une réponse plus solide au risque ransomware en plus de l hygiene des mots de passe.' }}</p>
            <ul style="margin:0 0 1rem 1.25rem;color:#334155;line-height:1.7;">
                <li>{{ isEn ? 'The offer combines SMB cybersecurity audit, phishing awareness, and a remediation roadmap.' : 'L offre combine audit cybersécurité PME, sensibilisation phishing et feuille de route de remediation.' }}</li>
                <li>{{ isEn ? 'It can be used independently of the software, or as a complement to MYKEYNEST adoption and secure password deployment.' : 'Elle peut etre utilisee independamment du logiciel ou en complement d un deploiement MYKEYNEST et d une politique de mots de passe securises.' }}</li>
                <li>{{ isEn ? 'If you are still comparing vendors, the comparison and solution pages provide the broader product context.' : 'Si vous etes encore en phase de comparaison, les pages comparatif et solution donnent le contexte produit plus large.' }}</li>
            </ul>
            <div style="display:flex;flex-wrap:wrap;gap:0.75rem;">
                <a href="{{ path('business_password_manager') }}" class="aud-cta-btn-ghost" style="text-decoration:none;">{{ isEn ? 'Password manager page' : 'Page gestionnaire de mots de passe' }}</a>
                <a href="{{ path('business_solution') }}" class="aud-cta-btn-white" style="text-decoration:none;">{{ isEn ? 'View the full solution' : 'Voir la solution complete' }}</a>
                <a href="{{ path('business_comparatif') }}" class="aud-cta-btn-ghost" style="text-decoration:none;">{{ isEn ? 'Open the comparison' : 'Ouvrir le comparatif' }}</a>
            </div>
        </div>
    </section>

    <div class="aud-layout">

{# ?? Stats proof ?? #}
<div class="aud-proof">
    <div>
        <div class="aud-proof-stat-number">91%</div>
        <div class="aud-proof-stat-label">
            {{ 'business.audit.proof.stat1'|trans }}
            <small class="aud-proof-source">
                (Source :
                <a href="https://www.ibm.com/reports/data-breach"
                   target="_blank" rel="noopener nofollow">
                    IBM Cost of a Data Breach Report
                </a>)
            </small>
        </div>
    </div>

    <div>
        <div class="aud-proof-stat-number">3x</div>
        <div class="aud-proof-stat-label">
            Risque accru d'attaque en cas d'absence de formation cybersecurite
            <small class="aud-proof-source">
                (estimation basee sur etudes sectorielles phishing et sensibilisation)
            </small>
        </div>
    </div>

    <div>
        <div class="aud-proof-stat-number">€18K</div>
        <div class="aud-proof-stat-label">
            Cout moyen d'un incident pour une PME
            <small class="aud-proof-source">
                (Source :
                <a href="https://www.ssi.gouv.fr/"
                   target="_blank" rel="noopener nofollow">
                    ANSSI
                </a>)
            </small>
        </div>
    </div>
</div>

<p class="aud-proof-disclaimer">
    Donnees indicatives issues de rapports publics. Les montants et pourcentages
    peuvent varier selon la taille de l'entreprise et le secteur d'activite.
</p>


        {# ?? Services ?? #}
        <div class="aud-section-eyebrow">{{ 'business.audit.services.eyebrow'|trans }}</div>
        <h2 class="aud-section-title">{{ 'business.audit.services.title'|trans }}</h2>
        <p class="aud-section-sub">{{ 'business.audit.services.subtitle'|trans }}</p>

        <div class="aud-services">
            {# Audit #}
            <div class="aud-service-card">
                <div class="aud-service-head">
                    <div class="aud-service-icon" aria-hidden="true"><i class="fa-solid fa-magnifying-glass"></i></div>
                    <div class="aud-service-title">{{ 'business.audit.services.audit.title'|trans }}</div>
                </div>
                <p class="aud-service-desc">{{ 'business.audit.services.audit.desc'|trans }}</p>
                <ul class="aud-service-list">
                    <li><span class="aud-li-check">&#10003;</span>{{ 'business.audit.services.audit.item1'|trans }}</li>
                    <li><span class="aud-li-check">&#10003;</span>{{ 'business.audit.services.audit.item2'|trans }}</li>
                    <li><span class="aud-li-check">&#10003;</span>{{ 'business.audit.services.audit.item3'|trans }}</li>
                    <li><span class="aud-li-check">&#10003;</span>{{ 'business.audit.services.audit.item4'|trans }}</li>
                </ul>
            </div>
            {# Formation #}
            <div class="aud-service-card">
                <div class="aud-service-head">
                    <div class="aud-service-icon" aria-hidden="true"><i class="fa-solid fa-chalkboard-user"></i></div>
                    <div class="aud-service-title">{{ 'business.audit.services.training.title'|trans }}</div>
                </div>
                <p class="aud-service-desc">{{ 'business.audit.services.training.desc'|trans }}</p>
                <ul class="aud-service-list">
                    <li><span class="aud-li-check">&#10003;</span>{{ 'business.audit.services.training.item1'|trans }}</li>
                    <li><span class="aud-li-check">&#10003;</span>{{ 'business.audit.services.training.item2'|trans }}</li>
                    <li><span class="aud-li-check">&#10003;</span>{{ 'business.audit.services.training.item3'|trans }}</li>
                    <li><span class="aud-li-check">&#10003;</span>{{ 'business.audit.services.training.item4'|trans }}</li>
                </ul>
            </div>
        </div>

        {# ?? Process ?? #}
        <div class="aud-process">
            <div class="aud-section-eyebrow">{{ 'business.audit.process.eyebrow'|trans }}</div>
            <h2 class="aud-section-title">{{ 'business.audit.process.title'|trans }}</h2>
            <p class="aud-section-sub">{{ 'business.audit.process.subtitle'|trans }}</p>
            <div class="aud-steps">
                <div class="aud-step">
                    <div class="aud-step-num">01</div>
                    <div class="aud-step-content">
                        <div class="aud-step-title">{{ 'business.audit.process.step1.title'|trans }}</div>
                        <p class="aud-step-desc">{{ 'business.audit.process.step1.desc'|trans }}</p>
                    </div>
                </div>
                <div class="aud-step">
                    <div class="aud-step-num">02</div>
                    <div class="aud-step-content">
                        <div class="aud-step-title">{{ 'business.audit.process.step2.title'|trans }}</div>
                        <p class="aud-step-desc">{{ 'business.audit.process.step2.desc'|trans }}</p>
                    </div>
                </div>
                <div class="aud-step">
                    <div class="aud-step-num">03</div>
                    <div class="aud-step-content">
                        <div class="aud-step-title">{{ 'business.audit.process.step3.title'|trans }}</div>
                        <p class="aud-step-desc">{{ 'business.audit.process.step3.desc'|trans }}</p>
                    </div>
                </div>
                <div class="aud-step">
                    <div class="aud-step-num">04</div>
                    <div class="aud-step-content">
                        <div class="aud-step-title">{{ 'business.audit.process.step4.title'|trans }}</div>
                        <p class="aud-step-desc">{{ 'business.audit.process.step4.desc'|trans }}</p>
                    </div>
                </div>
            </div>
        </div>

        {# ?? FAQ ?? #}
        <div class="aud-faq">
            <div class="aud-section-eyebrow">{{ 'business.audit.faq.eyebrow'|trans }}</div>
            <h2 class="aud-section-title">{{ 'business.audit.faq.title'|trans }}</h2>
            <div class="aud-faq-list" data-controller="faq-accordion">
                {% set faqs = ['q1','q2','q3','q4'] %}
                {% for faq in faqs %}
                <div class="aud-faq-item" data-faq-accordion-target="item">
                    <button class="aud-faq-btn" aria-expanded="false" data-faq-accordion-target="button" data-action="click->faq-accordion#toggle">
                        <span class="aud-faq-q">{{ ('business.audit.faq.' ~ faq ~ '.question')|trans }}</span>
                        <svg class="aud-faq-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                        </svg>
                    </button>
                    <div class="aud-faq-body">
                        <p>{{ ('business.audit.faq.' ~ faq ~ '.answer')|trans }}</p>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>

        {# ?? CTA ?? #}
        <div class="aud-cta">
            <div class="aud-cta-text">
                <div class="aud-cta-title">{{ 'business.audit.cta.title'|trans }}</div>
                <p class="aud-cta-sub">{{ 'business.audit.cta.subtitle'|trans }}</p>
            </div>
            <div class="aud-cta-actions">
                <a href="mailto:contact@key-nest.com" class="aud-cta-btn-white">{{ 'business.audit.cta.primary'|trans }}</a>
                <a href="{{ path('business_solution') }}" class="aud-cta-btn-ghost">{{ 'business.audit.cta.secondary'|trans }}</a>
            </div>
        </div>

        {% include 'components/seo/_internal_links.html.twig' with {
          sectionTitle: isEn ? 'Useful pages after the audit offer' : 'Pages utiles apres l offre audit',
          sectionSubtitle: isEn ? 'This page should connect service-oriented visitors to the product, the broader solution, the help center, and educational content instead of leaving them at a dead end.' : 'Cette page doit reconnecter les visiteurs orientes services vers le produit, la solution globale, le centre d aide et les contenus educatifs au lieu de les laisser en impasse.',
          links: [
            {
              route: 'business_password_manager',
              params: localeParams,
              icon: 'fa-solid fa-key',
              label: isEn ? 'Password manager' : 'Gestionnaire',
              title: isEn ? 'See the enterprise password manager for SMB teams' : 'Voir le gestionnaire de mots de passe entreprise pour equipes PME',
              text: isEn ? 'Useful when audit findings lead to stronger access control and password hygiene needs.' : 'Utile lorsque les constats d audit conduisent a renforcer le controle des acces et l hygiene des mots de passe.'
            },
            {
              route: 'business_solution',
              params: localeParams,
              icon: 'fa-solid fa-layer-group',
              label: isEn ? 'Full offer' : 'Offre complete',
              title: isEn ? 'Review the full SMB cybersecurity solution' : 'Relire la solution cybersécurité complete pour PME',
              text: isEn ? 'Connect services, software, support, and onboarding in one commercial path.' : 'Reliez services, logiciel, support et onboarding dans un seul parcours commercial.'
            },
            {
              route: 'app_help_center',
              params: localeParams,
              icon: 'fa-solid fa-book-open',
              label: isEn ? 'Documentation' : 'Documentation',
              title: isEn ? 'Read the help center and practical implementation guides' : 'Lire le centre d aide et les guides pratiques de mise en place',
              text: isEn ? 'Answer operational questions before the prospect leaves the site.' : 'Repondez aux questions operationnelles avant que le prospect ne quitte le site.'
            },
            {
              route: 'blog_index',
              params: { _locale: app.request.locale },
              icon: 'fa-solid fa-newspaper',
              label: isEn ? 'Blog' : 'Blog',
              title: isEn ? 'Open the cybersecurity blog and educational articles' : 'Ouvrir le blog cybersécurité et les articles educatifs',
              text: isEn ? 'Keep top-of-funnel visitors engaged with phishing, policy, and password-security content.' : 'Gardez engages les visiteurs haut de funnel avec des contenus sur le phishing, les politiques et la securite des mots de passe.'
            }
          ]
        } only %}

    </div>
</main>
{% endblock %}

