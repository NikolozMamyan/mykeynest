{% extends 'base_auth.html.twig' %}

{% block title %}{{ 'business.comparatif.meta.title'|trans }}{% endblock %}

{% block meta_description %}
{% set localeParams = app.request.locale == 'en' ? { lang: 'en' } : {} %}
<meta name="description" content="{{ 'business.comparatif.meta.description'|trans }}">
<meta name="keywords" content="{{ 'business.comparatif.meta.keywords'|trans }}">
<meta property="og:title" content="{{ 'business.comparatif.meta.title'|trans }}">
<meta property="og:description" content="{{ 'business.comparatif.meta.description'|trans }}">
<meta property="og:type" content="website">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "{{ 'business.comparatif.breadcrumb.home'|trans }}", "item": "{{ absolute_url(path('app_landing', localeParams)) }}" },
        { "@type": "ListItem", "position": 2, "name": "{{ 'business.comparatif.breadcrumb.solution'|trans }}", "item": "{{ absolute_url(path('business_solution', localeParams)) }}" },
        { "@type": "ListItem", "position": 3, "name": "{{ 'business.comparatif.breadcrumb.current'|trans }}", "item": "{{ absolute_url(path('business_comparatif', localeParams)) }}" }
      ]
    },
    {
      "@type": "Article",
      "headline": "{{ 'business.comparatif.schema.headline'|trans }}",
      "description": "{{ 'business.comparatif.schema.description'|trans }}",
      "mainEntityOfPage": "{{ absolute_url(path('business_comparatif', localeParams)) }}",
      "inLanguage": "{{ app.request.locale|default('fr') }}",
      "dateModified": "{{ "now"|date("Y-m-d") }}"
    }
  ]
}
</script>
{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/pages/business-comparatif.css') }}">
{% endblock %}

{% block body %}
<main>
    {# Breadcrumb #}
    <nav class="cmp-breadcrumb" aria-label="{{ 'business.comparatif.breadcrumb.aria'|trans }}">
        <div class="cmp-breadcrumb-inner">
            <a href="{{ path('app_landing') }}">{{ 'business.comparatif.breadcrumb.home'|trans }}</a>
            <span class="cmp-breadcrumb-sep">&rsaquo;</span>
            <a href="{{ path('business_solution') }}">{{ 'business.comparatif.breadcrumb.solution'|trans }}</a>
            <span class="cmp-breadcrumb-sep">&rsaquo;</span>
            <span class="cmp-breadcrumb-current">{{ 'business.comparatif.breadcrumb.current'|trans }}</span>
        </div>
    </nav>

    {# Hero #}
    <section class="cmp-hero">
        <div class="cmp-hero-inner">
            <div class="cmp-eyebrow">
                <i class="fa-solid fa-scale-balanced" aria-hidden="true"></i>
                {{ 'business.comparatif.hero.eyebrow'|trans }}
            </div>
            <h1>
                <span class="cmp-grad">MYKEYNEST</span>
                {{ 'business.comparatif.hero.h1_vs'|trans }}
                Bitwarden {{ 'business.comparatif.hero.h1_and'|trans }} 1Password
                <br>{{ 'business.comparatif.hero.h1_suffix'|trans }}
            </h1>
            <p class="cmp-hero-sub">{{ 'business.comparatif.hero.subtitle'|trans }}</p>
            <div class="cmp-disclaimer">
                <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
                {{ 'business.comparatif.hero.disclaimer'|trans }}
            </div>
        </div>
    </section>

    <section class="cmp-layout" aria-labelledby="cmp-summary-title" style="padding-top: 2rem;">
        {% set isEn = app.request.locale == 'en' %}
        <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:24px;padding:1.5rem 1.75rem;">
            <div class="cmp-section-eyebrow">{{ isEn ? 'Quick verdict' : 'Verdict rapide' }}</div>
            <h2 class="cmp-section-title" id="cmp-summary-title">{{ isEn ? 'What this comparison says' : 'Ce que dit ce comparatif' }}</h2>
            <p class="cmp-section-sub">{{ isEn ? 'This page helps SMB buyers compare enterprise password manager capabilities and included services before choosing a vendor.' : 'Cette page aide les PME a comparer les capacites d un gestionnaire de mots de passe entreprise et les services inclus avant de choisir un fournisseur.' }}</p>
            <ul style="margin:0 0 1rem 1.25rem;color:#334155;line-height:1.7;">
                <li>{{ isEn ? 'MYKEYNEST is positioned on value for SMBs that want a business password manager plus support, training, and audit guidance.' : 'MYKEYNEST se positionne sur la valeur pour les PME qui veulent un gestionnaire de mots de passe entreprise avec support, formation et accompagnement audit.' }}</li>
                <li>{{ isEn ? 'The comparison emphasizes operational support, phishing awareness, and French-language service in addition to core security features.' : 'Le comparatif met en avant l accompagnement operationnel, la sensibilisation phishing et le support francophone en plus des fonctions de securite.' }}</li>
                <li>{{ isEn ? 'For implementation details, continue to the solution page; for awareness and remediation services, continue to the audit page.' : 'Pour les details de mise en place, poursuivez sur la page solution ; pour les services de sensibilisation et remediation, poursuivez sur la page audit.' }}</li>
            </ul>
            <div style="display:flex;flex-wrap:wrap;gap:0.75rem;">
                <a href="{{ path('business_password_manager') }}" class="cmp-cta-btn" style="background:#fff;color:#0f172a;border:1px solid #cbd5e1;">{{ isEn ? 'Password manager page' : 'Page gestionnaire de mots de passe' }}</a>
                <a href="{{ path('business_solution') }}" class="cmp-cta-btn">{{ isEn ? 'See the full solution' : 'Voir la solution complete' }}</a>
                <a href="{{ path('business_audit') }}" class="cmp-cta-btn" style="background:#fff;color:#0f172a;border:1px solid #cbd5e1;">{{ isEn ? 'See audit services' : 'Voir les services audit' }}</a>
            </div>
        </div>
    </section>

    <div class="cmp-layout">

        {# Tableau comparatif #}
        <div class="cmp-section-eyebrow">{{ 'business.comparatif.table.eyebrow'|trans }}</div>
        <h2 class="cmp-section-title">{{ 'business.comparatif.table.title'|trans }}</h2>
        <p class="cmp-section-sub">{{ 'business.comparatif.table.subtitle'|trans }}</p>

        <div class="cmp-table-wrap">
            <table class="cmp-table" aria-label="{{ 'business.comparatif.table.aria'|trans }}">
                <thead>
                    <tr>
                        <th class="cmp-th-empty" scope="col"></th>
                        <th class="cmp-th cmp-th-mykeynest" scope="col">
                            <div class="cmp-th-logo">
                                <i class="fa-solid fa-shield-halved" aria-hidden="true"></i> MYKEYNEST
                                <span class="cmp-badge-winner">{{ 'business.comparatif.table.badge_recommended'|trans }}</span>
                                <span class="cmp-th-price">6,99€</span>
                            </div>
                        </th>
                        <th class="cmp-th" scope="col">
                            <div class="cmp-th-logo">
                                Bitwarden<br>
                                <span class="cmp-th-price cmp-th-price-other">~10€+</span>
                            </div>
                        </th>
                        <th class="cmp-th" scope="col">
                            <div class="cmp-th-logo">
                                1Password<br>
                                <span class="cmp-th-price cmp-th-price-other">~12€+</span>
                            </div>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    {# Tarif #}
                    <tr class="cmp-row-category">
                        <td class="cmp-td-category-label" colspan="4">{{ 'business.comparatif.table.cat_pricing'|trans }}</td>
                    </tr>
                    <tr>
                        <td class="cmp-td-feature">{{ 'business.comparatif.table.row.price_per_user'|trans }}<small>{{ 'business.comparatif.table.row.price_per_user_sub'|trans }}</small></td>
                        <td class="cmp-td-val cmp-td-mykeynest"><span class="cmp-th-price">6,99€</span></td>
                        <td class="cmp-td-val"><span class="cmp-val-text">~10€+</span></td>
                        <td class="cmp-td-val"><span class="cmp-val-text">~12€+</span></td>
                    </tr>
                    <tr>
                        <td class="cmp-td-feature">{{ 'business.comparatif.table.row.free_trial'|trans }}</td>
                        <td class="cmp-td-val cmp-td-mykeynest"><span class="cmp-yes"><i class="fa-solid fa-check"></i></span></td>
                        <td class="cmp-td-val"><span class="cmp-yes"><i class="fa-solid fa-check"></i></span></td>
                        <td class="cmp-td-val"><span class="cmp-partial"><i class="fa-solid fa-minus"></i></span></td>
                    </tr>

                    {# Securite #}
                    <tr class="cmp-row-category">
                        <td class="cmp-td-category-label" colspan="4">{{ 'business.comparatif.table.cat_security'|trans }}</td>
                    </tr>
                    <tr>
                        <td class="cmp-td-feature">{{ 'business.comparatif.table.row.aes256'|trans }}</td>
                        <td class="cmp-td-val cmp-td-mykeynest"><span class="cmp-yes"><i class="fa-solid fa-check"></i></span></td>
                        <td class="cmp-td-val"><span class="cmp-yes"><i class="fa-solid fa-check"></i></span></td>
                        <td class="cmp-td-val"><span class="cmp-yes"><i class="fa-solid fa-check"></i></span></td>
                    </tr>
                    <tr>
                        <td class="cmp-td-feature">{{ 'business.comparatif.table.row.zero_knowledge'|trans }}</td>
                        <td class="cmp-td-val cmp-td-mykeynest"><span class="cmp-yes"><i class="fa-solid fa-check"></i></span></td>
                        <td class="cmp-td-val"><span class="cmp-yes"><i class="fa-solid fa-check"></i></span></td>
                        <td class="cmp-td-val"><span class="cmp-yes"><i class="fa-solid fa-check"></i></span></td>
                    </tr>
                    <tr>
                        <td class="cmp-td-feature">{{ 'business.comparatif.table.row.2fa'|trans }}</td>
                        <td class="cmp-td-val cmp-td-mykeynest"><span class="cmp-yes"><i class="fa-solid fa-check"></i></span></td>
                        <td class="cmp-td-val"><span class="cmp-yes"><i class="fa-solid fa-check"></i></span></td>
                        <td class="cmp-td-val"><span class="cmp-yes"><i class="fa-solid fa-check"></i></span></td>
                    </tr>
                    <tr>
                        <td class="cmp-td-feature">{{ 'business.comparatif.table.row.audit'|trans }}<small>{{ 'business.comparatif.table.row.audit_sub'|trans }}</small></td>
                        <td class="cmp-td-val cmp-td-mykeynest"><span class="cmp-yes"><i class="fa-solid fa-check"></i></span></td>
                        <td class="cmp-td-val"><span class="cmp-partial"><i class="fa-solid fa-minus"></i></span></td>
                        <td class="cmp-td-val"><span class="cmp-partial"><i class="fa-solid fa-minus"></i></span></td>
                    </tr>

                    {# Services inclus #}
                    <tr class="cmp-row-category">
                        <td class="cmp-td-category-label" colspan="4">{{ 'business.comparatif.table.cat_services'|trans }}</td>
                    </tr>
                    <tr>
                        <td class="cmp-td-feature">{{ 'business.comparatif.table.row.maintenance'|trans }}<small>{{ 'business.comparatif.table.row.maintenance_sub'|trans }}</small></td>
                        <td class="cmp-td-val cmp-td-mykeynest"><span class="cmp-yes"><i class="fa-solid fa-check"></i></span></td>
                        <td class="cmp-td-val"><span class="cmp-no"><i class="fa-solid fa-xmark"></i></span></td>
                        <td class="cmp-td-val"><span class="cmp-no"><i class="fa-solid fa-xmark"></i></span></td>
                    </tr>
                    <tr>
                        <td class="cmp-td-feature">{{ 'business.comparatif.table.row.training'|trans }}<small>{{ 'business.comparatif.table.row.training_sub'|trans }}</small></td>
                        <td class="cmp-td-val cmp-td-mykeynest"><span class="cmp-yes"><i class="fa-solid fa-check"></i></span></td>
                        <td class="cmp-td-val"><span class="cmp-no"><i class="fa-solid fa-xmark"></i></span></td>
                        <td class="cmp-td-val"><span class="cmp-no"><i class="fa-solid fa-xmark"></i></span></td>
                    </tr>
                    <tr>
                        <td class="cmp-td-feature">{{ 'business.comparatif.table.row.security_audit'|trans }}<small>{{ 'business.comparatif.table.row.security_audit_sub'|trans }}</small></td>
                        <td class="cmp-td-val cmp-td-mykeynest"><span class="cmp-yes"><i class="fa-solid fa-check"></i></span></td>
                        <td class="cmp-td-val"><span class="cmp-no"><i class="fa-solid fa-xmark"></i></span></td>
                        <td class="cmp-td-val"><span class="cmp-no"><i class="fa-solid fa-xmark"></i></span></td>
                    </tr>
                    <tr>
                        <td class="cmp-td-feature">{{ 'business.comparatif.table.row.support'|trans }}</td>
                        <td class="cmp-td-val cmp-td-mykeynest"><span class="cmp-yes"><i class="fa-solid fa-check"></i></span></td>
                        <td class="cmp-td-val"><span class="cmp-partial"><i class="fa-solid fa-minus"></i></span></td>
                        <td class="cmp-td-val"><span class="cmp-partial"><i class="fa-solid fa-minus"></i></span></td>
                    </tr>
                    <tr>
                        <td class="cmp-td-feature">{{ 'business.comparatif.table.row.french_support'|trans }}</td>
                        <td class="cmp-td-val cmp-td-mykeynest"><span class="cmp-yes"><i class="fa-solid fa-check"></i></span></td>
                        <td class="cmp-td-val"><span class="cmp-no"><i class="fa-solid fa-xmark"></i></span></td>
                        <td class="cmp-td-val"><span class="cmp-no"><i class="fa-solid fa-xmark"></i></span></td>
                    </tr>
                </tbody>
            </table>
        </div>

        {# Pourquoi choisir MYKEYNEST #}
        <div class="cmp-section-eyebrow">{{ 'business.comparatif.why.eyebrow'|trans }}</div>
        <h2 class="cmp-section-title">{{ 'business.comparatif.why.title'|trans }}</h2>
        <p class="cmp-section-sub">{{ 'business.comparatif.why.subtitle'|trans }}</p>

        <div class="cmp-why-grid">
            <div class="cmp-why-card">
                <div class="cmp-why-icon"><i class="fa-solid fa-sack-dollar"></i></div>
                <div class="cmp-why-title">{{ 'business.comparatif.why.price.title'|trans }}</div>
                <p class="cmp-why-desc">{{ 'business.comparatif.why.price.desc'|trans }}</p>
            </div>
            <div class="cmp-why-card">
                <div class="cmp-why-icon"><i class="fa-solid fa-screwdriver-wrench"></i></div>
                <div class="cmp-why-title">{{ 'business.comparatif.why.maintenance.title'|trans }}</div>
                <p class="cmp-why-desc">{{ 'business.comparatif.why.maintenance.desc'|trans }}</p>
            </div>
            <div class="cmp-why-card">
                <div class="cmp-why-icon"><i class="fa-solid fa-user-check"></i></div>
                <div class="cmp-why-title">{{ 'business.comparatif.why.training.title'|trans }}</div>
                <p class="cmp-why-desc">{{ 'business.comparatif.why.training.desc'|trans }}</p>
            </div>
            <div class="cmp-why-card">
                <div class="cmp-why-icon"><i class="fa-solid fa-flag"></i></div>
                <div class="cmp-why-title">{{ 'business.comparatif.why.french.title'|trans }}</div>
                <p class="cmp-why-desc">{{ 'business.comparatif.why.french.desc'|trans }}</p>
            </div>
        </div>

        {# CTA #}
        <div class="cmp-cta">
            <h2 class="cmp-cta-title">{{ 'business.comparatif.cta.title'|trans }}</h2>
            <p class="cmp-cta-sub">{{ 'business.comparatif.cta.subtitle'|trans }}</p>
            <a href="{{ path('show_register') }}" class="cmp-cta-btn">
                <i class="fa-solid fa-rocket" aria-hidden="true"></i>
                {{ 'business.comparatif.cta.button'|trans }}
            </a>
        </div>

    </div>
</main>
{% endblock %}
