{% extends 'base_auth.html.twig' %}

{% block title %}{{ 'business.password_manager.meta.title'|trans }}{% endblock %}

{% block meta_description %}
{% set localeParams = app.request.locale == 'en' ? { lang: 'en' } : {} %}
<meta name="description" content="{{ 'business.password_manager.meta.description'|trans }}">
<meta name="keywords" content="{{ 'business.password_manager.meta.keywords'|trans }}">
<meta property="og:title" content="{{ 'business.password_manager.meta.title'|trans }}">
<meta property="og:description" content="{{ 'business.password_manager.meta.description'|trans }}">
<meta property="og:type" content="website">
<meta name="twitter:card" content="summary_large_image">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "{{ 'business.password_manager.breadcrumb.home'|trans }}", "item": "{{ absolute_url(path('app_landing', localeParams)) }}" },
        { "@type": "ListItem", "position": 2, "name": "{{ 'business.password_manager.breadcrumb.solution'|trans }}", "item": "{{ absolute_url(path('business_solution', localeParams)) }}" },
        { "@type": "ListItem", "position": 3, "name": "{{ 'business.password_manager.breadcrumb.current'|trans }}", "item": "{{ absolute_url(path('business_password_manager', localeParams)) }}" }
      ]
    },
    {
      "@type": "WebPage",
      "name": "{{ 'business.password_manager.meta.title'|trans }}",
      "url": "{{ absolute_url(path('business_password_manager', localeParams)) }}",
      "inLanguage": "{{ app.request.locale|default('fr') }}",
      "description": "{{ 'business.password_manager.meta.description'|trans|e('js') }}"
    }
  ]
}
</script>
{% endblock %}

{% block page_styles %}
<style>
  .pmgr-page {
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: #0f172a;
  }

  .pmgr-wrap {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
  }

  .pmgr-hero {
    padding: 3.5rem 0 2rem;
  }

  .pmgr-breadcrumb {
    display: flex;
    gap: .5rem;
    flex-wrap: wrap;
    align-items: center;
    color: #64748b;
    font-size: .92rem;
    margin-bottom: 1rem;
  }

  .pmgr-breadcrumb a {
    color: inherit;
    text-decoration: none;
  }

  .pmgr-breadcrumb a:hover {
    color: #0f172a;
  }

  .pmgr-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: .6rem;
    padding: .45rem .8rem;
    border-radius: 999px;
    background: rgba(5,150,105,.1);
    color: #047857;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .pmgr-hero-grid {
    display: grid;
    grid-template-columns: 1.15fr .85fr;
    gap: 2rem;
    align-items: center;
  }

  .pmgr-hero h1 {
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.02;
    letter-spacing: -.04em;
    margin: 0 0 1rem;
  }

  .pmgr-gradient {
    background: linear-gradient(135deg, #059669, #2563eb);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .pmgr-subtitle {
    color: #475569;
    font-size: 1.08rem;
    line-height: 1.7;
    max-width: 62ch;
  }

  .pmgr-pills {
    display: flex;
    flex-wrap: wrap;
    gap: .75rem;
    margin: 1.25rem 0 1.5rem;
  }

  .pmgr-pill {
    padding: .6rem .9rem;
    border-radius: 999px;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    color: #334155;
    font-weight: 600;
  }

  .pmgr-actions {
    display: flex;
    flex-wrap: wrap;
    gap: .85rem;
  }

  .pmgr-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: .55rem;
    padding: .92rem 1.2rem;
    border-radius: 14px;
    text-decoration: none;
    font-weight: 700;
  }

  .pmgr-btn-primary {
    background: linear-gradient(135deg, #059669, #2563eb);
    color: #fff;
  }

  .pmgr-btn-secondary {
    border: 1px solid #cbd5e1;
    color: #0f172a;
    background: #fff;
  }

  .pmgr-card {
    border-radius: 26px;
    background: linear-gradient(180deg, #0f172a, #111827);
    color: #e2e8f0;
    padding: 1.35rem;
    box-shadow: 0 25px 60px rgba(15, 23, 42, .22);
  }

  .pmgr-card-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: .86rem;
    color: #94a3b8;
  }

  .pmgr-dotset {
    display: flex;
    gap: .35rem;
  }

  .pmgr-dot {
    width: .62rem;
    height: .62rem;
    border-radius: 999px;
    background: #334155;
  }

  .pmgr-console {
    display: grid;
    gap: .7rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: .9rem;
  }

  .pmgr-console-line {
    color: #cbd5e1;
  }

  .pmgr-console-ok {
    color: #34d399;
  }

  .pmgr-section {
    padding: 1.5rem 0 0;
  }

  .pmgr-section-head {
    max-width: 760px;
    margin-bottom: 1.4rem;
  }

  .pmgr-section-head h2 {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    line-height: 1.1;
    margin: 0 0 .75rem;
  }

  .pmgr-section-head p {
    margin: 0;
    color: #475569;
    line-height: 1.75;
  }

  .pmgr-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .pmgr-panel {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 22px;
    padding: 1.25rem;
    box-shadow: 0 18px 40px rgba(148, 163, 184, .12);
  }

  .pmgr-panel i {
    font-size: 1.2rem;
    color: #059669;
    margin-bottom: .8rem;
  }

  .pmgr-panel h3 {
    margin: 0 0 .6rem;
    font-size: 1.06rem;
  }

  .pmgr-panel p,
  .pmgr-panel li {
    color: #475569;
    line-height: 1.7;
  }

  .pmgr-panel ul {
    margin: .8rem 0 0 1.1rem;
    padding: 0;
  }

  .pmgr-band {
    margin-top: 1.25rem;
    padding: 1.25rem;
    border-radius: 22px;
    background: linear-gradient(135deg, #eff6ff, #ecfdf5);
    border: 1px solid #dbeafe;
  }

  .pmgr-band strong {
    display: block;
    margin-bottom: .45rem;
    font-size: 1rem;
  }

  .pmgr-steps {
    display: grid;
    gap: .9rem;
  }

  .pmgr-demo {
    margin-top: 1.25rem;
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    gap: 1.2rem;
    align-items: center;
  }

  .pmgr-demo-copy {
    padding: 1.2rem 0;
  }

  .pmgr-demo-copy strong {
    display: inline-flex;
    align-items: center;
    gap: .55rem;
    color: #047857;
    font-size: .9rem;
    margin-bottom: .8rem;
  }

  .pmgr-demo-copy h3 {
    font-size: clamp(1.5rem, 2.8vw, 2.1rem);
    line-height: 1.1;
    margin: 0 0 .8rem;
  }

  .pmgr-demo-copy p {
    color: #475569;
    line-height: 1.8;
    margin: 0 0 1rem;
  }

  .pmgr-demo-points {
    margin: 0;
    padding-left: 1.1rem;
    color: #334155;
    line-height: 1.75;
  }

  .pmgr-video-shell {
    position: relative;
    border-radius: 28px;
    padding: 1rem;
    background:
      radial-gradient(circle at top left, rgba(5,150,105,.18), transparent 35%),
      radial-gradient(circle at bottom right, rgba(37,99,235,.18), transparent 35%),
      linear-gradient(180deg, #0f172a, #111827);
    box-shadow: 0 30px 70px rgba(15,23,42,.22);
  }

  .pmgr-video-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    color: #94a3b8;
    font-family: 'JetBrains Mono', monospace;
    font-size: .8rem;
    margin-bottom: .8rem;
  }

  .pmgr-video-screen {
    position: relative;
    border-radius: 22px;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    background: #020617;
    border: 1px solid rgba(148,163,184,.18);
  }

  .pmgr-video-screen iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }

  .pmgr-step {
    display: grid;
    grid-template-columns: 70px 1fr;
    gap: 1rem;
    align-items: start;
    padding: 1rem 1.1rem;
    border-radius: 20px;
    background: #fff;
    border: 1px solid #e2e8f0;
  }

  .pmgr-step-no {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 54px;
    height: 54px;
    border-radius: 18px;
    background: linear-gradient(135deg, #059669, #2563eb);
    color: #fff;
    font-weight: 800;
    letter-spacing: .06em;
  }

  .pmgr-links {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .pmgr-link-card {
    text-decoration: none;
    color: inherit;
    padding: 1.15rem;
    border-radius: 22px;
    background: #fff;
    border: 1px solid #e2e8f0;
    transition: transform .18s ease, box-shadow .18s ease;
  }

  .pmgr-link-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 40px rgba(148, 163, 184, .16);
  }

  .pmgr-link-card span {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    color: #059669;
    font-size: .82rem;
    font-weight: 700;
    margin-bottom: .6rem;
  }

  .pmgr-cta {
    margin: 2rem 0 3rem;
    padding: 1.6rem;
    border-radius: 28px;
    background: linear-gradient(135deg, #0f172a, #1d4ed8);
    color: #fff;
  }

  .pmgr-cta h2,
  .pmgr-cta p {
    margin: 0;
  }

  .pmgr-cta p {
    margin-top: .75rem;
    color: rgba(255,255,255,.85);
    line-height: 1.7;
  }

  .pmgr-cta .pmgr-actions {
    margin-top: 1.2rem;
  }

  .pmgr-cta .pmgr-btn-secondary {
    background: rgba(255,255,255,.12);
    color: #fff;
    border-color: rgba(255,255,255,.24);
  }

  @media (max-width: 960px) {
    .pmgr-hero-grid,
    .pmgr-grid,
    .pmgr-links,
    .pmgr-demo {
      grid-template-columns: 1fr;
    }
  }
</style>
{% endblock %}

{% block body %}
{% set isEn = app.request.locale == 'en' %}
{% set localeParams = app.request.locale == 'en' ? { lang: 'en' } : {} %}
<main class="pmgr-page">
  <section class="pmgr-hero">
    <div class="pmgr-wrap">
      <nav class="pmgr-breadcrumb" aria-label="{{ 'business.password_manager.breadcrumb.aria'|trans }}">
        <a href="{{ path('app_landing', localeParams) }}">{{ 'business.password_manager.breadcrumb.home'|trans }}</a>
        <span>&rsaquo;</span>
        <a href="{{ path('business_solution', localeParams) }}">{{ 'business.password_manager.breadcrumb.solution'|trans }}</a>
        <span>&rsaquo;</span>
        <span>{{ 'business.password_manager.breadcrumb.current'|trans }}</span>
      </nav>

      <div class="pmgr-eyebrow">
        <i class="fa-solid fa-key" aria-hidden="true"></i>
        {{ 'business.password_manager.hero.eyebrow'|trans }}
      </div>

      <div class="pmgr-hero-grid">
        <div>
          <h1>
            {{ 'business.password_manager.hero.h1_before'|trans }}
            <span class="pmgr-gradient">{{ 'business.password_manager.hero.h1_highlight'|trans }}</span>
            {{ 'business.password_manager.hero.h1_after'|trans }}
          </h1>
          <p class="pmgr-subtitle">{{ 'business.password_manager.hero.subtitle'|trans }}</p>

          <div class="pmgr-pills">
            <span class="pmgr-pill">{{ 'business.password_manager.hero.pill1'|trans }}</span>
            <span class="pmgr-pill">{{ 'business.password_manager.hero.pill2'|trans }}</span>
            <span class="pmgr-pill">{{ 'business.password_manager.hero.pill3'|trans }}</span>
          </div>

          <div class="pmgr-actions">
            <a href="{{ path('show_register') }}" class="pmgr-btn pmgr-btn-primary">
              <i class="fa-solid fa-rocket" aria-hidden="true"></i>
              {{ 'business.password_manager.hero.cta_primary'|trans }}
            </a>
            <a href="{{ path('business_comparatif', localeParams) }}" class="pmgr-btn pmgr-btn-secondary">
              {{ 'business.password_manager.hero.cta_secondary'|trans }}
            </a>
          </div>
        </div>

        <div class="pmgr-card">
          <div class="pmgr-card-head">
            <div class="pmgr-dotset">
              <span class="pmgr-dot"></span>
              <span class="pmgr-dot"></span>
              <span class="pmgr-dot"></span>
            </div>
            <span>mykeynest://access-control</span>
          </div>
          <div class="pmgr-console">
            <div class="pmgr-console-line">$ vault status</div>
            <div class="pmgr-console-line pmgr-console-ok">{{ 'business.password_manager.hero.console_1'|trans }}</div>
            <div class="pmgr-console-line">$ policy audit</div>
            <div class="pmgr-console-line pmgr-console-ok">{{ 'business.password_manager.hero.console_2'|trans }}</div>
            <div class="pmgr-console-line">$ share access --team marketing</div>
            <div class="pmgr-console-line pmgr-console-ok">{{ 'business.password_manager.hero.console_3'|trans }}</div>
            <div class="pmgr-console-line">$ incident-prevention</div>
            <div class="pmgr-console-line pmgr-console-ok">{{ 'business.password_manager.hero.console_4'|trans }}</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="pmgr-section">
    <div class="pmgr-wrap">
      <div class="pmgr-section-head">
        <h2>{{ 'business.password_manager.why.title'|trans }}</h2>
        <p>{{ 'business.password_manager.why.subtitle'|trans }}</p>
      </div>

      <div class="pmgr-grid">
        <article class="pmgr-panel">
          <i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i>
          <h3>{{ 'business.password_manager.why.card1.title'|trans }}</h3>
          <p>{{ 'business.password_manager.why.card1.text'|trans }}</p>
        </article>
        <article class="pmgr-panel">
          <i class="fa-solid fa-share-nodes" aria-hidden="true"></i>
          <h3>{{ 'business.password_manager.why.card2.title'|trans }}</h3>
          <p>{{ 'business.password_manager.why.card2.text'|trans }}</p>
        </article>
        <article class="pmgr-panel">
          <i class="fa-solid fa-shield-halved" aria-hidden="true"></i>
          <h3>{{ 'business.password_manager.why.card3.title'|trans }}</h3>
          <p>{{ 'business.password_manager.why.card3.text'|trans }}</p>
        </article>
      </div>

      <div class="pmgr-band">
        <strong>{{ 'business.password_manager.why.band_title'|trans }}</strong>
        <p>{{ 'business.password_manager.why.band_text'|trans }}</p>
      </div>

      <div class="pmgr-demo">
        <div class="pmgr-demo-copy">
          <strong><i class="fa-solid fa-play-circle" aria-hidden="true"></i>{{ 'business.password_manager.demo.eyebrow'|trans }}</strong>
          <h3>{{ 'business.password_manager.demo.title'|trans }}</h3>
          <p>{{ 'business.password_manager.demo.text'|trans }}</p>
          <ul class="pmgr-demo-points">
            <li>{{ 'business.password_manager.demo.point1'|trans }}</li>
            <li>{{ 'business.password_manager.demo.point2'|trans }}</li>
            <li>{{ 'business.password_manager.demo.point3'|trans }}</li>
          </ul>
        </div>

        <div class="pmgr-video-shell">
          <div class="pmgr-video-bar">
            <div class="pmgr-dotset">
              <span class="pmgr-dot"></span>
              <span class="pmgr-dot"></span>
              <span class="pmgr-dot"></span>
            </div>
            <span>mykeynest://demo/password-manager</span>
          </div>
          <div class="pmgr-video-screen">
            <iframe
              src="https://www.youtube-nocookie.com/embed/IS4YgAdW-H8?rel=0"
              title="{{ 'business.password_manager.demo.iframe_title'|trans }}"
              loading="lazy"
              referrerpolicy="strict-origin-when-cross-origin"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="pmgr-section">
    <div class="pmgr-wrap">
      <div class="pmgr-section-head">
        <h2>{{ 'business.password_manager.features.title'|trans }}</h2>
        <p>{{ 'business.password_manager.features.subtitle'|trans }}</p>
      </div>

      <div class="pmgr-grid">
        <article class="pmgr-panel">
          <i class="fa-solid fa-lock" aria-hidden="true"></i>
          <h3>{{ 'business.password_manager.features.card1.title'|trans }}</h3>
          <ul>
            <li>{{ 'business.password_manager.features.card1.item1'|trans }}</li>
            <li>{{ 'business.password_manager.features.card1.item2'|trans }}</li>
            <li>{{ 'business.password_manager.features.card1.item3'|trans }}</li>
          </ul>
        </article>
        <article class="pmgr-panel">
          <i class="fa-solid fa-users" aria-hidden="true"></i>
          <h3>{{ 'business.password_manager.features.card2.title'|trans }}</h3>
          <ul>
            <li>{{ 'business.password_manager.features.card2.item1'|trans }}</li>
            <li>{{ 'business.password_manager.features.card2.item2'|trans }}</li>
            <li>{{ 'business.password_manager.features.card2.item3'|trans }}</li>
          </ul>
        </article>
        <article class="pmgr-panel">
          <i class="fa-solid fa-chart-line" aria-hidden="true"></i>
          <h3>{{ 'business.password_manager.features.card3.title'|trans }}</h3>
          <ul>
            <li>{{ 'business.password_manager.features.card3.item1'|trans }}</li>
            <li>{{ 'business.password_manager.features.card3.item2'|trans }}</li>
            <li>{{ 'business.password_manager.features.card3.item3'|trans }}</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="pmgr-section">
    <div class="pmgr-wrap">
      <div class="pmgr-section-head">
        <h2>{{ 'business.password_manager.steps.title'|trans }}</h2>
        <p>{{ 'business.password_manager.steps.subtitle'|trans }}</p>
      </div>

      <div class="pmgr-steps">
        {% for idx in 1..4 %}
          <article class="pmgr-step">
            <div class="pmgr-step-no">{{ '%02d'|format(idx) }}</div>
            <div>
              <h3>{{ ('business.password_manager.steps.step' ~ idx ~ '.title')|trans }}</h3>
              <p>{{ ('business.password_manager.steps.step' ~ idx ~ '.text')|trans }}</p>
            </div>
          </article>
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="pmgr-section">
    <div class="pmgr-wrap">
      <div class="pmgr-section-head">
        <h2>{{ 'business.password_manager.links.title'|trans }}</h2>
        <p>{{ 'business.password_manager.links.subtitle'|trans }}</p>
      </div>

      <div class="pmgr-links">
        <a href="{{ path('business_solution', localeParams) }}" class="pmgr-link-card">
          <span><i class="fa-solid fa-layer-group" aria-hidden="true"></i>{{ 'business.password_manager.links.solution.label'|trans }}</span>
          <strong>{{ 'business.password_manager.links.solution.title'|trans }}</strong>
          <p>{{ 'business.password_manager.links.solution.text'|trans }}</p>
        </a>
        <a href="{{ path('business_comparatif', localeParams) }}" class="pmgr-link-card">
          <span><i class="fa-solid fa-scale-balanced" aria-hidden="true"></i>{{ 'business.password_manager.links.comparatif.label'|trans }}</span>
          <strong>{{ 'business.password_manager.links.comparatif.title'|trans }}</strong>
          <p>{{ 'business.password_manager.links.comparatif.text'|trans }}</p>
        </a>
        <a href="{{ path('business_audit', localeParams) }}" class="pmgr-link-card">
          <span><i class="fa-solid fa-shield-virus" aria-hidden="true"></i>{{ 'business.password_manager.links.audit.label'|trans }}</span>
          <strong>{{ 'business.password_manager.links.audit.title'|trans }}</strong>
          <p>{{ 'business.password_manager.links.audit.text'|trans }}</p>
        </a>
      </div>
    </div>
  </section>

  <section class="pmgr-wrap">
    <div class="pmgr-cta">
      <h2>{{ 'business.password_manager.cta.title'|trans }}</h2>
      <p>{{ 'business.password_manager.cta.subtitle'|trans }}</p>
      <div class="pmgr-actions">
        <a href="{{ path('show_register') }}" class="pmgr-btn pmgr-btn-primary">
          <i class="fa-solid fa-rocket" aria-hidden="true"></i>
          {{ 'business.password_manager.cta.primary'|trans }}
        </a>
        <a href="mailto:contact@key-nest.com" class="pmgr-btn pmgr-btn-secondary">
          <i class="fa-solid fa-envelope" aria-hidden="true"></i>
          {{ 'business.password_manager.cta.secondary'|trans }}
        </a>
      </div>
    </div>
  </section>
</main>
{% endblock %}
