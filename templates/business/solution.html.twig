{% extends 'base_auth.html.twig' %}

{% block title %}{{ 'business.solution.meta.title'|trans }}{% endblock %}

{% block meta_description %}
{% set localeParams = app.request.locale == 'en' ? { lang: 'en' } : {} %}
<meta name="description" content="{{ 'business.solution.meta.description'|trans }}">
<meta name="keywords" content="{{ 'business.solution.meta.keywords'|trans }}">
<meta property="og:title" content="{{ 'business.solution.meta.title'|trans }}">
<meta property="og:description" content="{{ 'business.solution.meta.description'|trans }}">
<meta property="og:type" content="website">
<meta name="twitter:card" content="summary_large_image">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "MYKEYNEST", "item": "{{ absolute_url(path('app_landing', localeParams)) }}" },
        { "@type": "ListItem", "position": 2, "name": "{{ 'business.solution.hero.eyebrow'|trans }}", "item": "{{ absolute_url(path('business_solution', localeParams)) }}" }
      ]
    },
    {
      "@type": "Service",
      "name": "{{ 'business.solution.schema.name'|trans }}",
      "description": "{{ 'business.solution.schema.description'|trans }}",
      "provider": { "@type": "Organization", "name": "MYKEYNEST" },
      "areaServed": "Europe",
      "offers": {
        "@type": "Offer",
        "price": "6.99",
        "priceCurrency": "EUR"
      }
    }
  ]
}
</script>
{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/pages/business-solution.css') }}">
{% endblock %}

{% block body %}
<main>

{# ======================== HERO ======================== #}
<section class="hero">
  <div class="hero-inner">
    <div class="hero-eyebrow">
      <i class="fas fa-building-lock" aria-hidden="true"></i>
      {{ 'business.solution.hero.eyebrow'|trans }}
    </div>
    <h1>
      {{ 'business.solution.hero.h1_before'|trans }}
      <span class="hero-grad">{{ 'business.solution.hero.h1_highlight'|trans }}</span>
      {{ 'business.solution.hero.h1_after'|trans }}
    </h1>
    <p class="hero-sub">{{ 'business.solution.hero.subtitle'|trans }}</p>

    {# Stat strip #}
    <div class="hero-stats" aria-label="Chiffres cles">
      <div class="hero-stat">
        <div class="hero-stat-num">AES-256</div>
        <div class="hero-stat-label">Chiffrement</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-num">0</div>
        <div class="hero-stat-label">Donnees lisibles</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-num">6,99€</div>
        <div class="hero-stat-label">/ utilisateur / mois</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-num">100%</div>
        <div class="hero-stat-label">Europeen</div>
      </div>
    </div>

    <div class="hero-actions">
      <a href="{{ path('show_register') }}" class="btn btn-green btn-lg btn-w">
        <i class="fas fa-rocket" aria-hidden="true"></i>
        {{ 'business.solution.hero.cta_primary'|trans }}
      </a>
      <a href="{{ path('business_audit') }}" class="btn btn-outline btn-lg btn-w">
        {{ 'business.solution.hero.cta_secondary'|trans }}
      </a>
    </div>

    <div class="hero-trust">
      <div class="trust-item"><span class="trust-check"><i class="fas fa-check"></i></span>{{ 'business.solution.hero.trust.no_commitment'|trans }}</div>
      <div class="trust-item"><span class="trust-check"><i class="fas fa-check"></i></span>{{ 'business.solution.hero.trust.setup'|trans }}</div>
      <div class="trust-item"><span class="trust-check"><i class="fas fa-check"></i></span>{{ 'business.solution.hero.trust.support'|trans }}</div>
    </div>
  </div>
</section>

<section class="wrap" aria-labelledby="solution-summary-title" style="padding: 2rem 0 0;">
  {% set isEn = app.request.locale == 'en' %}
  <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:24px;padding:1.5rem 1.75rem;">
    <div class="shead-eye" style="margin-bottom:0.75rem;"><i class="fas fa-bolt"></i> {{ isEn ? 'Quick summary' : 'Resume rapide' }}</div>
    <h2 id="solution-summary-title" style="margin-bottom:0.75rem;">{{ isEn ? 'What this page answers' : 'Ce que cette page explique' }}</h2>
    <p style="margin-bottom:1rem;color:#475569;">
      {{ isEn ? 'This page is designed for SMBs evaluating a password manager plus operational support, employee onboarding, and security guidance.' : 'Cette page s adresse aux PME qui cherchent un gestionnaire de mots de passe avec accompagnement, formation des equipes et cadre de securite.' }}
    </p>
    <ul style="margin:0 0 1rem 1.25rem;color:#334155;line-height:1.7;">
      <li>{{ isEn ? 'MYKEYNEST combines password management, maintenance, training, and audit support in one offer.' : 'MYKEYNEST combine gestion des mots de passe, maintenance, formation et accompagnement audit dans une seule offre.' }}</li>
      <li>{{ isEn ? 'The offer targets SMBs, agencies, and teams that need a practical cybersecurity baseline without building it in-house.' : 'L offre vise les PME, agences et equipes qui veulent un socle cyber operationnel sans recruter une equipe interne.' }}</li>
      <li>{{ isEn ? 'Use the comparison and audit pages below if you need vendor evaluation or a services-first entry point.' : 'Utilisez ensuite le comparatif et la page audit si vous avez besoin d une aide au choix ou d une entree orientee services.' }}</li>
    </ul>
    <div style="display:flex;flex-wrap:wrap;gap:0.75rem;">
      <a href="{{ path('business_comparatif') }}" class="btn btn-outline">{{ isEn ? 'See the comparison' : 'Voir le comparatif' }}</a>
      <a href="{{ path('business_audit') }}" class="btn btn-outline">{{ isEn ? 'See audit services' : 'Voir les services d audit' }}</a>
      <a href="{{ path('app_help_center') }}" class="btn btn-outline">{{ isEn ? 'Visit the help center' : 'Consulter le centre d aide' }}</a>
    </div>
  </div>
</section>

{# ======================== STATS BAND ======================== #}
<div class="stats-band" aria-hidden="true">
  <div class="stats-band-inner">
    <div class="sb-item"><i class="fas fa-certificate"></i> AES-256</div>
    <div class="sb-div"></div>
    <div class="sb-item"><i class="fas fa-fingerprint"></i> Installation Hashee</div>
    <div class="sb-div"></div>
    <div class="sb-item"><i class="fas fa-euro-sign"></i> Donnees en Europe</div>
    <div class="sb-div"></div>
    <div class="sb-item"><i class="fas fa-user-secret"></i> Zero-Knowledge</div>
    <div class="sb-div"></div>
    <div class="sb-item"><i class="fas fa-check-double"></i> Conformite RGPD</div>
  </div>
</div>

{# ======================== PILLARS ======================== #}
<section class="pillars-section" id="pillars">
  <div class="wrap">
    <div class="shead">
      <div class="shead-eye"><i class="fas fa-layer-group"></i> {{ 'business.solution.pillars.eyebrow'|trans }}</div>
      <h2>{{ 'business.solution.pillars.title'|trans }}</h2>
      <p>{{ 'business.solution.pillars.subtitle'|trans }}</p>
    </div>

    <div class="pillars-grid">
      {# Logiciel ? featured dark #}
      <div class="pillar featured">
        <div class="pillar-icon" aria-hidden="true"><i class="fas fa-lock" style="color:#34d399"></i></div>
        <div class="pillar-title">{{ 'business.solution.pillars.software.title'|trans }}</div>
        <ul class="pillar-list">
          <li><i class="fas fa-chevron-right"></i>{{ 'business.solution.pillars.software.item1'|trans }}</li>
          <li><i class="fas fa-chevron-right"></i>{{ 'business.solution.pillars.software.item2'|trans }}</li>
          <li><i class="fas fa-chevron-right"></i>{{ 'business.solution.pillars.software.item3'|trans }}</li>
          <li><i class="fas fa-chevron-right"></i>{{ 'business.solution.pillars.software.item4'|trans }}</li>
        </ul>
      </div>

      {# Maintenance #}
      <div class="pillar">
        <div class="pillar-icon" aria-hidden="true"><i class="fas fa-screwdriver-wrench" style="color:var(--color-primary)"></i></div>
        <div class="pillar-title">{{ 'business.solution.pillars.maintenance.title'|trans }}</div>
        <ul class="pillar-list">
          <li><i class="fas fa-chevron-right"></i>{{ 'business.solution.pillars.maintenance.item1'|trans }}</li>
          <li><i class="fas fa-chevron-right"></i>{{ 'business.solution.pillars.maintenance.item2'|trans }}</li>
          <li><i class="fas fa-chevron-right"></i>{{ 'business.solution.pillars.maintenance.item3'|trans }}</li>
        </ul>
      </div>

      {# Formation #}
      <div class="pillar">
        <div class="pillar-icon" aria-hidden="true"><i class="fas fa-chalkboard-user" style="color:var(--color-primary)"></i></div>
        <div class="pillar-title">{{ 'business.solution.pillars.training.title'|trans }}</div>
        <ul class="pillar-list">
          <li><i class="fas fa-chevron-right"></i>{{ 'business.solution.pillars.training.item1'|trans }}</li>
          <li><i class="fas fa-chevron-right"></i>{{ 'business.solution.pillars.training.item2'|trans }}</li>
          <li><i class="fas fa-chevron-right"></i>{{ 'business.solution.pillars.training.item3'|trans }}</li>
        </ul>
      </div>

      {# Audit #}
      <div class="pillar">
        <div class="pillar-icon" aria-hidden="true"><i class="fas fa-flask" style="color:var(--color-primary)"></i></div>
        <div class="pillar-title">{{ 'business.solution.pillars.audit.title'|trans }}</div>
        <ul class="pillar-list">
          <li><i class="fas fa-chevron-right"></i>{{ 'business.solution.pillars.audit.item1'|trans }}</li>
          <li><i class="fas fa-chevron-right"></i>{{ 'business.solution.pillars.audit.item2'|trans }}</li>
          <li><i class="fas fa-chevron-right"></i>{{ 'business.solution.pillars.audit.item3'|trans }}</li>
        </ul>
      </div>
    </div>
  </div>
</section>

{# ======================== SPLIT ? INSTALLATION HASHEE ======================== #}
<section class="split-section">
  <div class="split-inner">
    <div class="split-text">
      <div class="shead">
        <div class="shead-eye"><i class="fas fa-fingerprint"></i> Securite inviolable</div>
        <h2>Vous seul controlez l'acces</h2>
        <p>Chaque deploiement MykeyNest genere une empreinte cryptographique unique. L'acces est verrouille a votre instance, impossible a usurper, meme avec les bons identifiants.</p>
      </div>

      <div class="split-pts">
        <div class="split-pt">
          <div class="split-pt-ico"><i class="fas fa-fingerprint"></i></div>
          <div class="split-pt-body">
            <b>Signature Materielle</b>
            <p>Acces strictement lie a votre instance. Un attaquant sur un autre poste est bloque meme avec vos codes.</p>
          </div>
        </div>

        <div class="split-pt">
          <div class="split-pt-ico"><i class="fas fa-link-slash"></i></div>
          <div class="split-pt-body">
            <b>Preuve d'Integrite</b>
            <p>Si l'extension est modifiee ou falsifiee, le hash change instantanement et l'acces est revoque.</p>
          </div>
        </div>

        <div class="split-pt">
          <div class="split-pt-ico"><i class="fas fa-shield-halved"></i></div>
          <div class="split-pt-body">
            <b>Logs d'Audit Complets</b>
            <p>Chaque tentative d'acces est tracee avec horodatage cryptographique pour vos audits de conformite.</p>
          </div>
        </div>

        <div class="split-pt">
          <div class="split-pt-ico"><i class="fas fa-check-double"></i></div>
          <div class="split-pt-body">
            <b>Conformite RGPD native</b>
            <p>Donnees hebergees en Europe, architecture zero-knowledge. Conformite integree des la conception.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="split-visual">
      <div class="split-badge"><i class="fas fa-shield-halved"></i> Installation verifiee</div>
      <div class="split-card">
        <div class="split-card-header">
          <div class="sc-dots"><div class="sc-dot"></div><div class="sc-dot"></div><div class="sc-dot"></div></div>
          <span class="sc-title">mykeynest - audit de securite</span>
        </div>

        <div class="sc-body">
          <div class="tl"><span class="tp">$</span><span class="tc">verify_install --id 0x8f2a</span></div>
          <div class="tl"><span class="tp"> </span><span class="tv">HASH_STATUS&nbsp;&nbsp;: SIGNED <i class="fas fa-check"></i></span></div>
          <div class="tl"><span class="tp"> </span><span class="tv">OWNER_KEY&nbsp;&nbsp;&nbsp;&nbsp;: USER_STRICT</span></div>
          <div class="tl"><span class="tp"> </span><span class="tv">INTEGRITY&nbsp;&nbsp;&nbsp;&nbsp;: PASS</span></div>
          <br>
          <div class="tl"><span class="tp">$</span><span class="tc">simulate_attack</span></div>
          <div class="tl"><span class="tp"> </span><span class="te">HASH_MISMATCH - denied</span></div>
          <div class="tl"><span class="tp"> </span><span class="tw">VAULT : LOCKED</span></div>
          <br>
          <div class="tl"><span class="tp">$</span><span class="tok"><i class="fas fa-check"></i> Zero data exposed.</span></div>
        </div>

        <div class="sc-score">
          <div class="sc-score-top">
            <span class="sc-score-label">Score de securite</span>
            <span class="sc-score-val">A+</span>
          </div>
          <div class="sc-score-bar"><div class="sc-score-fill"></div></div>
        </div>
      </div>
    </div>
  </div>
</section>

{# ======================== EXPLORE ======================== #}
<section class="explore-section" id="explorer">
  <div class="wrap">
    <div class="shead">
      <div class="shead-eye"><i class="fas fa-compass"></i> {{ 'business.solution.explore.eyebrow'|trans }}</div>
      <h2>{{ 'business.solution.explore.title'|trans }}</h2>
      <p>{{ 'business.solution.explore.subtitle'|trans }}</p>
    </div>

    <div class="explore-grid">
      <a href="{{ path('business_comparatif') }}" class="explore-card">
        <div class="explore-card-top">
          <div class="explore-icon" aria-hidden="true"><i class="fas fa-scale-balanced"></i></div>
          <div>
            <span class="explore-badge">{{ 'business.solution.explore.comparatif.label'|trans }}</span>
            <div class="explore-card-title">{{ 'business.solution.explore.comparatif.title'|trans }}</div>
          </div>
        </div>
        <div class="explore-desc">{{ app.request.locale == 'en' ? 'Compare MYKEYNEST with other solutions on the criteria that matter for SMBs: security, pricing, support, and GDPR positioning.' : 'Comparez MYKEYNEST aux autres solutions sur les criteres qui comptent pour une PME : securite, prix, accompagnement et positionnement RGPD.' }}</div>
        <div class="explore-arrow"><i class="fas fa-arrow-right"></i> {{ app.request.locale == 'en' ? 'Open the comparison' : 'Voir le comparatif' }}</div>
      </a>

      <a href="{{ path('business_audit') }}" class="explore-card">
        <div class="explore-card-top">
          <div class="explore-icon" aria-hidden="true"><i class="fas fa-vial"></i></div>
          <div>
            <span class="explore-badge">{{ 'business.solution.explore.audit.label'|trans }}</span>
            <div class="explore-card-title">{{ 'business.solution.explore.audit.title'|trans }}</div>
          </div>
        </div>
        <div class="explore-desc">{{ app.request.locale == 'en' ? 'Discover the audit and awareness offer if your main need is to reduce human risk, weak password hygiene, and phishing exposure.' : 'Decouvrez l offre audit et sensibilisation si votre besoin principal est de reduire le risque humain, les mots de passe faibles et l exposition au phishing.' }}</div>
        <div class="explore-arrow"><i class="fas fa-arrow-right"></i> {{ app.request.locale == 'en' ? 'View the audit offer' : 'Lancer l audit' }}</div>
      </a>
    </div>
  </div>
</section>

{# ======================== PRICING ======================== #}
<section class="pricing-section" id="tarif">
  <div class="wrap">
    <div class="shead" style="text-align:center;max-width:600px;margin:0 auto 2.5rem">
      <div class="shead-eye" style="justify-content:center"><i class="fas fa-tag"></i> {{ 'business.solution.pricing.eyebrow'|trans }}</div>
      <h2>{{ 'business.solution.pricing.title'|trans }}</h2>
    </div>

    <div class="pricing-card">
      <div class="pricing-inner">
        <div class="pricing-left">
          <div class="pricing-amount">6,99€</div>
          <div class="pricing-unit">{{ 'business.solution.pricing.unit'|trans }}</div>
          <div class="pricing-pill"><i class="fas fa-tags"></i> {{ 'business.solution.pricing.badge'|trans }}</div>
          <p class="pricing-desc">{{ 'business.solution.pricing.description'|trans }}</p>
          <div class="pricing-cta">
            <a href="{{ path('show_register') }}" class="btn btn-green">
              <i class="fas fa-rocket"></i> {{ 'business.solution.pricing.cta'|trans }}
            </a>
            <a href="mailto:contact@key-nest.com" class="btn btn-outline">
              <i class="fas fa-envelope"></i> Contacter l'equipe
            </a>
          </div>
        </div>

        {# <div class="pricing-right">
          <ul class="pricing-features">
            <li><span class="feat-check"><i class="fas fa-check"></i></span>{{ 'business.solution.pricing.feature1'|trans }}</li>
            <li><span class="feat-check"><i class="fas fa-check"></i></span>{{ 'business.solution.pricing.feature2'|trans }}</li>
