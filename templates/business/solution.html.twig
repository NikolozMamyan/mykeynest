            <li><span class="feat-check"><i class="fas fa-check"></i></span>{{ 'business.solution.pricing.feature4'|trans }}</li>
            <li><span class="feat-check"><i class="fas fa-check"></i></span>{{ 'business.solution.pricing.feature5'|trans }}</li>
            <li><span class="feat-check"><i class="fas fa-check"></i></span>{{ 'business.solution.pricing.feature6'|trans }}</li>
          </ul> #}
        </div>
      </div>
    </div>
  </div>
</section>

{# ======================== CTA ======================== #}
<section class="cta-section">
  <div class="wrap">
    <div class="cta-box">
      <div class="cta-box-inner">
        <div class="cta-label"><i class="fas fa-shield-halved"></i> Solution PME</div>
        <h2>{{ 'business.solution.cta.title'|trans }}</h2>
        <p>{{ 'business.solution.cta.subtitle'|trans }}</p>
        <div class="cta-btns">
          <a href="{{ path('show_register') }}" class="btn btn-white btn-lg btn-w">
            <i class="fas fa-rocket"></i> {{ 'business.solution.cta.primary'|trans }}
          </a>
          <a href="mailto:contact@key-nest.com" class="btn btn-ghost btn-lg btn-w">
            <i class="fas fa-envelope"></i> {{ 'business.solution.cta.secondary'|trans }}
          </a>
        </div>
        <p class="cta-note"><i class="fas fa-circle-check"></i> Essai gratuit 14 jours - Sans carte bancaire - RGPD compliant</p>
      </div>
    </div>
  </div>
</section>

</main>
{% endblock %}
