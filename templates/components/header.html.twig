{% set headerTranslations = {
  notifications: {
    loading_list: 'header.notifications.loading_list'|trans|default('Chargement des notifications...'),
    load_error: 'header.notifications.load_error'|trans|default('Erreur de chargement'),
    empty: 'header.notifications.empty'|trans|default('Aucune notification pour le moment'),
    marking: 'header.notifications.marking'|trans|default('Marquage...'),
    marked: 'header.notifications.marked'|trans|default('Marque !'),
    error: 'header.notifications.error'|trans|default('Erreur'),
    delete: 'header.notifications.delete'|trans|default('Supprimer'),
    deleting: 'header.notifications.deleting'|trans|default('Suppression...'),
    deleted: 'header.notifications.deleted'|trans|default('Supprimee'),
    delete_error: 'header.notifications.delete_error'|trans|default('Suppression impossible')
  },
  priority: {
    high: 'priority.high'|trans|default('High'),
    medium: 'priority.medium'|trans|default('Medium'),
    low: 'priority.low'|trans|default('Low')
  },
  security_checker: {
    notifications: {
      weak: {
        title: 'security_checker.notifications.weak.title'|trans,
        message: 'security_checker.notifications.weak.message'|trans
      }
    }
  }
} %}

<header class="header_top"
        data-controller="header"
        data-header-translations-value="{{ headerTranslations|json_encode|e('html_attr') }}">
  <button class="burger-btn"
          aria-label="{{ 'header.burger_aria'|trans }}"
          data-action="click->layout#toggleSidebar">
    <i class="fas fa-bars"></i>
  </button>

  <div class="header-logo">
    <div class="logo-container">
      {% include 'components/parts/logo.html.twig' %}
    </div>
  </div>

  <div class="header_right">
    {% if not app.user.hasActiveSubscription %}
      <a href="{{ path('app_subscription') }}" class="header-upgrade-badge">
        <div class="upgrade-badge-icon">
          <i class="fas fa-crown"></i>
        </div>
        <div class="upgrade-badge-content">
          <span class="upgrade-badge-label">{{ 'header.upgrade.label'|trans|default('Upgrade') }}</span>
          <span class="upgrade-badge-text">{{ 'header.upgrade.text'|trans|default('Passez à PRO') }}</span>
        </div>
        <i class="fas fa-arrow-right upgrade-badge-arrow"></i>
      </a>
    {% endif %}

    {% include 'components/parts/theme_mode_btn.html.twig' %}

    <div class="notification-wrapper">
      <button class="notification-btn"
              type="button"
              aria-label="{{ 'header.notifications.aria'|trans }}"
              data-header-target="notificationButton"
              data-action="click->header#toggleNotifications">
        <i class="fas fa-bell"></i>
        <span class="notification-badge" data-header-target="notificationBadge"></span>
      </button>

      <div class="notification-panel" data-header-target="notificationPanel">
        <div class="notification-panel-header">
          <div class="notification-panel-title">
            <i class="fas fa-bell"></i>
            {{ 'header.notifications.title'|trans }}
            <span class="notification-count-badge" data-header-target="notificationCount">0</span>
          </div>

          <button class="mark-all-read"
                  type="button"
                  data-header-target="markAllReadButton"
                  data-action="click->header#markAllRead">
            <i class="fas fa-check-double"></i>
            {{ 'header.notifications.mark_all_read'|trans }}
          </button>
        </div>

        <div class="notification-list" data-header-target="notificationList">
          <div class="notification-empty">
            <div class="notification-empty-icon">
              <i class="fas fa-bell-slash"></i>
            </div>
            <div class="notification-empty-text">
              {{ 'header.notifications.loading'|trans }}
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="user-profile-wrapper">
      <button type="button"
              class="user-profile"
              data-header-target="profileButton"
              data-action="click->header#toggleProfile">
        <div class="avatar-wrapper">
          <img class="avatar-img"
               src="{{ app.user.avatar ? asset('uploads/avatars/' ~ app.user.avatar) : asset('images/avatar-default.png') }}"
               alt="{{ 'header.profile.avatar_alt'|trans }}">
        </div>
        {% set fullName = (app.user.prenom|default('') ~ ' ' ~ app.user.nom|default(''))|trim %}
        <span class="company-name">{{ fullName ?: app.user.company }}</span>
      </button>

      <div class="user-dropdown" data-header-target="profileDropdown">
        <div class="user-dropdown-header">
          <div class="user-dropdown-info">
            <img class="avatar-img user-dropdown-avatar"
                 src="{{ app.user.avatar ? asset('uploads/avatars/' ~ app.user.avatar) : asset('images/avatar-default.png') }}"
                 alt="{{ 'header.profile.avatar_alt'|trans }}" />
            <div class="user-dropdown-details">
              <div class="user-dropdown-company">{{ app.user.nom ?? '' }} {{ app.user.prenom ?? '' }}</div>
              <div class="user-dropdown-name">{{ app.user.company }}</div>
            </div>
          </div>
        </div>

        <div class="user-dropdown-content">
          <div class="user-dropdown-section">
            <div class="user-dropdown-section-title">
              <i class="fas fa-globe"></i> {{ 'header.profile.language'|trans }}
            </div>

            <div class="user-dropdown-lang">
              {% set currentLocale = app.request.locale|default('fr') %}
              <div class="lang-switch"
                   role="group"
                   aria-label="{{ 'header.profile.language_aria'|trans }}"
                   data-controller="locale-switcher">
                <button
                  type="button"
                  class="lang-switch__btn {{ currentLocale == 'fr' ? 'is-active' : '' }}"
                  data-lang="fr"
                  data-action="click->locale-switcher#switch"
                  aria-pressed="{{ currentLocale == 'fr' ? 'true' : 'false' }}"
                  title="{{ 'header.profile.language_fr'|trans }}"
                >
                  <img
                    src="{{ asset('images/flags/fr.svg') }}"
                    alt="{{ 'header.profile.language_fr'|trans }}"
                    class="lang-switch__flag"
                    loading="lazy"
                    width="22"
                    height="16"
                  >
                </button>

                <button
                  type="button"
                  class="lang-switch__btn {{ currentLocale == 'en' ? 'is-active' : '' }}"
                  data-lang="en"
                  data-action="click->locale-switcher#switch"
                  aria-pressed="{{ currentLocale == 'en' ? 'true' : 'false' }}"
                  title="{{ 'header.profile.language_en'|trans }}"
                >
                  <img
                    src="{{ asset('images/flags/gb.svg') }}"
                    alt="{{ 'header.profile.language_en'|trans }}"
                    class="lang-switch__flag"
                    loading="lazy"
                    width="22"
                    height="16"
                  >
                </button>
              </div>
            </div>
          </div>

          <div class="user-dropdown-divider"></div>

          <div class="user-dropdown-section">
            <a href="{{ path('app_install_app') }}" class="user-dropdown-item user-dropdown-item--install-app">
              <div class="user-dropdown-item-icon">
                <i class="fas fa-mobile-alt"></i>
              </div>
              <div class="user-dropdown-item-text">
                <div class="user-dropdown-item-label">{{ 'header.profile.install_hybrid_app.label'|trans }}</div>
                <div class="user-dropdown-item-desc">{{ 'header.profile.install_hybrid_app.desc'|trans }}</div>
              </div>
            </a>

            <a href="{{ path('app_settings') }}" class="user-dropdown-item">
              <div class="user-dropdown-item-icon">
                <i class="fas fa-cog"></i>
              </div>
              <div class="user-dropdown-item-text">
                <div class="user-dropdown-item-label">{{ 'header.profile.settings.label'|trans }}</div>
                <div class="user-dropdown-item-desc">{{ 'header.profile.settings.desc'|trans }}</div>
              </div>
            </a>

            <a href="" class="user-dropdown-item" data-controller="auth" data-action="click->auth#logout">
              <div class="user-dropdown-item-icon">
                <i class="fas fa-sign-out-alt"></i>
              </div>
              <div class="user-dropdown-item-text">
                <div class="user-dropdown-item-label">{{ 'header.profile.logout.label'|trans }}</div>
                <div class="user-dropdown-item-desc">{{ 'header.profile.logout.desc'|trans }}</div>
              </div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>
