<nav class="landing-nav"
     role="navigation"
     aria-label="{{ 'landing.nav.aria'|trans }}"
     data-controller="nav">
  <div class="nav-container">
    {% include 'components/parts/logo.html.twig' %}

    <button class="btn nav-toggle"
            type="button"
            aria-controls="primary-nav"
            aria-expanded="false"
            data-nav-target="toggle"
            data-action="click->nav#toggleMenu">
      <i class="fas fa-bars" aria-hidden="true"></i>
    </button>

    <div class="nav-links"
         id="primary-nav"
         data-nav-target="menu"
         data-action="click->nav#closeOnLink">
      <div class="nav-lang nav-lang-mobile" role="group" aria-label="{{ 'landing.nav.language'|trans }}">
        {% set route = app.request.attributes.get('_route') %}

        {% if route starts with 'blog_' %}
          {% include 'components/parts/blog_lang_switcher.html.twig' %}
        {% else %}
          {% include 'components/parts/lang_switcher.html.twig' %}
        {% endif %}
      </div>

      <a href="/#features" class="nav-link" data-action="click->nav#smoothScroll">{{ 'landing.nav.features'|trans }}</a>
      {# <a href="{{path('app_help_center')}}" class="nav-link">{{ 'landing.nav.how_it_works'|trans }}</a> #}
      <a href="/#pricing" class="nav-link" data-action="click->nav#smoothScroll">{{ 'landing.nav.pricing'|trans }}</a>
      <a href="{{ path('app_install_app') }}" class="nav-link nav-link-mobile-only">{{ 'landing.nav.install_hybrid_app'|trans }}</a>

      <a href="{{ path('blog_index', { _locale: app.request.locale }) }}"
         lang="{{ app.request.locale }}"
         class="nav-link">
        {{ 'landing.footer.links.blog'|trans }}
      </a>

      <div class="nav-cta nav-cta-mobile">
        <a href="{{ path('show_login') }}" class="btn btn-outline">{{ 'landing.nav.login'|trans }}</a>
        <a href="{{ path('show_register') }}" class="btn btn-primary">{{ 'landing.nav.free_trial'|trans }}</a>
      </div>
    </div>

    <div class="nav-cta">
      <a href="{{ path('app_install_app') }}" class="btn btn-outline">{{ 'landing.nav.install_hybrid_app'|trans }}</a>
      <a href="{{ path('show_login') }}" class="btn btn-outline">{{ 'landing.nav.login'|trans }}</a>
      <a href="{{ path('show_register') }}" class="btn btn-primary">{{ 'landing.nav.free_trial'|trans }}</a>

      <div class="nav-lang" role="group" aria-label="{{ 'landing.nav.language'|trans }}">
        {% set route = app.request.attributes.get('_route') %}

        {% if route starts with 'blog_' %}
          {% include 'components/parts/blog_lang_switcher.html.twig' %}
        {% else %}
          {% include 'components/parts/lang_switcher.html.twig' %}
        {% endif %}
      </div>
    </div>
  </div>
</nav>

<div class="nav-overlay"
     aria-hidden="true"
     data-nav-target="overlay"
     data-action="click->nav#closeMenu"></div>
