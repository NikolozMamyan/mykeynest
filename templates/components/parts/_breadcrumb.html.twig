<nav class="breadcrumb-nav" aria-label="{{ 'breadcrumb.aria'|default('Breadcrumb')|trans }}">
  <ol class="breadcrumb-list">
    {% for item in items %}
      {% set isActive = item.active is defined and item.active %}

      <li class="breadcrumb-item {% if isActive %}active{% endif %}">
        {% if item.url is defined and not isActive %}
          <a href="{{ item.url }}">
            {% if item.icon is defined %}
              <i class="{{ item.icon }}"></i>
            {% endif %}
            <span>{{ item.label|trans }}</span>
          </a>
        {% else %}
          {% if item.icon is defined %}
            <i class="{{ item.icon }}"></i>
          {% endif %}
          <span>{{ item.label|trans }}</span>
        {% endif %}
      </li>

      {% if not loop.last %}
        <li class="breadcrumb-separator" aria-hidden="true">
          <i class="fas fa-chevron-right"></i>
        </li>
      {% endif %}
    {% endfor %}
  </ol>
</nav>
