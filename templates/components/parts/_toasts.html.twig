<div class="toasts"
     aria-live="polite"
     aria-atomic="true"
     data-controller="toasts">
  {% for message in app.flashes('success') %}
    <div class="toast toast--success"
         role="status"
         data-duration="4200"
         data-action="mouseenter->toasts#pause mouseleave->toasts#resume">
      <div class="toast__icon" aria-hidden="true">
        <i class="fa-solid fa-circle-check"></i>
      </div>
      <div class="toast__content">{{ message }}</div>
      <button class="toast__close" type="button" aria-label="Fermer" data-action="click->toasts#close">
        <i class="fa-solid fa-xmark"></i>
      </button>
      <div class="toast__bar" aria-hidden="true"></div>
    </div>
  {% endfor %}

  {% for message in app.flashes('error') %}
    <div class="toast toast--error"
         role="alert"
         data-duration="6000"
         data-action="mouseenter->toasts#pause mouseleave->toasts#resume">
      <div class="toast__icon" aria-hidden="true">
        <i class="fa-solid fa-triangle-exclamation"></i>
      </div>
      <div class="toast__content">{{ message }}</div>
      <button class="toast__close" type="button" aria-label="Fermer" data-action="click->toasts#close">
        <i class="fa-solid fa-xmark"></i>
      </button>
      <div class="toast__bar" aria-hidden="true"></div>
    </div>
  {% endfor %}
</div>
