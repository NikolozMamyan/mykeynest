{% set sectionTitle = sectionTitle|default(app.request.locale == 'en' ? 'Continue exploring MYKEYNEST' : 'Continuer sur MYKEYNEST') %}
{% set sectionSubtitle = sectionSubtitle|default(app.request.locale == 'en' ? 'Move from discovery to action with the pages that clarify positioning, comparison, support, and implementation.' : 'Passez de la decouverte a l action avec les pages qui clarifient le positionnement, la comparaison, le support et la mise en place.') %}
{% set links = links|default([]) %}
{% set compact = compact|default(false) %}

<section class="seo-links-band" aria-labelledby="seo-links-title">
  <style>
    .seo-links-band {
      width: min(1120px, calc(100% - 2rem));
      margin: 2rem auto 0;
      padding: 1.6rem;
      border-radius: 28px;
      border: 1px solid #dbeafe;
      background:
        radial-gradient(circle at top left, rgba(37, 99, 235, .08), transparent 32%),
        radial-gradient(circle at bottom right, rgba(5, 150, 105, .10), transparent 35%),
        linear-gradient(180deg, #ffffff, #f8fafc);
      box-shadow: 0 24px 60px rgba(148, 163, 184, .12);
    }

    .seo-links-band__eyebrow {
      display: inline-flex;
      align-items: center;
      gap: .55rem;
      padding: .45rem .8rem;
      border-radius: 999px;
      background: rgba(5, 150, 105, .10);
      color: #047857;
      font-size: .8rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: .08em;
    }

    .seo-links-band__head {
      max-width: 760px;
      margin: 1rem 0 1.2rem;
    }

    .seo-links-band__head h2 {
      margin: 0 0 .65rem;
      font-size: clamp(1.5rem, 2.8vw, 2.25rem);
      line-height: 1.08;
      color: #0f172a;
    }

    .seo-links-band__head p {
      margin: 0;
      color: #475569;
      line-height: 1.75;
    }

    .seo-links-band__grid {
      display: grid;
      grid-template-columns: repeat({{ links|length >= 4 ? 4 : (links|length >= 3 ? 3 : (links|length >= 2 ? 2 : 1)) }}, minmax(0, 1fr));
      gap: 1rem;
    }

    .seo-links-band__card {
      display: flex;
      flex-direction: column;
      height: 100%;
      border-radius: 22px;
      background: #fff;
      border: 1px solid #e2e8f0;
      color: inherit;
      text-decoration: none;
      transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
    }

    .seo-links-band__card:hover {
      transform: translateY(-2px);
      border-color: #bfdbfe;
      box-shadow: 0 18px 40px rgba(148, 163, 184, .16);
    }

    .seo-links-band__visual {
      position: relative;
      aspect-ratio: {{ compact ? '16 / 9' : '4 / 3' }};
      overflow: hidden;
      background:
        radial-gradient(circle at top left, rgba(37, 99, 235, .28), transparent 34%),
        radial-gradient(circle at bottom right, rgba(5, 150, 105, .26), transparent 38%),
        linear-gradient(135deg, #0f172a, #1e3a8a 58%, #059669);
    }

    .seo-links-band__visual img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .seo-links-band__visual-overlay {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      padding: 1rem;
      background: linear-gradient(180deg, rgba(15, 23, 42, .06), rgba(15, 23, 42, .55));
      color: #fff;
    }

    .seo-links-band__visual-icon {
      width: 2.8rem;
      height: 2.8rem;
      border-radius: 16px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: rgba(255, 255, 255, .14);
      border: 1px solid rgba(255, 255, 255, .18);
      backdrop-filter: blur(8px);
      font-size: 1rem;
    }

    .seo-links-band__visual-kicker {
      max-width: 70%;
      font-size: .78rem;
      font-weight: 800;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, .88);
    }

    .seo-links-band__content {
      padding: {{ compact ? '1rem' : '1.15rem' }};
    }

    .seo-links-band__label {
      display: inline-flex;
      align-items: center;
      gap: .5rem;
      margin-bottom: .65rem;
      color: #2563eb;
      font-size: .8rem;
      font-weight: 800;
      letter-spacing: .02em;
    }

    .seo-links-band__card strong {
      display: block;
      margin-bottom: .55rem;
      color: #0f172a;
      font-size: 1rem;
      line-height: 1.35;
    }

    .seo-links-band__card p {
      margin: 0;
      color: #475569;
      line-height: 1.6;
      font-size: {{ compact ? '.9rem' : '.95rem' }};
    }

    @media (max-width: 960px) {
      .seo-links-band__grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <div class="seo-links-band__eyebrow">
    <i class="fa-solid fa-compass" aria-hidden="true"></i>
    {{ app.request.locale == 'en' ? 'Internal paths' : 'Parcours internes' }}
  </div>

  <div class="seo-links-band__head">
    <h2 id="seo-links-title">{{ sectionTitle }}</h2>
    <p>{{ sectionSubtitle }}</p>
  </div>

  <div class="seo-links-band__grid">
    {% for link in links %}
      <a href="{{ path(link.route, link.params|default({})) }}" class="seo-links-band__card">
        <div class="seo-links-band__visual">
          {% if link.image is defined and link.image is not empty %}
            <img src="{{ asset(link.image) }}" alt="{{ link.imageAlt|default(link.title) }}" loading="lazy">
          {% endif %}
          <div class="seo-links-band__visual-overlay">
            <span class="seo-links-band__visual-kicker">{{ link.kicker|default(link.label) }}</span>
            <span class="seo-links-band__visual-icon">
              <i class="{{ link.icon|default('fa-solid fa-arrow-right') }}" aria-hidden="true"></i>
            </span>
          </div>
        </div>
        <div class="seo-links-band__content">
          <span class="seo-links-band__label">
            <i class="{{ link.icon|default('fa-solid fa-arrow-right') }}" aria-hidden="true"></i>
            {{ link.label }}
          </span>
          <strong>{{ link.title }}</strong>
          <p>{{ link.text }}</p>
        </div>
      </a>
    {% endfor %}
  </div>
</section>
