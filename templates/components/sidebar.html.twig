<!-- === SIDEBAR === -->
<aside class="sidebar" data-layout-target="sidebar">
  <div class="sidebar-header">
    <div class="logo-container">
      {% include 'components/parts/logo.html.twig' %}
    </div>
  </div>

  <nav class="sidebar-nav">
    <div class="nav-section">
      <div class="nav-section-title">
        {{ 'sidebar.sections.main'|trans }}
      </div>

      <a href="{{ path('app_dashboard') }}"
         class="nav-item {{ app.request.attributes.get('_route') == 'app_dashboard' ? 'active' : '' }}">
        <i class="fas fa-house"></i>
        <span>{{ 'sidebar.items.dashboard'|trans }}</span>
      </a>

      <a href="{{ path('app_team_index') }}"
         class="nav-item {{ app.request.attributes.get('_route') == 'app_team_index' ? 'active' : '' }}">
        <i class="fas fa-users"></i>
        <span>{{ 'sidebar.items.teams'|trans }}</span>
      </a>

      <a href="{{ path('app_credential') }}"
         class="nav-item {{ app.request.attributes.get('_route') == 'app_credential' ? 'active' : '' }}">
        <i class="fas fa-key"></i>
        <span>{{ 'sidebar.items.credentials'|trans }}</span>
        <span class="nav-item-badge" data-layout-target="passLength"></span>
      </a>

      <a href="{{ path('app_sessions_manager') }}"
         class="nav-item {{ app.request.attributes.get('_route') == 'app_sessions_manager' ? 'active' : '' }}">
        <i class="fas fa-display"></i>
        <span>Sessions Manager</span>
      </a>

      <a href="{{ path('shared_access_index') }}"
         class="nav-item {{ app.request.attributes.get('_route') == 'shared_access_index' ? 'active' : '' }}">
        <i class="fas fa-share-alt"></i>
        <span>{{ 'sidebar.items.shared_access'|trans }}</span>
      </a>

      <a href="{{ path('app_extention') }}"
         class="nav-item {{ app.request.attributes.get('_route') == 'app_extention' ? 'active' : '' }}">
        <i class="fas fa-plug"></i>
        <span>{{ 'sidebar.items.extension'|trans }}</span>
      </a>
    </div>

    <div class="nav-divider"></div>

    <div class="nav-section">
      <div class="nav-section-title">
        {{ 'sidebar.sections.tools'|trans }}
      </div>

      <a href="{{ path('app_generator') }}"
         class="nav-item {{ app.request.attributes.get('_route') == 'app_generator' ? 'active' : '' }}">
        <i class="fas fa-wand-magic-sparkles"></i>
        <span>{{ 'sidebar.items.generator'|trans }}</span>
      </a>

      {% if app.user.hasActiveSubscription %}
        <a href="{{ path('app_note') }}"
           class="nav-item {{ app.request.attributes.get('_route') == 'app_note' ? 'active' : '' }}">
          <i class="fas fa-note-sticky"></i>
          <span>{{ 'sidebar.items.notes'|trans }}</span>
        </a>
      {% else %}
        <div class="nav-item nav-item-disabled">
          <i class="fas fa-note-sticky"></i>
          <span>{{ 'sidebar.items.notes'|trans }}</span>
          <span class="nav-item-badge-pro">PRO</span>
        </div>
      {% endif %}

      {% if app.user.hasActiveSubscription %}
        <a href="{{ path('app_security_checker') }}"
           class="nav-item {{ app.request.attributes.get('_route') == 'app_security_checker' ? 'active' : '' }}">
          <i class="fas fa-shield-heart"></i>
          <span>{{ 'sidebar.items.security_checker'|trans }}</span>
        </a>
      {% else %}
        <div class="nav-item nav-item-disabled">
          <i class="fas fa-shield-heart"></i>
          <span>{{ 'sidebar.items.security_checker'|trans }}</span>
          <span class="nav-item-badge-pro">PRO</span>
        </div>
      {% endif %}
    </div>

    <div class="nav-section">
      <div class="nav-section-title">
        {{ 'sidebar.sections.settings'|trans }}
      </div>

      <a href="{{ path('app_subscription') }}"
         class="nav-item {{ app.request.attributes.get('_route') == 'app_subscription' ? 'active' : '' }}">
        <i class="fas fa-receipt"></i>
        <span>{{ 'sidebar.items.subscription'|trans }}</span>
      </a>

      <a href="{{ path('app_settings') }}"
         class="nav-item {{ app.request.attributes.get('_route') == 'app_settings' ? 'active' : '' }}">
        <i class="fas fa-gear"></i>
        <span>{{ 'sidebar.items.settings'|trans }}</span>
      </a>
    </div>
  </nav>

  <div class="sidebar-footer">
    <a href="#"
       class="logout-btn"
       data-controller="auth"
       data-action="click->auth#logout">
      <i class="fas fa-sign-out-alt"></i>
      <span>{{ 'sidebar.items.logout'|trans }}</span>
    </a>
  </div>
</aside>
