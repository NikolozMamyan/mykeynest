<!-- === SIDEBAR === -->
<aside class="sidebar" data-layout-target="sidebar">
  <div class="sidebar-header">
    <div class="logo-container">
      {% include 'components/parts/logo.html.twig' %}
    </div>
  </div>

  <nav class="sidebar-nav">
    <div class="nav-section">
      <div class="nav-section-title">
        {{ 'sidebar.sections.main'|trans }}
      </div>

      <a href="{{ path('app_admin') }}"
         class="nav-item {{ app.request.attributes.get('_route') == 'app_admin' ? 'active' : '' }}">
        <i class="fas fa-house"></i>
        <span>{{ 'sidebar.items.dashboard'|trans }}</span>
      </a>
    </div>

    <div class="nav-divider"></div>

    <div class="nav-section">
      <div class="nav-section-title">
        {{ 'sidebar.sections.settings'|trans }}
      </div>
    </div>
  </nav>

  <div class="sidebar-footer">
    <a href="#"
       class="logout-btn"
       data-controller="auth"
       data-action="click->auth#logout">
      <i class="fas fa-sign-out-alt"></i>
      <span>{{ 'sidebar.items.logout'|trans }}</span>
    </a>
  </div>
</aside>
