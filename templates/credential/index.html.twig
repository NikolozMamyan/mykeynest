{# templates/credential/index.html.twig #}
{% extends 'base.html.twig' %}
{% block title %}Gestionnaire de mots de passe{% endblock %}

{% block stylesheets %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="{{ asset('styles/pages/credential-index.css') }}">
{% endblock %}
{% block page_styles %}
<style>
  .quick-share-modal {
    position: fixed;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 1.25rem;
    z-index: 1200;
  }

  .quick-share-modal.is-open {
    display: flex;
  }

  .quick-share-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.55);
    backdrop-filter: blur(6px);
  }

  .quick-share-dialog {
    position: relative;
    width: min(100%, 460px);
    border-radius: 22px;
    background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(248,250,252,0.98));
    border: 1px solid rgba(148, 163, 184, 0.2);
    box-shadow: 0 30px 80px rgba(15, 23, 42, 0.28);
    overflow: hidden;
  }

  .quick-share-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.35rem 1.4rem 1rem;
    background:
      radial-gradient(circle at top right, rgba(59,130,246,.14), transparent 40%),
      radial-gradient(circle at top left, rgba(16,185,129,.16), transparent 35%);
  }

  .quick-share-title {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-text-dark);
  }

  .quick-share-subtitle {
    margin: 0.35rem 0 0;
    color: var(--color-text-muted);
    font-size: 0.93rem;
    line-height: 1.45;
  }

  .quick-share-close {
    width: 2.2rem;
    height: 2.2rem;
    border: 0;
    border-radius: 999px;
    background: rgba(255,255,255,0.8);
    color: var(--color-text-muted);
    cursor: pointer;
  }

  .quick-share-close:hover {
    color: var(--color-text-dark);
    background: rgba(255,255,255,1);
  }

  .quick-share-body {
    padding: 0 1.4rem 1.4rem;
  }

  .quick-share-credential {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.9rem 1rem;
    margin-bottom: 1rem;
    border-radius: 16px;
    background: rgba(241, 245, 249, 0.95);
    border: 1px solid rgba(226, 232, 240, 0.95);
  }

  .quick-share-badge {
    width: 2.7rem;
    height: 2.7rem;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #059669, #2563eb);
    color: #fff;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .quick-share-credential strong,
  .quick-share-credential span {
    display: block;
  }

  .quick-share-credential span {
    color: var(--color-text-muted);
    font-size: 0.86rem;
    margin-top: 0.18rem;
  }

  .quick-share-label {
    display: block;
    margin-bottom: 0.45rem;
    color: var(--color-text-dark);
    font-size: 0.84rem;
    font-weight: 600;
  }

  .quick-share-input {
    width: 100%;
    padding: 0.85rem 0.95rem;
    border-radius: 14px;
    border: 1px solid rgba(148, 163, 184, 0.35);
    background: #fff;
    color: var(--color-text-dark);
    font: inherit;
  }

  .quick-share-input:focus {
    outline: 0;
    border-color: rgba(37, 99, 235, 0.5);
    box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.12);
  }

  .quick-share-hint {
    margin: 0.45rem 0 0;
    color: var(--color-text-muted);
    font-size: 0.82rem;
  }

  .quick-share-actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
    margin-top: 1.2rem;
  }

  .quick-share-btn {
    border: 0;
    border-radius: 14px;
    padding: 0.82rem 1rem;
    font: inherit;
    cursor: pointer;
  }

  .quick-share-btn-secondary {
    background: rgba(226, 232, 240, 0.8);
    color: var(--color-text-dark);
  }

  .quick-share-btn-primary {
    background: linear-gradient(135deg, #059669, #2563eb);
    color: #fff;
    font-weight: 600;
    box-shadow: 0 16px 28px rgba(37, 99, 235, 0.18);
  }

  body.quick-share-open {
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .quick-share-dialog {
      width: 100%;
    }

    .quick-share-actions {
      flex-direction: column-reverse;
    }
  }
</style>
{% endblock %}
{% block body %}

<div class="pm-wrap" data-controller="credential-index">

  {# ?? HEADER ?? #}
  <div class="pm-header">
    <div class="pm-header-left">
      <h1><i class="fas fa-shield-alt"></i> {{ 'credential.index.header.title'|trans }}</h1>
      <p>{{ 'credential.index.header.subtitle'|trans }}</p>
    </div>
  </div>

  {# ?? STATS PILLS ?? #}
  {% set totalMine   = credentials|length %}
  {% set totalShared = sharedAccesses|length %}
  {% set totalTeamShared = teamSharedCredentials|default([])|length %}
  <div class="pm-stats">
    <div class="stat-pill"><span class="dot dot-green"></span> <strong>{{ totalMine }}</strong>&nbsp;identifiant{{ totalMine > 1 ? 's' : '' }}</div>
    <div class="stat-pill"><span class="dot dot-blue"></span>  <strong>{{ totalShared }}</strong>&nbsp;partag&eacute;{{ totalShared > 1 ? 's' : '' }} avec moi</div>
    <div class="stat-pill"><span class="dot dot-blue"></span> <strong>{{ totalTeamShared }}</strong>&nbsp;via mes &eacute;quipes</div>
    {% if not app.user.hasActiveSubscription %}
      <div class="stat-pill"><span class="dot dot-amber"></span> {{ totalMine }}/5 - Plan gratuit</div>
    {% else %}
      <div class="stat-pill"><span class="dot dot-green"></span> Plan PRO</div>
    {% endif %}
  </div>

  {# ?? PRO BANNER ?? #}
  {% if not app.user.hasActiveSubscription and totalMine >= 5 %}
    <div class="pro-banner">
      <div class="pro-banner-left">
        <div class="pro-icon"><i class="fas fa-crown"></i></div>
        <div>
          <h3>{{ 'credential.pro_banner.title'|trans|default('Limite atteinte !') }}</h3>
          <p>{{ 'credential.pro_banner.description'|trans|default('Passez &agrave; PRO pour des identifiants illimit&eacute;s.')|raw }}</p>
        </div>
      </div>
      <a href="{{ path('app_subscription') }}" class="btn-upgrade">
        <i class="fas fa-star"></i> Passer &agrave; PRO
      </a>
    </div>
  {% endif %}

  {# ?? TOOLBAR ?? #}
  <div class="pm-toolbar">
    <div class="pm-search">
      <i class="fas fa-search"></i>
      <input type="text" id="searchInput" placeholder="{{ 'credential.index.search.placeholder'|trans }}" autocomplete="off" data-action="input->credential-index#search">
    </div>
    <div class="pm-actions">
      {% if app.user.hasActiveSubscription or totalMine < 5 %}
        <a href="{{ path('credential_new') }}" class="btn-primary">
          <i class="fas fa-plus"></i> Ajouter
        </a>
        <a href="{{ path('credential_import') }}" class="btn-primary btn-import">
          <i class="fas fa-file-import"></i> Import CSV
        </a>
      {% else %}
        <div class="btn-primary disabled" title="Passez a PRO">
          <i class="fas fa-lock"></i> Ajouter
        </div>
        <div class="btn-primary disabled" title="Passez a PRO">
          <i class="fas fa-lock"></i> Import CSV
        </div>
      {% endif %}
    </div>
  </div>

  {# ?? FILTERS ?? #}
  <div class="pm-filters">
    <button class="filter-tab active" data-filter="all" data-action="click->credential-index#setFilter">
      <i class="fas fa-th-large"></i> <span class="mob_off">Tous</span>
      <span class="tab-count">{{ totalMine + totalShared + totalTeamShared }}</span>
    </button>
    <button class="filter-tab" data-filter="mine" data-action="click->credential-index#setFilter">
      <i class="fas fa-user"></i> <span class="mob_off">Mes identifiants</span>
      <span class="tab-count">{{ totalMine }}</span>
    </button>
    <button class="filter-tab" data-filter="shared" data-action="click->credential-index#setFilter">
      <i class="fas fa-share-alt"></i><span class="mob_off">Partag&eacute;s avec moi</span>
      <span class="tab-count">{{ totalShared }}</span>
    </button>
    <button class="filter-tab" data-filter="team" data-action="click->credential-index#setFilter">
      <i class="fas fa-users"></i><span class="mob_off">Teams</span>
      <span class="tab-count">{{ totalTeamShared }}</span>
    </button>
  </div>

  {# ?? CONTENT ?? #}
  {% if totalMine == 0 and totalShared == 0 and totalTeamShared == 0 %}
    <div class="pm-empty">
      <div class="empty-icon"><i class="fas fa-lock"></i></div>
      <h3>{{ 'credential.index.empty.title'|trans }}</h3>
      <p>{{ 'credential.index.empty.text'|trans }}</p>
      <a href="{{ path('credential_new') }}" class="btn-primary">
        <i class="fas fa-plus"></i> {{ 'credential.index.actions.add_first'|trans }}
      </a>
    </div>

  {% else %}

    <div id="noResults" class="no-results-msg">
      <i class="fas fa-search"></i>
      Aucun identifiant ne correspond &agrave; votre recherche.
    </div>

    {# ?? MY CREDENTIALS ?? #}
    {% if totalMine > 0 %}
      <div class="section-label" id="section-mine" data-section="mine">
        <h2>Mes identifiants</h2>
        <span class="label-badge badge-mine">{{ totalMine }}</span>
        <div class="label-line"></div>
      </div>

      <div class="pm-grid pm-grid-spaced" id="grid-mine">
        {% for credential in credentials %}
          {% set shouldLoadFavicon = credential.domain is not empty and '.' in credential.domain and ' ' not in credential.domain %}
          <div class="cred-card" data-section="mine" data-name="{{ credential.name|lower }}" data-domain="{{ credential.domain|lower }}" data-username="{{ credential.username|lower }}" style="animation-delay:{{ loop.index0 * 0.04 }}s">
            <div class="cred-card-body">

              <div class="site-row">
                <div class="site-favicon">
                  {% if shouldLoadFavicon %}
                    <img
                      data-domain="{{ credential.domain }}"
                      data-favicon-url="https://www.google.com/s2/favicons?domain={{ credential.domain|url_encode }}&sz=64"
                      alt=""
                      loading="lazy"
                      referrerpolicy="no-referrer"
                      data-action="load->credential-index#handleFaviconLoad error->credential-index#handleFaviconError"
                    >
                  {% endif %}
                  <span class="favicon-letter">{{ credential.name|first|upper }}</span>
                </div>
                <div class="site-meta">
                  <div class="site-name">{{ credential.name }}</div>
                  <div class="site-domain">{{ credential.domain }}</div>
                </div>
              </div>

              <div class="cred-fields">
                <div class="cred-field">
                  <div class="cred-field-label"><i class="fas fa-user"></i> Identifiant</div>
                  <div class="cred-field-value">{{ credential.username }}</div>
                </div>
                <div class="cred-field">
                  <div class="cred-field-label"><i class="fas fa-key"></i> Mot de passe</div>
                  <div class="cred-field-value is-password">**********</div>
                </div>
              </div>

            </div>
            <div class="cred-card-footer">
              <a href="{{ path('credential_show', {'id': credential.id}) }}" class="act-btn view" title="{{ 'credential.index.card_actions.view'|trans }}">
                <i class="fas fa-eye"></i>
              </a>
              <button
                type="button"
                class="act-btn share"
                title="{{ 'credential.index.card_actions.share'|trans }}"
                data-action="click->credential-index#openQuickShare"
                data-credential-id="{{ credential.id }}"
                data-credential-name="{{ credential.name }}"
                data-credential-domain="{{ credential.domain }}"
                data-credential-initials="{{ credential.name|slice(0, 2)|upper }}"
              >
                <i class="fas fa-share-alt"></i>
              </button>
              <a href="{{ path('credential_edit', {'id': credential.id}) }}" class="act-btn edit" title="{{ 'credential.index.card_actions.edit'|trans }}">
                <i class="fas fa-pencil-alt"></i>
              </a>
              <form method="post" action="{{ path('credential_delete', {'id': credential.id}) }}"
                    class="credential-delete-form"
                    data-action="submit->credential-index#confirmDelete"
                    data-confirm-message="{{ 'credential.index.confirm.delete'|trans }}">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ credential.id) }}">
                <button class="act-btn delete" title="{{ 'credential.index.card_actions.delete'|trans }}" type="submit">
                  <i class="fas fa-trash"></i>
                </button>
              </form>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {# ?? SHARED WITH ME ?? #}
    {% if totalShared > 0 %}
      <div class="section-label" id="section-shared" data-section="shared">
        <h2>Partag&eacute;s avec moi</h2>
        <span class="label-badge badge-shared">{{ totalShared }}</span>
        <div class="label-line"></div>
      </div>

      <div class="pm-grid" id="grid-shared">
        {% for access in sharedAccesses %}
          {% set credential = access.credential %}
          {% set owner = access.owner %}
          {% set shouldLoadFavicon = credential.domain is not empty and '.' in credential.domain and ' ' not in credential.domain %}
          <div class="cred-card is-shared" data-section="shared" data-name="{{ credential.name|lower }}" data-domain="{{ credential.domain|lower }}" data-username="{{ credential.username|lower }}" style="animation-delay:{{ loop.index0 * 0.04 }}s">

            <div class="shared-ribbon">
              <i class="fas fa-share-alt"></i> Partag&eacute;
            </div>

            <div class="cred-card-body">

              <div class="site-row">
                <div class="site-favicon">
                  {% if shouldLoadFavicon %}
                    <img
                      data-domain="{{ credential.domain }}"
                      data-favicon-url="https://www.google.com/s2/favicons?domain={{ credential.domain|url_encode }}&sz=64"
                      alt=""
                      loading="lazy"
                      referrerpolicy="no-referrer"
                      data-action="load->credential-index#handleFaviconLoad error->credential-index#handleFaviconError"
                    >
                  {% endif %}
                  <span class="favicon-letter">{{ credential.name|first|upper }}</span>
                </div>
                <div class="site-meta">
                  <div class="site-name">{{ credential.name }}</div>
                  <div class="site-domain">{{ credential.domain }}</div>
                </div>
              </div>

              {# Owner info #}
              <div class="owner-row">
                <div class="owner-avatar">{{ owner.email|first|upper }}</div>
                <i class="fas fa-user-shield"></i>
                Propri&eacute;taire&nbsp;:&nbsp;<strong>{{ owner.email }}</strong>
              </div>

              <div class="cred-fields">
                <div class="cred-field">
                  <div class="cred-field-label"><i class="fas fa-user"></i> Identifiant</div>
                  <div class="cred-field-value">{{ credential.username }}</div>
                </div>
                <div class="cred-field">
                  <div class="cred-field-label"><i class="fas fa-key"></i> Mot de passe</div>
                  <div class="cred-field-value is-password">**********</div>
                </div>
              </div>

            </div>
            <div class="cred-card-footer">
              <a href="{{ path('shared_access_view_credential', {'id': access.id}) }}" class="act-btn view" title="Voir">
                <i class="fas fa-eye"></i>
              </a>
              {# No share/edit/delete for shared credentials ? read-only access #}
              <button class="act-btn act-btn-disabled" title="Non disponible (acces partage)">
                <i class="fas fa-share-alt"></i>
              </button>
              <button class="act-btn act-btn-disabled" title="Non disponible (acces partage)">
                <i class="fas fa-pencil-alt"></i>
              </button>
              <button class="act-btn act-btn-disabled" title="Non disponible (acces partage)">
                <i class="fas fa-trash"></i>
              </button>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if totalTeamShared > 0 %}
      <div class="section-label" id="section-team" data-section="team">
        <h2>Via mes &eacute;quipes</h2>
        <span class="label-badge badge-shared">{{ totalTeamShared }}</span>
        <div class="label-line"></div>
      </div>

      <div class="pm-grid" id="grid-team">
        {% for entry in teamSharedCredentials %}
          {% set credential = entry.credential %}
          {% set owner = entry.owner %}
          {% set teamNames = entry.teams %}
          {% set shouldLoadFavicon = credential.domain is not empty and '.' in credential.domain and ' ' not in credential.domain %}
          <div class="cred-card is-shared" data-section="team" data-name="{{ credential.name|lower }}" data-domain="{{ credential.domain|lower }}" data-username="{{ credential.username|lower }}" style="animation-delay:{{ loop.index0 * 0.04 }}s">
            <div class="shared-ribbon">
              <i class="fas fa-users"></i> &Eacute;quipe
            </div>

            <div class="cred-card-body">
              <div class="site-row">
                <div class="site-favicon">
                  {% if shouldLoadFavicon %}
                    <img
                      data-domain="{{ credential.domain }}"
                      data-favicon-url="https://www.google.com/s2/favicons?domain={{ credential.domain|url_encode }}&sz=64"
                      alt=""
                      loading="lazy"
                      referrerpolicy="no-referrer"
                      data-action="load->credential-index#handleFaviconLoad error->credential-index#handleFaviconError"
                    >
                  {% endif %}
                  <span class="favicon-letter">{{ credential.name|first|upper }}</span>
                </div>
                <div class="site-meta">
                  <div class="site-name">{{ credential.name }}</div>
                  <div class="site-domain">{{ credential.domain }}</div>
                </div>
              </div>

              <div class="owner-row">
                <div class="owner-avatar">{{ owner.email|first|upper }}</div>
                <i class="fas fa-user-shield"></i>
                Propri&eacute;taire&nbsp;:&nbsp;<strong>{{ owner.email }}</strong>
              </div>

              <div class="owner-row">
                <div class="owner-avatar"><i class="fas fa-users"></i></div>
                <span>&Eacute;quipe{{ teamNames|length > 1 ? 's' : '' }}&nbsp;:&nbsp;<strong>{{ teamNames|join(', ') }}</strong></span>
              </div>

              <div class="cred-fields">
                <div class="cred-field">
                  <div class="cred-field-label"><i class="fas fa-user"></i> Identifiant</div>
                  <div class="cred-field-value">{{ credential.username }}</div>
                </div>
                <div class="cred-field">
                  <div class="cred-field-label"><i class="fas fa-key"></i> Mot de passe</div>
                  <div class="cred-field-value is-password">**********</div>
                </div>
              </div>
            </div>

            <div class="cred-card-footer">
              <a href="{{ path('credential_show', {'id': credential.id}) }}" class="act-btn view" title="Voir">
                <i class="fas fa-eye"></i>
              </a>
              <button class="act-btn act-btn-disabled" title="Non disponible (acc&egrave;s &eacute;quipe)">
                <i class="fas fa-share-alt"></i>
              </button>
              <button class="act-btn act-btn-disabled" title="Non disponible (acc&egrave;s &eacute;quipe)">
                <i class="fas fa-pencil-alt"></i>
              </button>
              <button class="act-btn act-btn-disabled" title="Non disponible (acc&egrave;s &eacute;quipe)">
                <i class="fas fa-trash"></i>
              </button>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

  {% endif %}

  <div
    class="quick-share-modal"
    data-credential-index-target="quickShareModal"
    data-action="keydown.esc@window->credential-index#closeQuickShare"
    aria-hidden="true"
  >
    <div class="quick-share-backdrop"></div>

    <div class="quick-share-dialog" role="dialog" aria-modal="true" aria-labelledby="quick-share-title">
      <div class="quick-share-head">
        <div>
          <h3 class="quick-share-title" id="quick-share-title">{{ 'credential.index.quick_share.title'|trans }}</h3>
          <p class="quick-share-subtitle">{{ 'credential.index.quick_share.subtitle'|trans }}</p>
        </div>

        <button
          type="button"
          class="quick-share-close"
          aria-label="{{ 'credential.index.quick_share.close'|trans }}"
          data-action="click->credential-index#closeQuickShare"
        >
          <i class="fas fa-times"></i>
        </button>
      </div>

      <div class="quick-share-body">
        <div class="quick-share-credential">
          <div class="quick-share-badge" data-credential-index-target="quickShareInitials">--</div>
          <div>
            <strong data-credential-index-target="quickShareName">-</strong>
            <span data-credential-index-target="quickShareDomain">-</span>
          </div>
        </div>

        <form method="post" action="{{ path('shared_access_quick') }}">
          <input type="hidden" name="credential_id" value="" data-credential-index-target="quickShareCredentialId">
          <label class="quick-share-label" for="quick-share-email">{{ 'credential.index.quick_share.email_label'|trans }}</label>
          <input
            id="quick-share-email"
            name="email"
            type="email"
            class="quick-share-input"
            placeholder="{{ 'credential.index.quick_share.email_placeholder'|trans }}"
            required
            autocomplete="email"
            data-credential-index-target="quickShareEmail"
          >
          <p class="quick-share-hint">{{ 'credential.index.quick_share.email_hint'|trans }}</p>

          <div class="quick-share-actions">
            <button type="button" class="quick-share-btn quick-share-btn-secondary" data-action="click->credential-index#closeQuickShare">
              {{ 'credential.index.quick_share.cancel'|trans }}
            </button>
            <button type="submit" class="quick-share-btn quick-share-btn-primary">
              {{ 'credential.index.quick_share.submit'|trans }}
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

{% endblock %}

