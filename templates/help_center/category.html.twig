{% extends 'base_auth.html.twig' %}

{% block title %}{{ category.title }} | Centre d'aide | MYKEYNEST{% endblock %}

{% block meta_description %}
<meta name="description" content="{{ category.description }}">
<meta property="og:title" content="{{ category.title }} | Centre d'aide MYKEYNEST">
<meta property="og:description" content="{{ category.description }}">
<meta property="og:type" content="website">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,700;1,400&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/pages/help-category.css') }}">
{% endblock %}

{% block body %}
<main>
    <nav class="cat-breadcrumb" aria-label="{{ 'help_category.breadcrumb.aria'|trans }}">
        <div class="cat-breadcrumb-inner">
            <a href="{{ path('app_help_center') }}">
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                </svg>
                {{ 'help_category.breadcrumb.help_center'|trans }}
            </a>
            <span class="cat-breadcrumb-sep">&rsaquo;</span>
            <span class="cat-breadcrumb-current">{{ category.title }}</span>
        </div>
    </nav>

    <section class="cat-hero">
        <div class="cat-hero-inner">
            <div class="cat-hero-icon-wrap" aria-hidden="true"><i class="{{ category.iconClass }}"></i></div>

            <div class="cat-hero-text">
                <div class="cat-hero-label">
                    <i class="fa-solid fa-folder-open" aria-hidden="true"></i>
                    {{ 'help_category.hero.label'|trans }}
                </div>

                <h1>{{ category.title }}</h1>
                <p class="cat-hero-desc">{{ category.description }}</p>

                <div class="cat-hero-meta">
                    <span class="cat-hero-pill">
                        <span class="dot" aria-hidden="true"></span>
                        {{ 'help_category.hero.articles_count'|trans({ count: articles|length }) }}
                    </span>
                    <span class="cat-hero-pill">
                        <i class="fa-regular fa-clock" aria-hidden="true"></i>
                        {{ 'help_category.hero.updated_regularly'|trans }}
                    </span>
                </div>
            </div>
        </div>
    </section>

    <div class="cat-layout">
        <div>
            <div class="cat-filter-bar">
                <div class="cat-filter-pills" role="group" aria-label="{{ 'help_category.filters.aria'|trans }}">
                    <button class="cat-filter-pill active" data-filter="all">{{ 'help_category.filters.all'|trans }}</button>
                    <button class="cat-filter-pill" data-filter="popular"><i class="fa-solid fa-fire" aria-hidden="true"></i> {{ 'help_category.filters.popular'|trans }}</button>
                    <button class="cat-filter-pill" data-filter="recent">{{ 'help_category.filters.recent'|trans }}</button>
                </div>

                <select class="cat-sort-select" id="catSort" aria-label="{{ 'help_category.sort.aria'|trans }}">
                    <option value="default">{{ 'help_category.sort.default'|trans }}</option>
                    <option value="az">{{ 'help_category.sort.az'|trans }}</option>
                    <option value="read">{{ 'help_category.sort.read'|trans }}</option>
                </select>
            </div>

            <div class="cat-articles" id="catArticleList">
                {% for article in articles %}
                    <a href="{{ path('app_help_article', { categorySlug: category.slug, articleSlug: article.slug }) }}"
                       class="cat-article-card"
                       data-popular="{{ article.popular ? 'true' : 'false' }}"
                       data-readtime="{{ article.readTime }}"
                       data-title="{{ article.title|lower }}">

                        <div class="cat-article-idx" aria-hidden="true">
                            {{ loop.index < 10 ? '0' ~ loop.index : loop.index }}
                        </div>

                        <div class="cat-article-body">
                            <div class="cat-article-tags">
                                {% if article.popular %}
                                    <span class="cat-tag cat-tag-popular"><i class="fa-solid fa-fire" aria-hidden="true"></i> {{ 'help_category.article.popular_tag'|trans }}</span>
                                {% endif %}
                                {% for tag in article.tags|slice(0, 2) %}
                                    <span class="cat-tag">{{ tag }}</span>
                                {% endfor %}
                            </div>

                            <h2 class="cat-article-title">{{ article.title }}</h2>
                            <p class="cat-article-excerpt">{{ article.excerpt }}</p>

                            <div class="cat-article-footer">
                                <span class="cat-article-footer-item">
                                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                    </svg>
                                    {{ 'help_category.article.read_time'|trans({ minutes: article.readTime }) }}
                                </span>

                                <span class="cat-article-footer-item">
                                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                    </svg>
                                    {{ article.updatedAt|date('d/m/Y') }}
                                </span>
                            </div>
                        </div>

                        <svg class="cat-article-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                    </a>
                {% else %}
                    <div style="text-align:center;padding:3rem;color:var(--color-text-muted);">
                        <p style="font-size:2rem;margin-bottom:0.75rem;"><i class="fa-regular fa-folder-open"></i></p>
                        <p>{{ 'help_category.empty.title'|trans }}</p>
                    </div>
                {% endfor %}
            </div>
        </div>

        <aside class="cat-sidebar" aria-label="{{ 'help_category.sidebar.aria'|trans }}">
            <div class="cat-sidebar-card">
                <div class="cat-sidebar-title">
                    <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                    {{ 'help_category.sidebar.quick_search.title'|trans }}
                </div>
                <div class="cat-sidebar-search">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M21 21l-4.35-4.35M17 11A6 6 0 115 11a6 6 0 0112 0z"/>
                    </svg>
                    <input
                        type="search"
                        id="catInlineSearch"
                        placeholder="{{ 'help_category.sidebar.quick_search.placeholder'|trans }}"
                        aria-label="{{ 'help_category.sidebar.quick_search.aria'|trans }}"
                    >
                </div>
            </div>

            <div class="cat-sidebar-card">
                <div class="cat-sidebar-title">
                    <i class="fa-solid fa-layer-group" aria-hidden="true"></i>
                    {{ 'help_category.sidebar.other_categories'|trans }}
                </div>
                <div class="cat-other-grid">
                    {% for otherCat in otherCategories %}
                        <a href="{{ path('app_help_category', { slug: otherCat.slug }) }}"
                           class="cat-sidebar-link"
                           {% if otherCat.slug == category.slug %}aria-current="page"{% endif %}>
                            <span class="cat-sidebar-link-icon" aria-hidden="true"><i class="{{ otherCat.iconClass }}"></i></span>
                            {{ otherCat.title }}
                        </a>
                    {% endfor %}
                </div>
            </div>

            <div class="cat-sidebar-card cat-sidebar-contact">
                <div class="cat-sidebar-contact-icon">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
                    </svg>
                </div>
                <h3>{{ 'help_category.sidebar.contact.title'|trans }}</h3>
                <p>{{ 'help_category.sidebar.contact.desc'|trans }}</p>
                <a href="mailto:contact@key-nest.com" class="cat-contact-btn">
                    <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8"/>
                    </svg>
                    {{ 'help_category.sidebar.contact.cta'|trans }}
                </a>
            </div>
        </aside>
    </div>
</main>

<script>
(function () {
    var cards = Array.from(document.querySelectorAll('.cat-article-card'));

    document.getElementById('catInlineSearch').addEventListener('input', function () {
        var q = this.value.toLowerCase().trim();
        cards.forEach(function (c) {
            var match = !q || c.dataset.title.includes(q) ||
                        c.querySelector('.cat-article-excerpt').textContent.toLowerCase().includes(q);
            c.style.display = match ? '' : 'none';
        });
    });

    document.querySelectorAll('.cat-filter-pill').forEach(function (btn) {
        btn.addEventListener('click', function () {
            document.querySelectorAll('.cat-filter-pill').forEach(function (b) { b.classList.remove('active'); });
            btn.classList.add('active');

            var filter = btn.dataset.filter;
            cards.forEach(function (c) {
                var show = true;
                if (filter === 'popular') show = c.dataset.popular === 'true';
                c.style.display = show ? '' : 'none';
            });
        });
    });

    var list = document.getElementById('catArticleList');
    document.getElementById('catSort').addEventListener('change', function () {
        var val = this.value;
        var sorted = cards.slice().sort(function (a, b) {
            if (val === 'az') return a.dataset.title.localeCompare(b.dataset.title);
            if (val === 'read') return parseInt(a.dataset.readtime) - parseInt(b.dataset.readtime);
            return 0;
        });
        sorted.forEach(function (c) { list.appendChild(c); });
    });
})();
</script>
{% endblock %}
