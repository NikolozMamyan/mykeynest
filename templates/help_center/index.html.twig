{% extends 'base_auth.html.twig' %}

{% block title %}{{ app.request.locale == 'en' ? 'Cybersecurity Help Center for SMBs | MYKEYNEST' : 'Centre d aide cybersécurité PME | MYKEYNEST' }}{% endblock %}

{% block meta_description %}
<meta name="description" content="{{ app.request.locale == 'en' ? 'Help center for SMB cybersecurity, password manager setup, phishing awareness, browser extension support, and secure password best practices.' : 'Centre d aide sur la cybersécurité PME, le gestionnaire de mots de passe, le phishing, l extension navigateur et les bonnes pratiques pour sécuriser les mots de passe.' }}">
<meta name="keywords" content="{{ app.request.locale == 'en' ? 'help center password manager, SMB cybersecurity help, phishing awareness, secure password guide, browser extension support' : 'centre aide cybersécurité PME, aide gestionnaire de mot de passe, sécuriser mots de passe PME, phishing entreprise, support extension navigateur' }}">
<meta property="og:title" content="{{ app.request.locale == 'en' ? 'Cybersecurity Help Center for SMBs | MYKEYNEST' : 'Centre d aide cybersécurité PME | MYKEYNEST' }}">
<meta property="og:description" content="{{ app.request.locale == 'en' ? 'Guides and answers about passwords, phishing, browser extension setup, and SMB cybersecurity.' : 'Guides et réponses sur les mots de passe, le phishing, l extension navigateur et la cybersécurité PME.' }}">
<meta property="og:type" content="website">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/pages/help-center.css') }}">
{% endblock %}

{% block seo_jsonld %}
{% set localeParams = app.request.locale == 'en' ? { lang: 'en' } : {} %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "{{ app.request.locale == 'en' ? 'Home' : 'Accueil' }}",
          "item": "{{ absolute_url(path('app_landing', localeParams)) }}"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "{{ app.request.locale == 'en' ? 'Help center' : 'Centre d aide' }}",
          "item": "{{ absolute_url(path('app_help_center', localeParams)) }}"
        }
      ]
    },
    {
      "@type": "CollectionPage",
      "name": "{{ app.request.locale == 'en' ? 'MYKEYNEST Help Center' : 'Centre d aide MYKEYNEST' }}",
      "url": "{{ absolute_url(path('app_help_center', localeParams)) }}",
      "inLanguage": "{{ app.request.locale|default('fr') }}",
      "description": "{{ 'help_center.hero.subtitle'|trans|e('js') }}"
    }
  ]
}
</script>
{% endblock %}

{% block body %}
<main data-controller="help-center">

    {# Hero #}
    <section class="hc-hero">
        <div class="hc-hero-inner">
            <div class="hc-eyebrow">
                <i class="fa-solid fa-circle-question" aria-hidden="true"></i>
                {{ 'help_center.hero.eyebrow'|trans }}
            </div>

            <h1>
                {{ 'help_center.hero.title_line1'|trans }}<br>
                <span class="hc-grad">{{ 'help_center.hero.title_highlight'|trans }}</span>
            </h1>

            <p>{{ 'help_center.hero.subtitle'|trans }}</p>

            <div class="hc-search-wrap">
                <svg class="hc-search-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
                </svg>

                <input
                    type="search"
                    id="hcSearch"
                    class="hc-search-input"
                    placeholder="{{ 'help_center.search.placeholder'|trans }}"
                    autocomplete="off"
                    aria-label="{{ 'help_center.search.aria'|trans }}"
                    data-help-center-target="searchInput"
                    data-action="input->help-center#filter"
                >

                <button class="hc-search-clear" id="hcSearchClear" aria-label="{{ 'help_center.search.clear_aria'|trans }}" hidden data-help-center-target="clearButton" data-action="click->help-center#clear">&times;</button>
            </div>

            {% set isEn = app.request.locale == 'en' %}
            <div class="hc-quick-links" aria-label="{{ isEn ? 'Help center shortcuts' : 'Raccourcis centre d aide' }}">
                <a href="{{ path('app_help_category', { slug: 'demarrer' }) }}" class="hc-quick-link">
                    <i class="fa-solid fa-rocket" aria-hidden="true"></i>
                    <span>{{ isEn ? 'Getting started' : 'Demarrer' }}</span>
                </a>
                <a href="{{ path('app_help_category', { slug: 'securite' }) }}" class="hc-quick-link">
                    <i class="fa-solid fa-lock" aria-hidden="true"></i>
                    <span>{{ isEn ? 'Security' : 'Securite' }}</span>
                </a>
                <a href="{{ path('app_help_category', { slug: 'extension' }) }}" class="hc-quick-link">
                    <i class="fa-solid fa-puzzle-piece" aria-hidden="true"></i>
                    <span>{{ isEn ? 'Extension' : 'Extension' }}</span>
                </a>
                <a href="{{ path('app_public_generator') }}" class="hc-quick-link">
                    <i class="fa-solid fa-key" aria-hidden="true"></i>
                    <span>{{ isEn ? 'Generator' : 'Generateur' }}</span>
                </a>
            </div>
        </div>
    </section>

    {# Stats #}
    <div class="hc-stats" aria-label="{{ 'help_center.stats.aria'|trans }}">
        <div class="hc-stat">
            <div class="hc-stat-number">{{ totalArticles }}</div>
            <div class="hc-stat-label">{{ 'help_center.stats.articles'|trans }}</div>
        </div>
        <div class="hc-stat">
            <div class="hc-stat-number">{{ categories|length }}</div>
            <div class="hc-stat-label">{{ 'help_center.stats.categories'|trans }}</div>
        </div>
        <div class="hc-stat">
            <div class="hc-stat-number">&lt; 2h</div>
            <div class="hc-stat-label">{{ 'help_center.stats.response_time'|trans }}</div>
        </div>
        <div class="hc-stat">
            <div class="hc-stat-number">98%</div>
            <div class="hc-stat-label">{{ 'help_center.stats.satisfaction'|trans }}</div>
        </div>
    </div>

    <div class="hc-layout">
        <section class="hc-summary" aria-labelledby="hc-summary-title">
            <div class="hc-summary-copy">
                <div class="hc-section-label">{{ isEn ? 'Product support' : 'Support produit' }}</div>
                <h2 class="hc-section-title" id="hc-summary-title">{{ isEn ? 'Clear answers, practical guides, faster paths' : 'Reponses claires, guides concrets, parcours plus direct' }}</h2>
                <p class="hc-section-sub">{{ isEn ? 'The MYKEYNEST help center is organized to resolve account, security, sharing, browser extension, and billing questions quickly.' : 'Le centre d aide MYKEYNEST est organise pour resoudre rapidement les questions de compte, securite, partage, extension navigateur et abonnement.' }}</p>
            </div>
            <div class="hc-summary-points">
                <div class="hc-summary-point">
                    <i class="fa-solid fa-shield-halved" aria-hidden="true"></i>
                    <div>
                        <strong>{{ isEn ? 'Reliable documentation' : 'Base documentaire fiable' }}</strong>
                        <p>{{ isEn ? 'Short, connected articles organized by category and built for quick resolution.' : 'Des articles courts, relies entre eux et mis a jour par categorie.' }}</p>
                    </div>
                </div>
                <div class="hc-summary-point">
                    <i class="fa-solid fa-compass" aria-hidden="true"></i>
                    <div>
                        <strong>{{ isEn ? 'More useful navigation' : 'Navigation plus utile' }}</strong>
                        <p>{{ isEn ? 'Direct access to critical topics without a demo-style browsing experience.' : 'Acces direct aux sujets critiques sans passer par un parcours de demo.' }}</p>
                    </div>
                </div>
                <div class="hc-summary-point">
                    <i class="fa-solid fa-life-ring" aria-hidden="true"></i>
                    <div>
                        <strong>{{ isEn ? 'Support handoff' : 'Passerelle vers le support' }}</strong>
                        <p>{{ isEn ? 'Support remains reachable when documentation alone is not enough.' : 'Le support reste accessible quand la documentation ne suffit pas.' }}</p>
                    </div>
                </div>
            </div>
        </section>

        {# Categories #}
        <div class="hc-section-label">{{ 'help_center.sections.explore_label'|trans }}</div>
        <h2 class="hc-section-title">{{ 'help_center.sections.all_categories_title'|trans }}</h2>
        <p class="hc-section-sub">{{ 'help_center.sections.all_categories_sub'|trans }}</p>

        <div class="hc-categories" id="hcCategories">
            {% for cat in categories %}
                <a href="{{ path('app_help_category', { slug: cat.slug }) }}"
                   class="hc-cat-card"
                   data-tags="{{ cat.tags }}"
                   data-help-center-target="category">
                    <div class="hc-cat-icon" aria-hidden="true"><i class="{{ cat.iconClass }}"></i></div>
                    <div class="hc-cat-title">{{ cat.title }}</div>
                    <p class="hc-cat-desc">{{ cat.description }}</p>
                    <div class="hc-cat-meta">
                        <span class="hc-cat-count">
                            {{ 'help_center.category.articles_count'|trans({ count: cat.articleCount }) }}
                        </span>
                        <svg class="hc-cat-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                    </div>
                </a>
            {% endfor %}
        </div>

        {# No results message #}
        <div class="hc-no-results" id="hcNoResults" aria-live="polite" hidden data-help-center-target="noResults">
            <div class="hc-no-results-icon"><i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i></div>
            <p class="hc-no-results-title">
                {{ 'help_center.no_results.title'|trans }}
            </p>
            <p>
                {{ 'help_center.no_results.text'|trans }}
                <a href="mailto:contact@key-nest.com" class="hc-no-results-link">
                    {{ 'help_center.no_results.contact'|trans }}
                </a>.
            </p>
        </div>

        {# Popular Articles + Sidebar #}
        <div class="hc-two-col">
            <div>
                <div class="hc-section-label">{{ 'help_center.popular.label'|trans }}</div>
                <h2 class="hc-section-title">{{ 'help_center.popular.title'|trans }}</h2>
                <p class="hc-section-sub hc-popular-sub">
                    {{ 'help_center.popular.sub'|trans }}
                </p>

                <div class="hc-popular-list">
                    {% for article in popularArticles %}
                        <a href="{{ path('app_help_article', { categorySlug: article.categorySlug, articleSlug: article.articleSlug }) }}"
                           class="hc-article-row">
                            <div class="hc-article-num" aria-hidden="true">
                                <i class="fa-solid fa-file-lines"></i>
                            </div>
                            <div class="hc-article-info">
                                <div class="hc-article-title">{{ article.title }}</div>
                                <div class="hc-article-cat">{{ article.categoryTitle }}</div>
                            </div>
                            <svg class="hc-article-row-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                            </svg>
                        </a>
                    {% endfor %}
                </div>
            </div>

            {# Sidebar #}
            <aside class="hc-sidebar" aria-label="{{ 'help_center.sidebar.aria'|trans }}">
                <div class="hc-contact-card">
                    <div class="hc-contact-icon-wrap">
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                        </svg>
                    </div>
                    <div class="hc-contact-title">{{ 'help_center.sidebar.write.title'|trans }}</div>
                    <p class="hc-contact-desc">{{ 'help_center.sidebar.write.desc'|trans }}</p>
                    <a href="mailto:contact@key-nest.com" class="hc-contact-btn">
                        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8"/>
                        </svg>
                        {{ 'help_center.sidebar.write.cta'|trans }}
                    </a>
                </div>

                <div class="hc-contact-card">
                    <div class="hc-contact-icon-wrap">
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                    </div>
                    <div class="hc-contact-title">
                        <span class="hc-status-dot"></span>
                        {{ 'help_center.sidebar.status.title'|trans }}
                    </div>
                    <p class="hc-contact-desc">{{ 'help_center.sidebar.status.desc'|trans }}</p>
                    <a href="#" class="hc-contact-btn hc-contact-btn-outline">
                        {{ 'help_center.sidebar.status.cta'|trans }}
                    </a>
                </div>
            </aside>
        </div>

        {# FAQ Accordion #}
        <div class="hc-faq-section">
            <div class="hc-section-label">{{ 'help_center.faq.label'|trans }}</div>
            <h2 class="hc-section-title">{{ 'help_center.faq.title'|trans }}</h2>
            <p class="hc-section-sub hc-faq-sub">{{ 'help_center.faq.sub'|trans }}</p>

            <div class="hc-faq-list" role="list" data-controller="faq-accordion">

                {% for i in 1..5 %}
                    <div class="hc-faq-item" role="listitem" data-faq-accordion-target="item">
                        <button class="hc-faq-trigger" aria-expanded="false" data-faq-accordion-target="button" data-action="click->faq-accordion#toggle">
                            <span class="hc-faq-q">{{ ('help_center.faq.items.q' ~ i)|trans }}</span>
                            <svg class="hc-faq-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                            </svg>
                        </button>
                        <div class="hc-faq-body" role="region">
                            <p>{{ ('help_center.faq.items.a' ~ i)|trans }}</p>
                        </div>
                    </div>
                {% endfor %}

            </div>
        </div>

        {# CTA Banner #}
        <div class="hc-cta">
            <div class="hc-cta-text">
                <div class="hc-cta-title">{{ 'help_center.cta.title'|trans }}</div>
                <div class="hc-cta-desc">{{ 'help_center.cta.desc'|trans }}</div>
            </div>
            <div class="hc-cta-actions">
                <a href="mailto:contact@key-nest.com" class="hc-cta-btn-white">{{ 'help_center.cta.support'|trans }}</a>
                <a href="{{ path('show_register') }}" class="hc-cta-btn-ghost">{{ 'help_center.cta.create_account'|trans }}</a>
            </div>
        </div>

    </div>
</main>

{% endblock %}

