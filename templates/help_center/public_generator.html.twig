{% extends 'base_auth.html.twig' %}

{% block title %}{{ app.request.locale == 'en' ? 'Free Secure Password Generator | MYKEYNEST' : 'Generateur de mot de passe securise gratuit | MYKEYNEST' }}{% endblock %}

{% block meta_description %}
{% set localeParams = app.request.locale == 'en' ? { lang: 'en' } : {} %}
<meta name="description" content="{{ 'public_generator.hero.subtitle'|trans }}">
<meta property="og:title" content="{{ app.request.locale == 'en' ? 'Free Secure Password Generator | MYKEYNEST' : 'Generateur de mot de passe securise gratuit | MYKEYNEST' }}">
<meta property="og:description" content="{{ 'public_generator.hero.subtitle'|trans }}">
<meta property="og:type" content="website">
<meta name="twitter:card" content="summary_large_image">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "{{ app.request.locale == 'en' ? 'Home' : 'Accueil' }}",
          "item": "{{ absolute_url(path('app_landing', localeParams)) }}"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "{{ app.request.locale == 'en' ? 'Help center' : 'Centre d aide' }}",
          "item": "{{ absolute_url(path('app_help_center', localeParams)) }}"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "{{ app.request.locale == 'en' ? 'Password generator' : 'Generateur de mot de passe' }}",
          "item": "{{ absolute_url(path('app_public_generator', localeParams)) }}"
        }
      ]
    },
    {
      "@type": "WebPage",
      "name": "{{ app.request.locale == 'en' ? 'MYKEYNEST Password Generator' : 'Generateur de mot de passe MYKEYNEST' }}",
      "url": "{{ absolute_url(path('app_public_generator', localeParams)) }}",
      "inLanguage": "{{ app.request.locale|default('fr') }}",
      "description": "{{ 'public_generator.hero.subtitle'|trans|e('js') }}"
    }
  ]
}
</script>
{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/pages/public-generator.css') }}">
{% endblock %}

{% block body %}
{% set isEn = app.request.locale == 'en' %}
{% set featureIcons = [
    'fa-solid fa-shield-halved',
    'fa-solid fa-bolt',
    'fa-solid fa-lock',
    'fa-solid fa-sliders',
    'fa-solid fa-chart-column',
    'fa-solid fa-copy'
] %}

<main class="pg-page">
    <section class="hero-section">
        <div class="hero-content">
            <div class="hero-badge">
                <i class="fa-solid fa-lock" aria-hidden="true"></i>
                {{ isEn ? 'Secure browser-side generation' : 'Generation securisee cote navigateur' }}
            </div>

            <h1>
                {{ 'public_generator.hero.title_before'|trans }}
                <span class="hero-gradient-text">{{ 'public_generator.hero.title_highlight'|trans }}</span><br>
                {{ 'public_generator.hero.title_after'|trans }}
            </h1>

            <p class="hero-subtitle">{{ 'public_generator.hero.subtitle'|trans }}</p>

            <div class="trust-indicators">
                <div class="trust-item">{{ 'public_generator.hero.trust.no_storage'|trans }}</div>
                <div class="trust-item">{{ 'public_generator.hero.trust.client_side'|trans }}</div>
                <div class="trust-item">{{ 'public_generator.hero.trust.open_source'|trans }}</div>
            </div>
        </div>
    </section>

    <section class="generator-container">
        <div class="generator-card">
            <div class="password-display">
                <div class="password-output">
                    <div id="generatedPassword">{{ 'public_generator.generator.placeholder'|trans }}</div>

                    <div class="password-actions">
                        <button class="icon-btn" id="copyBtn" type="button" title="{{ 'public_generator.generator.actions.copy'|trans }}" aria-label="{{ 'public_generator.generator.actions.copy'|trans }}">
                            <i class="fa-regular fa-copy" aria-hidden="true"></i>
                        </button>

                        <button class="icon-btn" id="regenerateBtn" type="button" title="{{ 'public_generator.generator.actions.regenerate'|trans }}" aria-label="{{ 'public_generator.generator.actions.regenerate'|trans }}">
                            <i class="fa-solid fa-rotate-right" aria-hidden="true"></i>
                        </button>
                    </div>
                </div>
            </div>

            <div class="strength-meter" id="strengthMeter">
                <div class="strength-label">
                    <span class="strength-text">{{ 'public_generator.generator.strength.label'|trans }}</span>
                    <span class="strength-value" id="strengthText">{{ 'public_generator.generator.strength.value'|trans }}</span>
                </div>
                <div class="strength-bar">
                    <div class="strength-fill" id="strengthFill"></div>
                </div>
            </div>

            <div class="controls-section">
                <div class="control-group">
                    <div class="control-label">
                        <span>{{ 'public_generator.generator.length.label'|trans }}</span>
                        <span class="control-value" id="lengthValue">16</span>
                    </div>
                    <input type="range" id="lengthSlider" class="slider" min="8" max="64" value="16">
                </div>

                <div class="options-grid">
                    <div class="checkbox-wrapper">
                        <input type="checkbox" id="includeUppercase" class="checkbox-input" checked>
                        <label for="includeUppercase" class="checkbox-label">
                            <span class="checkbox-custom"></span>
                            <span class="checkbox-text">{{ 'public_generator.generator.options.uppercase'|trans }}</span>
                        </label>
                    </div>

                    <div class="checkbox-wrapper">
                        <input type="checkbox" id="includeLowercase" class="checkbox-input" checked>
                        <label for="includeLowercase" class="checkbox-label">
                            <span class="checkbox-custom"></span>
                            <span class="checkbox-text">{{ 'public_generator.generator.options.lowercase'|trans }}</span>
                        </label>
                    </div>

                    <div class="checkbox-wrapper">
                        <input type="checkbox" id="includeNumbers" class="checkbox-input" checked>
                        <label for="includeNumbers" class="checkbox-label">
                            <span class="checkbox-custom"></span>
                            <span class="checkbox-text">{{ 'public_generator.generator.options.numbers'|trans }}</span>
                        </label>
                    </div>

                    <div class="checkbox-wrapper">
                        <input type="checkbox" id="includeSymbols" class="checkbox-input" checked>
                        <label for="includeSymbols" class="checkbox-label">
                            <span class="checkbox-custom"></span>
                            <span class="checkbox-text">{{ 'public_generator.generator.options.symbols'|trans }}</span>
                        </label>
                    </div>
                </div>
            </div>

            <button class="generate-btn" id="generateBtn" type="button">
                <span>
                    <i class="fa-solid fa-key" aria-hidden="true"></i>
                    {{ 'public_generator.generator.generate_button'|trans }}
                </span>
            </button>
        </div>
    </section>

    <section class="features-section">
        <div class="section-header">
            <h2 class="section-title">{{ 'public_generator.features.title'|trans }}</h2>
            <p class="section-subtitle">{{ 'public_generator.features.subtitle'|trans }}</p>
        </div>

        <div class="features-grid">
            {% for idx in 0..5 %}
                <article class="feature-card">
                    <div class="feature-icon"><i class="{{ featureIcons[idx] }}" aria-hidden="true"></i></div>
                    <h3 class="feature-title">{{ ('public_generator.features.items.' ~ idx ~ '.title')|trans }}</h3>
                    <p class="feature-description">{{ ('public_generator.features.items.' ~ idx ~ '.description')|trans }}</p>
                </article>
            {% endfor %}
        </div>
    </section>

    <section class="seo-content">
        <article itemscope itemtype="https://schema.org/Article">
            <h2 itemprop="headline">{{ 'public_generator.seo.title'|trans }}</h2>

            <div itemprop="articleBody">
                <p>{{ 'public_generator.seo.intro'|trans }}</p>

                <h2>{{ 'public_generator.seo.good_password_title'|trans }}</h2>
                <p>{{ 'public_generator.seo.good_password_text'|trans }}</p>

                <h2>{{ 'public_generator.seo.why_generator_title'|trans }}</h2>
                <p>{{ 'public_generator.seo.why_generator_text'|trans }}</p>

                <h2>{{ 'public_generator.seo.tips_title'|trans }}</h2>
                <ul>
                    {% for idx in 0..5 %}
                        <li>{{ ('public_generator.seo.tips.' ~ idx)|trans }}</li>
                    {% endfor %}
                </ul>

                <h2>{{ 'public_generator.seo.tech_title'|trans }}</h2>
                <p>{{ 'public_generator.seo.tech_text'|trans }}</p>
            </div>
        </article>
    </section>

    <section class="cta-section">
        <div class="cta-content">
            <h2 class="cta-title" style="color:white;">{{ 'public_generator.cta.title'|trans }}</h2>
            <p class="cta-description" style="color:white;">{{ 'public_generator.cta.description'|trans }}</p>
            <a href="{{ path('show_register') }}" class="cta-btn">{{ 'public_generator.cta.button'|trans }}</a>
        </div>
    </section>
</main>

<script>
(function () {
    var generatedPassword = document.getElementById('generatedPassword');
    var generateBtn = document.getElementById('generateBtn');
    var regenerateBtn = document.getElementById('regenerateBtn');
    var copyBtn = document.getElementById('copyBtn');
    var strengthMeter = document.getElementById('strengthMeter');
    var strengthFill = document.getElementById('strengthFill');
    var strengthText = document.getElementById('strengthText');
    var lengthSlider = document.getElementById('lengthSlider');
    var lengthValue = document.getElementById('lengthValue');
    var placeholder = {{ 'public_generator.generator.placeholder'|trans|json_encode|raw }};
    var messages = {
        noOption: {{ (isEn ? 'Select at least one option' : 'Selectionnez au moins une option')|json_encode|raw }},
        weak: {{ (isEn ? 'Weak' : 'Faible')|json_encode|raw }},
        medium: {{ (isEn ? 'Medium' : 'Moyenne')|json_encode|raw }},
        strong: {{ (isEn ? 'Strong' : 'Forte')|json_encode|raw }},
        copied: {{ (isEn ? 'Copied' : 'Copie')|json_encode|raw }}
    };

    function selectedPools() {
        var pools = [];
        if (document.getElementById('includeUppercase').checked) pools.push('ABCDEFGHIJKLMNOPQRSTUVWXYZ');
        if (document.getElementById('includeLowercase').checked) pools.push('abcdefghijklmnopqrstuvwxyz');
        if (document.getElementById('includeNumbers').checked) pools.push('0123456789');
        if (document.getElementById('includeSymbols').checked) pools.push('!@#$%^&*()_+-=[]{}|;:,.<>?');
        return pools;
    }

    function securePick(pool) {
        var random = new Uint32Array(1);
        crypto.getRandomValues(random);
        return pool[random[0] % pool.length];
    }

    function generatePassword() {
        var pools = selectedPools();
        var length = parseInt(lengthSlider.value, 10);

        if (!pools.length) {
            generatedPassword.textContent = messages.noOption;
            updateStrength('');
            return '';
        }

        var combined = pools.join('');
        var chars = [];

        pools.forEach(function (pool) {
            chars.push(securePick(pool));
        });

        while (chars.length < length) {
            chars.push(securePick(combined));
        }

        for (var i = chars.length - 1; i > 0; i--) {
            var random = new Uint32Array(1);
            crypto.getRandomValues(random);
            var j = random[0] % (i + 1);
            var tmp = chars[i];
            chars[i] = chars[j];
            chars[j] = tmp;
        }

        var password = chars.slice(0, length).join('');
        generatedPassword.textContent = password;
        updateStrength(password);
        return password;
    }

    function updateStrength(password) {
        var strength = 0;
        if (password.length >= 8) strength += 20;
        if (password.length >= 12) strength += 20;
        if (password.length >= 16) strength += 10;
        if (/[a-z]/.test(password)) strength += 15;
        if (/[A-Z]/.test(password)) strength += 15;
        if (/[0-9]/.test(password)) strength += 10;
        if (/[^a-zA-Z0-9]/.test(password)) strength += 10;

        strengthFill.style.width = strength + '%';
        strengthMeter.classList.remove('strength-weak', 'strength-medium', 'strength-strong');

        if (strength < 50) {
            strengthMeter.classList.add('strength-weak');
            strengthText.textContent = messages.weak;
            strengthText.style.color = 'var(--color-danger-start)';
        } else if (strength < 80) {
            strengthMeter.classList.add('strength-medium');
            strengthText.textContent = messages.medium;
            strengthText.style.color = 'var(--color-warning)';
        } else {
            strengthMeter.classList.add('strength-strong');
            strengthText.textContent = messages.strong;
            strengthText.style.color = 'var(--color-success)';
        }
    }

    function copyToClipboard() {
        var password = generatedPassword.textContent;
        if (!password || password === placeholder || password === messages.noOption) {
            return;
        }

        navigator.clipboard.writeText(password).then(function () {
            var original = copyBtn.innerHTML;
            copyBtn.innerHTML = '<i class="fa-solid fa-check" aria-hidden="true"></i>';
            setTimeout(function () {
                copyBtn.innerHTML = original;
            }, 1200);
        }).catch(function () {
            window.prompt('Copy password', password);
        });
    }

    function updateSliderBackground(slider) {
        var value = (slider.value - slider.min) / (slider.max - slider.min) * 100;
        slider.style.background = 'linear-gradient(to right, var(--color-primary) 0%, var(--color-primary) ' + value + '%, var(--color-bg-light) ' + value + '%, var(--color-bg-light) 100%)';
    }

    generateBtn.addEventListener('click', generatePassword);
    regenerateBtn.addEventListener('click', generatePassword);
    copyBtn.addEventListener('click', copyToClipboard);

    lengthSlider.addEventListener('input', function (event) {
        lengthValue.textContent = event.target.value;
        updateSliderBackground(event.target);
        if (generatedPassword.textContent !== placeholder) {
            generatePassword();
        }
    });

    ['includeUppercase', 'includeLowercase', 'includeNumbers', 'includeSymbols'].forEach(function (id) {
        document.getElementById(id).addEventListener('change', function () {
            if (generatedPassword.textContent !== placeholder) {
                generatePassword();
            }
        });
    });

    updateSliderBackground(lengthSlider);
    window.addEventListener('load', generatePassword);
})();
</script>
{% endblock %}
