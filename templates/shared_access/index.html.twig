{% extends 'base.html.twig' %}

{% block title %}Identifiants partag&eacute;s{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/pages/shared-access-index.css') }}">
{% endblock %}

{% block body %}
<div data-controller="shared-access-index">

  <!-- Hero Section -->
  <div class="hero-section">
    <div class="hero-content">
      <div class="hero-text">
        <h1 class="hero-title">{{ 'shared_access.index.hero.title'|trans }}</h1>
        <p class="hero-subtitle">{{ 'shared_access.index.hero.subtitle'|trans }}</p>
      </div>

{% if app.user.hasActiveSubscription or sharedByMe|length < 3 %}
  <a href="{{ path('shared_access_new') }}" class="btn-primary">
    <i class="fas fa-share-alt"></i>
    <span>{{ 'shared_access.index.hero.new'|trans }}</span>
  </a>
{% else %}
  <div class="btn-primary btn-disabled" title="Passez &agrave; PRO pour partager plus d&apos;acc&egrave;s">
    <i class="fas fa-lock"></i>
    <span>{{ 'shared_access.index.hero.new'|trans }}</span>
  </div>
{% endif %}
    </div>
  </div>
{# PRO Upgrade Banner - Affich? seulement si non abonn? et a d?j? 3 partages #}
{% if not app.user.hasActiveSubscription and sharedByMe|length >= 3 %}
  <div class="pro-upgrade-banner">
    <div class="pro-banner-content">
      <div class="pro-banner-icon">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
        </svg>
      </div>
      <div class="pro-banner-text">
        <h3>{{ 'shared_access.pro_banner.title'|trans|default('Limite de partage atteinte !') }}</h3>
        <p>{{ 'shared_access.pro_banner.description'|trans|default('Vous avez atteint la limite de 3 partages d&apos;acc&egrave;s. Passez &agrave; PRO pour des partages illimit&eacute;s et collaborez sans restriction.')|raw }}</p>
        <div class="limit-info">
          <i class="fas fa-users"></i>
          <span>{{ sharedByMe|length }}/3 partages utilis&eacute;s</span>
        </div>
      </div>
    </div>
    <a href="{{ path('app_subscription') }}" class="btn-upgrade-pro">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
      </svg>
      {{ 'shared_access.pro_banner.action'|trans|default('Passer &agrave; PRO')|raw }}
    </a>
  </div>
{% endif %}
  <!-- Tabs -->
  <div class="tabs-wrapper">
    <div class="tabs-header">
      <button class="tab-btn active" data-tab="shared-by-me" data-action="click->shared-access-index#switchTab">
        <i class="fas fa-share-alt"></i>
        <span>{{ 'shared_access.index.tabs.shared_by_me'|trans }}</span>
        <span class="tab-badge">{{ sharedByMe|length }}</span>
      </button>

      <button class="tab-btn" data-tab="shared-with-me" data-action="click->shared-access-index#switchTab">
        <i class="fas fa-inbox"></i>
        <span>{{ 'shared_access.index.tabs.shared_with_me'|trans }}</span>
        <span class="tab-badge">{{ sharedWithMe|length }}</span>
      </button>
    </div>

    <!-- Tab Content: Shared by me -->
    <div id="shared-by-me" class="tab-panel active">
      {% if sharedByMe is empty %}
        <div class="empty-state">
          <div class="empty-illustration">
            <div class="empty-icon-wrapper">
              <i class="fas fa-share-alt"></i>
            </div>
          </div>

          <h3 class="empty-title">{{ 'shared_access.index.empty.by_me.title'|trans }}</h3>
          <p class="empty-description">{{ 'shared_access.index.empty.by_me.text'|trans }}</p>

          <a href="{{ path('shared_access_new') }}" class="btn-primary-outline">
            <i class="fas fa-plus"></i>
            <span>{{ 'shared_access.index.empty.by_me.cta'|trans }}</span>
          </a>
        </div>
      {% else %}
        <div class="access-grid">
          {% for access in sharedByMe %}
            <div class="access-card">
              <div class="card-content">
                <!-- Header -->
                <div class="card-top">
                  <div class="credential-avatar color-{{ loop.index % 5 }}">
                    <span>{{ access.credential.name|first|upper }}</span>
                  </div>
                  <div class="credential-details">
                    <h3 class="credential-title">{{ access.credential.name }}</h3>
                    <div class="credential-meta">
                      <i class="fas fa-globe"></i>
                      <span>{{ access.credential.domain }}</span>
                    </div>
                  </div>
                </div>

                <!-- Body -->
                <div class="card-body">
                  <div class="info-row">
                    <span class="info-label">{{ 'shared_access.index.labels.shared_with'|trans }}</span>
                    <div class="user-badge">
                      <div class="user-avatar-sm color-{{ (loop.index * 3) % 5 }}">
                        {{ access.guest.email|first|upper }}
                      </div>
                      <div class="user-details">
                        <span class="user-name">{{ access.guest.company }}</span>
                        <span class="user-email">{{ access.guest.email }}</span>
                      </div>
                    </div>
                  </div>

                  <div class="info-row">
                    <span class="info-label">{{ 'shared_access.index.labels.shared_date'|trans }}</span>
                    <div class="date-badge">
                      <i class="far fa-calendar-alt"></i>
                      <span>{{ access.createdAt|date('d/m/Y') }}</span>
                    </div>
                  </div>
                </div>

                <!-- Footer -->
                <div class="card-footer">
                  <form method="post"
                        action="{{ path('shared_access_revoke', {'id': access.id}) }}"
                        class="revoke-form"
                        data-action="submit->shared-access-index#handleFormSubmit">
                    <input type="hidden" name="_token" value="{{ csrf_token('revoke' ~ access.id) }}">
                    <button type="button" class="btn-danger revoke-btn" data-id="{{ access.id }}" data-action="click->shared-access-index#openRevokeModal">
                      <i class="fas fa-user-slash"></i>
                      <span>{{ 'shared_access.index.actions.revoke'|trans }}</span>
                    </button>
                  </form>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <!-- Tab Content: Shared with me -->
    <div id="shared-with-me" class="tab-panel">
      {% if sharedWithMe is empty %}
        <div class="empty-state">
          <div class="empty-illustration">
            <div class="empty-icon-wrapper">
              <i class="fas fa-inbox"></i>
            </div>
          </div>
          <h3 class="empty-title">{{ 'shared_access.index.empty.with_me.title'|trans }}</h3>
          <p class="empty-description">{{ 'shared_access.index.empty.with_me.text'|trans }}</p>
        </div>
      {% else %}
        <div class="access-grid">
          {% for access in sharedWithMe %}
            <div class="access-card">
              <div class="card-content">
                <!-- Header -->
                <div class="card-top">
                  <div class="credential-avatar color-{{ loop.index % 5 }}">
                    <span>{{ access.credential.name|first|upper }}</span>
                  </div>
                  <div class="credential-details">
                    <h3 class="credential-title">{{ access.credential.name }}</h3>
                    <div class="credential-meta">
                      <i class="fas fa-globe"></i>
                      <span>{{ access.credential.domain }}</span>
                    </div>
                  </div>
                </div>

                <!-- Body -->
                <div class="card-body">
                  <div class="info-row">
                    <span class="info-label">{{ 'shared_access.index.labels.shared_by'|trans }}</span>
                    <div class="user-badge">
                      <div class="user-avatar-sm color-{{ (loop.index * 3) % 5 }}">
                        {{ access.owner.email|first|upper }}
                      </div>
                      <div class="user-details">
                        <span class="user-name">{{ access.owner.company }}</span>
                        <span class="user-email">{{ access.owner.email }}</span>
                      </div>
                    </div>
                  </div>

                  <div class="info-row">
                    <span class="info-label">{{ 'shared_access.index.labels.shared_date'|trans }}</span>
                    <div class="date-badge">
                      <i class="far fa-calendar-alt"></i>
                      <span>{{ access.createdAt|date('d/m/Y') }}</span>
                    </div>
                  </div>
                </div>

                <!-- Footer -->
                <div class="card-footer">
                  <a href="{{ path('shared_access_view_credential', {'id': access.id}) }}" class="btn-view">
                    <i class="fas fa-key"></i>
                    <span>{{ 'shared_access.index.actions.view_credentials'|trans }}</span>
                  </a>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>

  <!-- Revoke Modal -->
  <div id="revoke-modal" class="modal"
       data-loading-text="{{ 'shared_access.index.modal.loading'|trans|e('html_attr') }}">
    <div class="modal-overlay" data-action="click->shared-access-index#closeRevokeModal"></div>
    <div class="modal-dialog">
      <div class="modal-header">
        <h3 class="modal-title">{{ 'shared_access.index.modal.title'|trans }}</h3>
        <button class="modal-close" data-action="click->shared-access-index#closeRevokeModal">
          <i class="fas fa-times"></i>
        </button>
      </div>

      <div class="modal-body">
        <div class="warning-box">
          <i class="fas fa-exclamation-triangle"></i>
          <div>
            <p class="warning-title">{{ 'shared_access.index.modal.warning_title'|trans }}</p>
            <p class="warning-text">{{ 'shared_access.index.modal.warning_text'|trans }}</p>
          </div>
        </div>
      </div>

      <div class="modal-footer">
        <button id="cancel-revoke" class="btn-secondary" data-action="click->shared-access-index#closeRevokeModal">
          {{ 'shared_access.index.modal.cancel'|trans }}
        </button>

        <button id="confirm-revoke" class="btn-danger-confirm"
                data-action="click->shared-access-index#confirmRevoke"
                data-default-text="{{ 'shared_access.index.modal.confirm'|trans|e('html_attr') }}">
          <i class="fas fa-user-slash"></i>
          <span>{{ 'shared_access.index.modal.confirm'|trans }}</span>
        </button>
      </div>
    </div>
  </div>


</div>
{% endblock %}

