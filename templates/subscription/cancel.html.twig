{% extends 'base.html.twig' %}

{% block title %}Paiement annulé{% endblock %}

{% block body %}
<div class="subscription-result cancel">

    <div class="icon">❌</div>

    <h1>Paiement annulé</h1>

    <p>
        Aucun paiement n’a été effectué.  
        Tu peux réessayer quand tu veux.
    </p>

    <div class="actions">
        <a href="{{ path('app_subscription_checkout_pro') }}" class="btn primary">
            Réessayer
        </a>

        <a href="{{ path('app_subscription') }}" class="btn secondary">
            Retour aux abonnements
        </a>
    </div>

</div>

<style>
.subscription-result {
    max-width: 520px;
    margin: 80px auto;
    text-align: center;
    padding: 2rem;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    box-shadow: var(--shadow-sm);
}
.icon {
    font-size: 64px;
    margin-bottom: 20px;
}
.subscription-result h1 {
    color: var(--color-text-dark);
    margin-bottom: 0.75rem;
}
.subscription-result p {
    color: var(--color-text-muted);
}
.actions {
    margin-top: 30px;
    display: flex;
    justify-content: center;
    gap: 15px;
    flex-wrap: wrap;
}
.btn {
    padding: 12px 22px;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
}
.btn.primary {
    background: linear-gradient(135deg, var(--color-danger-start), var(--color-danger-end));
    color: var(--color-white);
}
.btn.secondary {
    border: 1px solid var(--color-border);
    color: var(--color-text-dark);
    background: var(--color-bg-light);
}
</style>
{% endblock %}
